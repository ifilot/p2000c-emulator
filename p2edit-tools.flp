        DB      '^X  Exit                ^G/Esc Help',13,10,13,10
        DB      'The * in the header m     CALL    PUTC
        MOV     A,C
        ADI     20H
        JMP     PUTC

PUTC:   PUSH    B
        PUSH    D
        PUSH    H
        MOV     E,A
        MVI     C,CONOUT
        CALL    BDOS
        POP     H
        POP     D
       eans the buffer has changed.',13,10

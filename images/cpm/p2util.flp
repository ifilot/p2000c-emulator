╔═Řçççç§═Ř┴H▒╔═.2B!2ćw:B╔!Ds+q*C&␀═Ź:D═╔├␀␀├␀├␀═␀╔╔╔Ű_␀Űůoîg╔_␀{Áoz┤g╔^#VŰ)┬Ź╔_␀{Ľozťg╔i`N#FĹośg╔o&␀Ľoťg╔_␀{ľ_z#×WŰ╔ňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňň; P2FILE.ASM - two-panel CP/M file manager for the Philips P2000C
;
; Assemble on the P2000C with Digital Research's tools:
;     ASM P2FILE
;     LOAD P2FILE
;     P2FILE
;
; Keys: TAB panel, W/S move, SPACE mark, C copy, D delete, R rename,
;    T
        JMP     KEYLOOP

KTAB:   LDA     ACTIVE
        XRI     1
        STA     ACTIVE
        CALL    SETL
        CALL    DRAWHDR
        CALL    DRAWCUR
        CALL    SETR
        CALL    DRAWHDR
        CALL    DRAWCUR
        JMP       V choose drive, Q quit.
;
; Intel 8080 source.  The program uses only documented CP/M 2.2 BDOS calls
; and documented P2000C terminal escape sequences.

BDOS    EQU     0005H
CONOUT  EQU     02H
DIRIO   EQU     06H
OPENF   EQU     0FH
CLOSEF  E KEYLOOP

KUP:    CALL    SAVENAV
        CALL    MOVEUP
        CALL    NAVDRAW
        JMP     KEYLOOP

KDOWN:  CALL    SAVENAV
        CALL    MOVEDOWN
        CALL    NAVDRAW
        JMP     KEYLOOP

KMARK:  CALL    MARKFILE
        CALL  QU     10H
SFIRST  EQU     11H
SNEXT   EQU     12H
DELETE  EQU     13H
READSEQ EQU     14H
WRITSEQ EQU     15H
MAKEF   EQU     16H
RENAME  EQU     17H
SETDMA  EQU     1AH
FSIZE   EQU     23H

MAXFILE EQU     128
ROWS    EQU     22
FIRST   EQU   REDRAWC
        JMP     KEYLOOP

KCOPY:  CALL    COPYFILES
        JMP     KEYLOOP

KDEL:
        CALL    DELFILES
        JMP     KEYLOOP

KREN:
        CALL    RENFILE
        JMP     KEYLOOP

KDRIVE:CALL    PICKDRIVE
        JMP     MAI    1
ENTSIZ  EQU     15
NORMATT EQU     40H
INVATT  EQU     50H
BOLDINV EQU     11H
CPBUFR  EQU     32

        ORG     0100H

START:  LXI     SP,STACK
        LDA     LDRIVE
        CALL    SHOWSTART
        CALL    LOADL
        CALL    DRAN

KQUIT:  MVI     A,0CH
        CALL    PUTC
        LXI     H,BYEMSG
        CALL    PRINTZ
        JMP     0000H

; ---------------------------------------------------------------------------
; Directory loading

LOADL:  LDA     LDRIVE
     WSHELL
        LDA     RDRIVE
        CALL    SHOWREAD
        CALL    LOADR

MAIN:   CALL    DRAW
KEYLOOP:CALL    GETKEY
        STA     KEYTMP
        LDA     MODAL
        ORA     A
        JZ      KEYFOOT
        XRA     A
        STA     M   STA     SRCHFCB
        LXI     H,LFILES
        SHLD    STOREPTR
        LXI     H,LCOUNT
        SHLD    CNTPTR
        CALL    READDIR
        CALL    NORML
        RET

LOADR:  LDA     RDRIVE
        STA     SRCHFCB
        LXI     H,RFILODAL
        CALL    DRAW
        JMP     KEYLOAD
KEYFOOT:
        LDA     FOOTMSG
        ORA     A
        JZ      KEYLOAD
        CALL    DRAWHELP
KEYLOAD:LDA     KEYTMP
        CPI     'a'
        JC      KEYUP
        CPI     'z'+1
       ES
        SHLD    STOREPTR
        LXI     H,RCOUNT
        SHLD    CNTPTR
        CALL    READDIR
        CALL    NORMR
        RET

READDIR:
        LXI     H,SRCHFCB+1
        MVI     B,11
RDFILL: MVI     M,'?'
        INX     H
        DC JNC     KEYUP
        SUI     20H
KEYUP:  CPI     09H
        JZ      KTAB
        CPI     05H
        JZ      KUP
        CPI     18H
        JZ      KDOWN
        CPI     'W'
        JZ      KUP
        CPI     'S'
        JZ      KDOWN
    R     B
        JNZ     RDFILL
        MVI     B,24
        XRA     A
RDZERO: MOV     M,A
        INX     H
        DCR     B
        JNZ     RDZERO
        LHLD    CNTPTR
        MVI     M,0
        LXI     D,DIRBUF
        MVI     C,SETDMA
      CPI     ' '
        JZ      KMARK
        CPI     'C'
        JZ      KCOPY
        CPI     'D'
        JZ      KDEL
        CPI     'R'
        JZ      KREN
        CPI     'V'
        JZ      KDRIVE
        CPI     'Q'
        JZ      KQUI      CALL    BDOS
        LXI     D,SRCHFCB
        MVI     C,SFIRST
        CALL    BDOS
RDLOOP: CPI     0FFH
        JZ      RDDONE
        ANI     03H
        RLC
        RLC
        RLC
        RLC
        RLC
        MOV     E,A
        MVI     D,0
        LXI     H,DIRBUF
        DAD     D
        INX     H
        SHLD    DIRPTR
        LHLD    DIRPTR
        XCHG
        LHLD    STOREPTR
        MVI     B,11
RDCOPY: LDAX    D
        ANI     7FH
        MOV     M,A
         LDA     RCUR
        CALL    NORM
        STA     RCUR
        CPI     ROWS
        JC      NORMZR
        SUI     ROWS-1
        JMP     NORMSR
NORMZR: XRA     A
NORMSR:
        STA     RTOP
        RET

NORM:   MOV     C,A
        MOV     AINX     D
        INX     H
        DCR     B
        JNZ     RDCOPY
        MVI     M,0
        INX     H
        MVI     M,0
        INX     H
        MVI     M,0
        INX     H
        MVI     M,0FFH
        INX     H
        SHLD    STOR,B
        ORA     A
        JZ      NORMZERO
        MOV     A,C
        CMP     B
        RC
        MOV     A,B
        DCR     A
        RET
NORMZERO:
        XRA     A
        RET

; -------------------------------------------------------EPTR
        LHLD    CNTPTR
        INR     M
        MOV     A,M
        CPI     MAXFILE
        JZ      RDDONE
        LXI     D,SRCHFCB
        MVI     C,SNEXT
        CALL    BDOS
        JMP     RDLOOP

RDDONE: RET

; Resolve an entry's s--------------------
; Screen drawing

DRAW:   CALL    DRAWSHELL
        CALL    FILLSIZES
        RET

DRAWSHELL:
        MVI     A,0CH
        CALL    PUTC
        CALL    DRAWL
        CALL    DRAWR
        CALL    DRAWHELP
        RET

;ize only when its row becomes active. Byte 14 of the
; panel entry is FFH until BDOS function 35 has populated bytes 12-14.
ENSURESIZE:
        LDA     LINEIDX
        CALL    PENTRY
        SHLD    ENTRYPTR
        LXI     D,14
        DAD     D
  Populate exact sizes only for the two visible windows. The initial panel
; drawing therefore appears immediately, followed by one visibly updated row
; per BDOS function-35 query. Cached rows are skipped on later redraws.
FILLSIZES:
        CALL    SE       MOV     A,M
        CPI     0FFH
        RNZ
        LXI     H,SRCFCB
        CALL    CLEAR36
        LDA     PDRIVE
        STA     SRCFCB
        LHLD    ENTRYPTR
        XCHG
        LXI     H,SRCFCB+1
        MVI     B,11
RDSZCP: LDAXTL
        CALL    FILLPANEL
        CALL    SETR
        CALL    FILLPANEL
        RET

FILLPANEL:
        LDA     PTOP
        STA     SZIDX
        MVI     A,ROWS
        STA     SZLEFT
FZLOOP: LDA     SZLEFT
        ORA     A
        RZ
     D
        MOV     M,A
        INX     D
        INX     H
        DCR     B
        JNZ     RDSZCP
        LXI     D,SRCFCB
        MVI     C,FSIZE
        CALL    BDOS
        LHLD    ENTRYPTR
        LXI     D,12
        DAD     D
              LDA     SZIDX
        MOV     B,A
        LDA     PCOUNT
        CMP     B
        RC
        RZ
        MOV     A,B
        CALL    PENTRY
        LXI     D,14
        DAD     D
        MOV     A,M
        CPI     0FFH
        JNZ     F LDA     SRCFCB+33
        MOV     M,A
        INX     H
        LDA     SRCFCB+34
        MOV     M,A
        INX     H
        LDA     SRCFCB+35
        MOV     M,A
        RET

NORML:  LDA     LCOUNT
        MOV     B,A
        LDA     LCURZNEXT
        LDA     SZIDX
        STA     LINEIDX
        CALL    ENSURESIZE
        LDA     SZIDX
        STA     DRAWIDX
        MOV     B,A
        LDA     PTOP
        MOV     C,A
        MOV     A,B
        SUB     C
        ADI     FIRST
        CALL    NORM
        STA     LCUR
        CPI     ROWS
        JC      NORMZL
        SUI     ROWS-1
        JMP     NORMSL
NORMZL: XRA     A
NORMSL:
        STA     LTOP
        RET

NORMR:  LDA     RCOUNT
        MOV     B,A
       
        STA     DRAWROW
        CALL    DRAWLINE
FZNEXT: LDA     SZIDX
        INR     A
        STA     SZIDX
        LDA     SZLEFT
        DCR     A
        STA     SZLEFT
        JMP     FZLOOP

DRAWHELP:
        MVI     B,23
        MVI     C,0
        CALL    POS
        MVI     A,INVATT
        CALL    SETATTR
        MVI     A,1BH
        CALL    PUTC
        MVI     A,'K'
        CALL    PUTC
        LXI     H,HELP
        CALL    PRINTZ
        MVI     A,NORMATT
        CA '
        CALL    PUTC
        MVI     A,' '
        CALL    PUTC
        LDA     PCOUNT
        CALL    PRINT3
        LXI     H,FILEMSG
        CALL    PRINTZ
        LDA     PCOUNT
        ORA     A
        JZ      DPHPOS
        LDA     PCULL    SETATTR
        XRA     A
        STA     FOOTMSG
        RET

DRAWL:  CALL    SETL
        CALL    DRAWP
        RET

SETL:   XRA     A
        STA     PCOL
        LDA     LDRIVE
        STA     PDRIVE
        LDA     LCOUNT
        SR
        INR     A
DPHPOS: CALL    PRINT3
        MVI     A,'/'
        CALL    PUTC
        LDA     PCOUNT
        CALL    PRINT3
        MVI     A,' '
        CALL    PUTC
        LDA     PTOP
        ORA     A
        MVI     A,' '
        TA     PCOUNT
        LDA     LCUR
        STA     PCUR
        LDA     LTOP
        STA     PTOP
        LXI     H,LFILES
        SHLD    PLIST
        LDA     ACTIVE
        XRI     1
        STA     PACTIVE
        RET

DRAWR:  CALL    SETRJZ      DPHUP
        MVI     A,'^'
DPHUP:  CALL    PUTC
        LDA     PTOP
        ADI     ROWS
        MOV     B,A
        LDA     PCOUNT
        CMP     B
        MVI     A,' '
        JC      DPHDOWN
        JZ      DPHDOWN
        MVI    
        CALL    DRAWP
        RET

SETR:   MVI     A,41
        STA     PCOL
        LDA     RDRIVE
        STA     PDRIVE
        LDA     RCOUNT
        STA     PCOUNT
        LDA     RCUR
        STA     PCUR
        LDA     RTOP
        STA A,'v'
DPHDOWN:CALL    PUTC
        MVI     A,NORMATT
        CALL    SETATTR
        RET

DRAWROWS:
        LDA     PTOP
        STA     DRAWIDX
        MVI     A,FIRST
        STA     DRAWROW
        MVI     A,ROWS
        STA     DRAWLEFT
D     PTOP
        LXI     H,RFILES
        SHLD    PLIST
        LDA     ACTIVE
        STA     PACTIVE
        RET

DRAWP:  CALL    DRAWHDR
        CALL    DRAWROWS
        RET

DRAWHDR:
        MVI     A,INVATT
        STA     LINEATT
     PLOOP: LDA     DRAWROW
        CALL    DRAWLINE
        LDA     DRAWIDX
        INR     A
        STA     DRAWIDX
        LDA     DRAWROW
        INR     A
        STA     DRAWROW
        LDA     DRAWLEFT
        DCR     A
        STA     DRAWLEF   LDA     PACTIVE
        ORA     A
        JZ      DPHATTR
        MVI     A,BOLDINV
        STA     LINEATT
DPHATTR:MVI     B,0
        LDA     PCOL
        MOV     C,A
        CALL    POS
        LDA     LINEATT
        CALL    SETATTR
     T
        JNZ     DPLOOP
        RET

DRAWLINE:
        LDA     DRAWIDX
        STA     LINEIDX
        MOV     D,A
        LDA     PCOUNT
        CMP     D
        MVI     A,0
        JC      DLVALID
        JZ      DLVALID
        MVI     A,   MVI     B,39
DPHCLR: MVI     A,' '
        CALL    PUTC
        DCR     B
        JNZ     DPHCLR
        MVI     B,0
        LDA     PCOL
        MOV     C,A
        CALL    POS
        LDA     PACTIVE
        ORA     A
        MVI     A,' '1
DLVALID:STA     LINEOK
        MVI     A,NORMATT
        STA     LINEATT
        LDA     LINEOK
        ORA     A
        JZ      DLATTR
        LDA     PACTIVE
        ORA     A
        JZ      DLATTR
        LDA     PCUR
        MOV     D,A
        JZ      DPHMARK
        MVI     A,'*'
DPHMARK:CALL    PUTC
        LXI     H,DRIVEMSG
        CALL    PRINTZ
        LDA     PDRIVE
        ADI     'A'-1
        CALL    PUTC
        MVI     A,':'
        CALL    PUTC
        MVI     A,'
        LDA     LINEIDX
        CMP     D
        JNZ     DLATTR
        MVI     A,INVATT
        STA     LINEATT
DLATTR: LDA     DRAWROW
        MOV     B,A
        LDA     PCOL
        MOV     C,A
        CALL    POS
        LDA     LINEATT
        CALL    SETATTR
        MVI     B,39
DLBLANK:MVI     A,' '
        CALL    PUTC
        DCR     B
        JNZ     DLBLANK
        LDA     LINEOK
        ORA     A
        JZ      DLNORM
        LDA     DRAWROW
        MOV     B,A
           DCR     B
        JNZ     PNEXT
        RET

PRINT3: MOV     L,A
        MVI     H,0
        XRA     A
        STA     LEAD
        LXI     D,100
        CALL    PDIV
        LXI     D,10
        CALL    PDIV
        MOV     A,L
        ADILDA     PCOL
        MOV     C,A
        CALL    POS
        LDA     LINEIDX
        MOV     D,A
        LDA     PACTIVE
        ORA     A
        JZ      DLNOCUR
        LDA     PCUR
        CMP     D
        MVI     A,' '
        JNZ     DLCUR     '0'
        CALL    PUTC
        RET

PRINT5: XRA     A
        STA     LEAD
        LXI     D,10000
        CALL    PDIV
        LXI     D,1000
        CALL    PDIV
        LXI     D,100
        CALL    PDIV
        LXI     D,10
        S
        MVI     A,'>'
        JMP     DLCURS
DLNOCUR:MVI     A,' '
DLCURS: CALL    PUTC
        LDA     LINEIDX
        CALL    PENTRY
        PUSH    H
        LXI     D,11
        DAD     D
        MOV     A,M
        ORA     A
        MVI CALL    PDIV
        MOV     A,L
        ADI     '0'
        CALL    PUTC
        RET

PDIV:   MVI     B,0
PDLOOP: MOV     A,H
        CMP     D
        JC      PDDONE
        JNZ     PDSUB
        MOV     A,L
        CMP     E
        JC         A,' '
        JZ      DLSEL
        MVI     A,'*'
DLSEL:  CALL    PUTC
        MVI     A,' '
        CALL    PUTC
        POP     H
        PUSH    H
        CALL    PRINTNAME
        POP     H
        MVI     A,' '
        CALL    PUTC
    PDDONE
PDSUB:  MOV     A,L
        SUB     E
        MOV     L,A
        MOV     A,H
        SBB     D
        MOV     H,A
        INR     B
        JMP     PDLOOP
PDDONE: MOV     A,B
        ORA     A
        JNZ     PDNUM
        LDA     LEA     PUSH    H
        LXI     D,14
        DAD     D
        MOV     A,M
        CPI     0FFH
        JZ      DLUNKSZ
        DCX     H
        DCX     H
        MOV     E,M
        INX     H
        MOV     D,M
        XCHG
        LXI     D,D
        ORA     A
        MVI     A,' '
        JZ      PDOUT
        MVI     A,'0'
        JMP     PDOUT
PDNUM:  MVI     A,1
        STA     LEAD
        MOV     A,B
        ADI     '0'
PDOUT:  CALL    PUTC
        RET

HALF:   ORA     A
 7
        DAD     D
        CALL    HALF
        CALL    HALF
        CALL    HALF
        CALL    PRINT5
        JMP     DLSIZED
DLUNKSZ:
        LXI     H,UNKSIZE
        CALL    PRINTZ
DLSIZED:
        MVI     A,'K'
        CALL    PUTC
          MOV     A,H
        RAR
        MOV     H,A
        MOV     A,L
        RAR
        MOV     L,A
        RET

SETATTR:MOV     B,A
        MVI     A,1BH
        CALL    PUTC
        MVI     A,'0'
        CALL    PUTC
        MOV     A,B
     POP     H
DLNORM: MVI     A,NORMATT
        CALL    SETATTR
        RET

PENTRY: LHLD    PLIST
ENTRYA: ORA     A
        RZ
        LXI     D,ENTSIZ
ENTLOOP:DAD     D
        DCR     A
        JNZ     ENTLOOP
        RET

PRINTNAME:
           CALL    PUTC
        RET

POS:    PUSH    B
        MVI     A,1BH
        CALL    PUTC
        MVI     A,'Y'
        CALL    PUTC
        POP     B
        MOV     A,B
        ADI     20H
        CALL    PUTC
        MOV     A,C
           MVI     B,8
PNBASE: MOV     A,M
        CALL    PUTC
        INX     H
        DCR     B
        JNZ     PNBASE
        MVI     A,'.'
        CALL    PUTC
        MVI     B,3
PNEXT:  MOV     A,M
        CALL    PUTC
        INX     H
       ADI     20H
        CALL    PUTC
        RET

STATUS: PUSH    H
        MVI     B,23
        MVI     C,0
        CALL    POS
        MVI     A,1BH
        CALL    PUTC
        MVI     A,'K'
        CALL    PUTC
        POP     H
        CALL    PRINTZ
        MVI     A,1
        STA     FOOTMSG
        RET

; ---------------------------------------------------------------------------
; Navigation and marking

SAVENAV:LDA     ACTIVE
        ORA     A
        JNZ     SAVER
        LDEUP: LDA     ACTIVE
        ORA     A
        JNZ     RUP
        LDA     LCUR
        ORA     A
        RZ
        DCR     A
        STA     LCUR
        MOV     B,A
        LDA     LTOP
        MOV     C,A
        MOV     A,B
        CMP     A     LCUR
        STA     OLDCUR
        LDA     LTOP
        STA     OLDTOP
        RET
SAVER:  LDA     RCUR
        STA     OLDCUR
        LDA     RTOP
        STA     OLDTOP
        RET

NAVDRAW:LDA     ACTIVE
        ORA     A
        JNZC
        RNC
        STA     LTOP
        RET
RUP:    LDA     RCUR
        ORA     A
        RZ
        DCR     A
        STA     RCUR
        MOV     B,A
        LDA     RTOP
        MOV     C,A
        MOV     A,B
        CMP     C
            NAVR
        CALL    SETL
        JMP     NAVSET
NAVR:   CALL    SETR
NAVSET: LDA     PCUR
        MOV     B,A
        LDA     OLDCUR
        CMP     B
        JNZ     NAVCHG
        LDA     PTOP
        MOV     B,A
        LDA     OLDTOP
 RNC
        STA     RTOP
        RET

MOVEDOWN:
        LDA     ACTIVE
        ORA     A
        JNZ     RDOWN
        LDA     LCOUNT
        MOV     B,A
        LDA     LCUR
        INR     A
        CMP     B
        RNC
        STA     LC        CMP     B
        RZ
NAVCHG:CALL    DRAWHDR
        LDA     PTOP
        MOV     B,A
        LDA     OLDTOP
        CMP     B
        JZ      NAVROWS
        CALL    DRAWROWS
        CALL    FILLPANEL
        RET
NAVROWS:
        LDA   UR
        MOV     B,A
        LDA     LTOP
        ADI     ROWS
        CMP     B
        JC      LDSCROLL
        JZ      LDSCROLL
        RET
LDSCROLL:
        LDA     LTOP
        INR     A
        STA     LTOP
        RET
RDOWN:  LDA       OLDCUR
        STA     DRAWIDX
        MOV     B,A
        LDA     PTOP
        MOV     C,A
        MOV     A,B
        SUB     C
        ADI     FIRST
        STA     DRAWROW
        CALL    DRAWLINE
        LDA     PCUR
        MOV     B,A
RCOUNT
        MOV     B,A
        LDA     RCUR
        INR     A
        CMP     B
        RNC
        STA     RCUR
        MOV     B,A
        LDA     RTOP
        ADI     ROWS
        CMP     B
        JC      RDSCROLL
        JZ      RDSCRO        LDA     OLDCUR
        CMP     B
        RZ
        MOV     A,B
        STA     DRAWIDX
        MOV     B,A
        LDA     PTOP
        MOV     C,A
        MOV     A,B
        SUB     C
        ADI     FIRST
        STA     DRAWROW
   LL
        RET
RDSCROLL:
        LDA     RTOP
        INR     A
        STA     RTOP
        RET

MARKFILE:
        LDA     ACTIVE
        ORA     A
        JNZ     RMARK
        LDA     LCOUNT
        ORA     A
        RZ
        LDA     LC     CALL    DRAWLINE
        RET

REDRAWC:LDA     ACTIVE
        ORA     A
        JNZ     REDRAWR
        CALL    SETL
        JMP     REDSET
REDRAWR:CALL    SETR
REDSET: CALL    DRAWCUR
        RET

DRAWCUR:LDA     PCOUNT
        ORA     AUR
        LXI     H,LFILES
        JMP     DOMARK
RMARK:  LDA     RCOUNT
        ORA     A
        RZ
        LDA     RCUR
        LXI     H,RFILES
DOMARK: SHLD    WORKLIST
        CALL    WENTRY
        LXI     D,11
        DAD     D
        
        RZ
        LDA     PCUR
        STA     DRAWIDX
        MOV     B,A
        LDA     PTOP
        MOV     C,A
        MOV     A,B
        SUB     C
        ADI     FIRST
        STA     DRAWROW
        CALL    DRAWLINE
        RET

MOVMOV     A,M
        XRI     1
        MOV     M,A
        RET

WENTRY: LHLD    WORKLIST
        JMP     ENTRYA

PICKDRIVE:
        CALL    SHOWDRIVES
PDKEY:  CALL    GETKEY
        CPI     1BH
        RZ
        CPI     'a'
        JC      PDUP
        CPI     'z'+1
        JNC     PDUP
        SUI     20H
PDUP:   CPI     'A'
        JC      PDKEY
        CPI     'G'
        JNC     PDKEY
        SUI     'A'-1
        MOV     B,A
        PUSH    B
        CALL    SHOWREAD
        P    SCUR
        CMP     B
        JNZ     CPNEXT
CPONE:  MOV     A,B
        CALL    SENTRY
        SHLD    ENTRYPTR
        LDA     CPNUM
        INR     A
        STA     CPNUM
        CALL    PREPCOPY
        CALL    SHOWCOPY
        CALL   OP     B
        LDA     ACTIVE
        ORA     A
        JNZ     PDRIGHT
        MOV     A,B
        STA     LDRIVE
        CALL    LOADL
        RET
PDRIGHT:MOV     A,B
        STA     RDRIVE
        CALL    LOADR
        RET

SHOWDRIVES:
  COPYONE
CPNEXT: LDA     LOOPIDX
        INR     A
        STA     LOOPIDX
        JMP     CPLOOP
CPDONE: CALL    LOADL
        CALL    LOADR
        CALL    DRAW
        LDA     OPERROR
        ORA     A
        JNZ     SHOWCPERR
        CALL         CALL    MODBOX
        MVI     B,9
        MVI     C,34
        CALL    POS
        LXI     H,DRVHEAD
        CALL    PRINTZ
        MVI     B,10
        MVI     C,29
        CALL    POS
        LXI     H,DRVOPTS
        CALL    PRINTZ
    SHOWCPDONE
        RET

SHOWCPERR:
        CALL    SHOWERROR
        RET

SETSOURCE:
        LDA     ACTIVE
        ORA     A
        JNZ     SRCRIGHT
        LDA     LDRIVE
        STA     SRCDRIVE
        LDA     RDRIVE
        STA     DS      MVI     B,11
        MVI     C,27
        CALL    POS
        LXI     H,DRVPROMPT
        CALL    PRINTZ
        MVI     B,12
        MVI     C,26
        CALL    POS
        LXI     H,DRVREADY
        CALL    PRINTZ
        MVI     A,NORMATDRIVE
        LDA     LCOUNT
        STA     SCOUNT
        LDA     LCUR
        STA     SCUR
        LXI     H,LFILES
        SHLD    SLIST
        RET
SRCRIGHT:
        LDA     RDRIVE
        STA     SRCDRIVE
        LDA     LDRIVE
        STT
        CALL    SETATTR
        RET

; ---------------------------------------------------------------------------
; Copy

COPYFILES:
        CALL    SETSOURCE
        LDA     SRCDRIVE
        MOV     B,A
        LDA     DSTDRIVE
        CMPTA     DSTDRIVE
        LDA     RCOUNT
        STA     SCOUNT
        LDA     RCUR
        STA     SCUR
        LXI     H,RFILES
        SHLD    SLIST
        RET

FINDSEL:XRA     A
        STA     LOOPIDX
FSLOOP: LDA     LOOPIDX
        MOV        B
        JNZ     CPDIFF
        LXI     H,SAMEDRV
        CALL    STATUS
        RET
CPDIFF:
        LDA     SCOUNT
        ORA     A
        JNZ     CPHAVE
        LXI     H,NOFILES
        CALL    STATUS
        RET
CPHAVE: CALL    FIND  B,A
        LDA     SCOUNT
        CMP     B
        JZ      FSNONE
        MOV     A,B
        CALL    SENTRY
        LXI     D,11
        DAD     D
        MOV     A,M
        ORA     A
        MVI     A,1
        RNZ
        LDA     LOOPIDSEL
        STA     SELMODE
        CALL    COUNTCP
        XRA     A
        STA     OPERROR
        STA     LOOPIDX
        STA     CPNUM
CPLOOP: LDA     LOOPIDX
        MOV     B,A
        LDA     SCOUNT
        CMP     B
        JZ      CPDOX
        INR     A
        STA     LOOPIDX
        JMP     FSLOOP
FSNONE: XRA     A
        RET

COUNTCP:LDA     SELMODE
        ORA     A
        JNZ     CCSEL
        MVI     A,1
        STA     CPTOTAL
        RET
CCSEL:  XRA     A
      NE
        LDA     SELMODE
        ORA     A
        JZ      CPCUR
        MOV     A,B
        CALL    SENTRY
        LXI     D,11
        DAD     D
        MOV     A,M
        ORA     A
        JZ      CPNEXT
        JMP     CPONE
CPCUR:  LDA   STA     CPTOTAL
        STA     LOOPIDX
CCLOOP: LDA     LOOPIDX
        MOV     B,A
        LDA     SCOUNT
        CMP     B
        RZ
        MOV     A,B
        CALL    SENTRY
        LXI     D,11
        DAD     D
        MOV     A,M
        ORA     A
        JZ      CCNEXT
        LDA     CPTOTAL
        INR     A
        STA     CPTOTAL
CCNEXT: LDA     LOOPIDX
        INR     A
        STA     LOOPIDX
        JMP     CCLOOP

SENTRY: LHLD    SLIST
        JMP     ENTRYA

; CaETDMA
        CALL    BDOS
        LXI     D,SRCFCB
        MVI     C,READSEQ
        CALL    BDOS
        ORA     A
        JNZ     CPREADEOF
        LDA     CPBCOUNT
        INR     A
        STA     CPBCOUNT
        LHLD    CPBUFPTR
        Lche the selected file's exact record count and initialise its individual
; copy-progress counter. P2000C logical volumes fit in the displayed 16 bits.
PREPCOPY:
        LHLD    ENTRYPTR
        LXI     D,14
        DAD     D
        MOV     A,M
    XI     D,128
        DAD     D
        SHLD    CPBUFPTR
        LDA     CPBLEFT
        DCR     A
        STA     CPBLEFT
        JNZ     CPREAD
        JMP     CPWRITESET
CPREADEOF:
        MVI     A,1
        STA     CPEOF
CPWRITESET:
           CPI     0FFH
        JNZ     CPPKNOWN
        CALL    BUILDSRC
        LXI     D,SRCFCB
        MVI     C,FSIZE
        CALL    BDOS
        LHLD    ENTRYPTR
        LXI     D,12
        DAD     D
        LDA     SRCFCB+33
        MOV     M,A LDA     CPBCOUNT
        ORA     A
        JZ      CPRDEOF
        STA     CPBLEFT
        LXI     H,BUFFER
        SHLD    CPBUFPTR
CPWRITE:
        LHLD    CPBUFPTR
        XCHG
        MVI     C,SETDMA
        CALL    BDOS
        LXI     D,
        INX     H
        LDA     SRCFCB+34
        MOV     M,A
        INX     H
        LDA     SRCFCB+35
        MOV     M,A
CPPKNOWN:
        LHLD    ENTRYPTR
        LXI     D,12
        DAD     D
        MOV     E,M
        INX     H
  DSTFCB
        MVI     C,WRITSEQ
        CALL    BDOS
        ORA     A
        JNZ     CPWRERR
        LHLD    CPRECDONE
        INX     H
        SHLD    CPRECDONE
        LHLD    CPBUFPTR
        LXI     D,128
        DAD     D
        SHLD        MOV     D,M
        XCHG
        SHLD    CPTOTREC
        LXI     H,0
        SHLD    CPRECDONE
        RET

COPYONE:
        CALL    BUILDFCBS
        LXI     D,DIRBUF
        MVI     C,SETDMA
        CALL    BDOS
        LXI     D,DSTFC  CPBUFPTR
        LDA     CPBLEFT
        DCR     A
        STA     CPBLEFT
        JNZ     CPWRITE
        CALL    SHOWFILEPROG
        LDA     CPEOF
        ORA     A
        JNZ     CPCLOSE
        JMP     CPBATCH
CPWRERR:
        MVI     A,B
        MVI     C,SFIRST
        CALL    BDOS
        CPI     0FFH
        JZ      CPNEW
        CALL    ASKOVER
        ORA     A
        RZ
        CALL    BUILDFCBS
        LXI     D,DSTFCB
        MVI     C,DELETE
        CALL    BDOS
CPN1
        STA     OPERROR
        JMP     CPCLOSE
CPRDEOF:
        CALL    SHOWFILEPROG
CPCLOSE:LXI     D,DSTFCB
        MVI     C,CLOSEF
        CALL    BDOS
        LXI     D,SRCFCB
        MVI     C,CLOSEF
        CALL    BDOS
        RET
CPEW:  CALL    BUILDFCBS
        LXI     D,SRCFCB
        MVI     C,OPENF
        CALL    BDOS
        CPI     0FFH
        JZ      CPFAIL
        LXI     D,DSTFCB
        MVI     C,MAKEF
        CALL    BDOS
        CPI     0FFH
        JZ      CPMKERR:LXI     D,SRCFCB
        MVI     C,CLOSEF
        CALL    BDOS
CPFAIL: MVI     A,1
        STA     OPERROR
        RET

ASKOVER:CALL    MODBOX
        MVI     B,10
        MVI     C,22
        CALL    POS
        LXI     H,OVER1
        CMKERR
CPBATCH:
        LXI     H,BUFFER
        SHLD    CPBUFPTR
        MVI     A,CPBUFR
        STA     CPBLEFT
        XRA     A
        STA     CPBCOUNT
        STA     CPEOF
CPREAD:
        LHLD    CPBUFPTR
        XCHG
        MVI     C,SALL    PRINTZ
        LHLD    ENTRYPTR
        CALL    PRINTSHORT
        LXI     H,OVER2
        CALL    PRINTZ
        MVI     A,NORMATT
        CALL    SETATTR
OVKEY:  CALL    GETKEY
        CPI     'a'
        JC      OVUP
        CPI     'z'+1
        JNC     OVUP
        SUI     20H
OVUP:   CPI     'Y'
        JZ      OVYES
        CPI     'N'
        JNZ     OVKEY
        XRA     A
        RET
OVYES:  CALL    SHOWCOPY
        MVI     A,1
        RET

; Four-row inverse-video coBOX
        MVI     B,10
        MVI     C,25
        CALL    POS
        LXI     H,COPYERR
        CALL    PRINTZ
SHOWACK:MVI     B,11
        MVI     C,31
        CALL    POS
        LXI     H,CPACK
        CALL    PRINTZ
        MVI     A,NORpy modal. It deliberately stays clear of row 23,
; so the keyboard legend remains visible throughout the operation.
MODBOX: MVI     B,9
MBLOOP:CALL    MODROW
        INR     B
        MOV     A,B
        CPI     13
        JNZ     MBLOOP
        REMATT
        CALL    SETATTR
        MVI     A,1
        STA     MODAL
        RET

BUILDFCBS:
        LXI     H,SRCFCB
        CALL    CLEAR36
        LXI     H,DSTFCB
        CALL    CLEAR36
        LDA     SRCDRIVE
        STA     SRCFCB
  T

MODROW:MOV     A,B
        STA     MODROWNO
        MVI     C,20
        CALL    POS
        MVI     A,INVATT
        CALL    SETATTR
        MVI     D,40
MRCLEAR:MVI     A,' '
        CALL    PUTC
        DCR     D
        JNZ     MRCLEAR
      LDA     DSTDRIVE
        STA     DSTFCB
        LHLD    ENTRYPTR
        XCHG
        LXI     H,SRCFCB+1
        MVI     B,11
BFSRC:  LDAX    D
        MOV     M,A
        INX     D
        INX     H
        DCR     B
        JNZ     BFSRC        LDA     MODROWNO
        MOV     B,A
        MVI     C,20
        CALL    POS
        RET

SHOWCOPY:
        CALL    MODBOX
        MVI     B,9
        MVI     C,32
        CALL    POS
        LXI     H,CPHEAD
        CALL    PRINTZ
  
        LHLD    ENTRYPTR
        XCHG
        LXI     H,DSTFCB+1
        MVI     B,11
BFDST:  LDAX    D
        MOV     M,A
        INX     D
        INX     H
        DCR     B
        JNZ     BFDST
        RET

; ---------------------------      MVI     B,10
        MVI     C,22
        CALL    POS
        LXI     H,CPFILE
        CALL    PRINTZ
        LHLD    ENTRYPTR
        CALL    PRINTSHORT
        MVI     B,11
        MVI     C,29
        CALL    POS
        LXI     H,CPSTEP------------------------------------------------
; Delete

DELFILES:
        CALL    SETSOURCE
        LDA     SCOUNT
        ORA     A
        JNZ     DELHAVE
        LXI     H,NOFILES
        CALL    STATUS
        RET
DELHAVE:CALL    FINDSEL
        CALL    PRINTZ
        LDA     CPNUM
        CALL    PRINT3
        LXI     H,CPOF
        CALL    PRINTZ
        LDA     CPTOTAL
        CALL    PRINT3
        CALL    SHOWFILEPROG
        MVI     A,NORMATT
        CALL    SETATTR
    
        STA     SELMODE
        LXI     H,DELASK
        CALL    STATUS
        CALL    YESNO
        ORA     A
        RZ
        XRA     A
        STA     OPERROR
        STA     LOOPIDX
DELLOOP:LDA     LOOPIDX
        MOV     B,A
        LDA    RET

SHOWFILEPROG:
        MVI     B,12
        MVI     C,29
        CALL    POS
        LXI     H,CPRECS
        CALL    PRINTZ
        LHLD    CPRECDONE
        CALL    PRINT5
        MVI     A,'/'
        CALL    PUTC
        LHLD    CPT     SCOUNT
        CMP     B
        JZ      DELDONE
        LDA     SELMODE
        ORA     A
        JZ      DELCUR
        MOV     A,B
        CALL    SENTRY
        LXI     D,11
        DAD     D
        MOV     A,M
        ORA     A
     OTREC
        CALL    PRINT5
        RET

SHOWCPDONE:
        CALL    MODBOX
        MVI     B,10
        MVI     C,33
        CALL    POS
        LXI     H,COPYOK
        CALL    PRINTZ
        JMP     SHOWACK

SHOWERROR:
        CALL    MOD   JZ      DELNEXT
        JMP     DELONE
DELCUR: LDA     SCUR
        CMP     B
        JNZ     DELNEXT
DELONE: MOV     A,B
        CALL    SENTRY
        SHLD    ENTRYPTR
        CALL    BUILDSRC
        LXI     D,SRCFCB
        MVI     C,DELETE
        CALL    BDOS
        CPI     0FFH
        JNZ     DELNEXT
        MVI     A,1
        STA     OPERROR
DELNEXT:LDA     LOOPIDX
        INR     A
        STA     LOOPIDX
        JMP     DELLOOP
DELDONE:CALL    LOADL
        CALL    LOADR        STA     INLEN
        LXI     H,NEWASK
        CALL    STATUS
GNKEY:  CALL    GETKEY
        CPI     1BH
        JZ      GNCANCEL
        CPI     0DH
        JZ      GNDONE
        CPI     08H
        JZ      GNBACK
        CPI     7FH
 
        CALL    DRAW
        LDA     OPERROR
        ORA     A
        LXI     H,DELOK
        JZ      DELSTAT
        LXI     H,DELERR
DELSTAT:CALL    STATUS
        RET

BUILDSRC:
        LXI     H,SRCFCB
        CALL    CLEAR36
        LDA       JZ      GNBACK
        CPI     'a'
        JC      GNUP
        CPI     'z'+1
        JNC     GNUP
        SUI     20H
GNUP:   CPI     21H
        JC      GNKEY
        CPI     7FH
        JNC     GNKEY
        MOV     B,A
        LDA         SRCDRIVE
        STA     SRCFCB
        LHLD    ENTRYPTR
        XCHG
        LXI     H,SRCFCB+1
        MVI     B,11
BSONE:  LDAX    D
        MOV     M,A
        INX     D
        INX     H
        DCR     B
        JNZ     BSONE
        INLEN
        CPI     12
        JNC     GNKEY
        MOV     A,B
        LHLD    INPTR
        MOV     M,A
        INX     H
        MVI     M,0
        SHLD    INPTR
        LDA     INLEN
        INR     A
        STA     INLEN
        MOV  RET

; ---------------------------------------------------------------------------
; Rename

RENFILE:LDA     ACTIVE
        ORA     A
        JNZ     RENR
        LDA     LCOUNT
        ORA     A
        JZ      RENNONE
        LDA     LDRIVE
    A,B
        CALL    PUTC
        JMP     GNKEY
GNBACK: LDA     INLEN
        ORA     A
        JZ      GNKEY
        DCR     A
        STA     INLEN
        LHLD    INPTR
        DCX     H
        SHLD    INPTR
        MVI     M,0
        M        STA     SRCDRIVE
        LDA     LCUR
        LXI     H,LFILES
        JMP     RENSET
RENR:   LDA     RCOUNT
        ORA     A
        JZ      RENNONE
        LDA     RDRIVE
        STA     SRCDRIVE
        LDA     RCUR
        LXI     H,VI     A,08H
        CALL    PUTC
        MVI     A,' '
        CALL    PUTC
        MVI     A,08H
        CALL    PUTC
        JMP     GNKEY
GNDONE: CALL    PARSENEW
        RET
GNCANCEL:
        XRA     A
        RET

PARSENEW:
        LXI RFILES
RENSET: SHLD    WORKLIST
        CALL    WENTRY
        SHLD    ENTRYPTR
        CALL    GETNEW
        ORA     A
        RZ
        CALL    NEWEXISTS
        ORA     A
        JZ      RENDO
        LXI     H,NAMEUSED
        CALL    STAT    H,NEWNAME
        MVI     B,11
        MVI     A,' '
PNCLR:  MOV     M,A
        INX     H
        DCR     B
        JNZ     PNCLR
        LXI     H,NEWBUF
        LXI     D,NEWNAME
        MVI     B,0
        MVI     C,0
PNLOOP: MOV     A,MUS
        RET
RENDO:  CALL    BUILDREN
        LXI     D,SRCFCB
        MVI     C,RENAME
        CALL    BDOS
        CPI     0FFH
        LXI     H,RENOK
        JNZ     RENRES
        LXI     H,RENERR
RENRES: PUSH    H
        CALL    LOADL

        ORA     A
        JZ      PNEND
        CPI     '.'
        JZ      PNDOT
        CPI     '*'
        JZ      PNBAD
        CPI     '?'
        JZ      PNBAD
        CPI     '/'
        JZ      PNBAD
        CPI     ':'
        JZ             CALL    LOADR
        CALL    DRAW
        POP     H
        CALL    STATUS
        RET
RENNONE:LXI     H,NOFILES
        CALL    STATUS
        RET

GETNEW: LXI     H,NEWBUF
        MVI     M,0
        SHLD    INPTR
        XRA     A
 PNBAD
        CPI     ';'
        JZ      PNBAD
        CPI     '<'
        JZ      PNBAD
        CPI     '='
        JZ      PNBAD
        CPI     '>'
        JZ      PNBAD
        CPI     '['
        JZ      PNBAD
        CPI     ']'
        JZ      PNBAD
        MOV     A,C
        ORA     A
        JNZ     PNEXTC
        MOV     A,B
        CPI     8
        JNC     PNBAD
        MOV     A,M
        STAX    D
        INX     D
        INR     B
        INX     H
        JMP           JNC     YNUP
        SUI     20H
YNUP:   CPI     'Y'
        JZ      YNYES
        CPI     'N'
        JNZ     YESNO
        XRA     A
        RET
YNYES:  MVI     A,1
        RET

CLEAR36:MVI     B,36
        XRA     A
C36LOOP:MOV     M,PNLOOP
PNEXTC: MOV     A,B
        CPI     3
        JNC     PNBAD
        MOV     A,M
        STAX    D
        INX     D
        INR     B
        INX     H
        JMP     PNLOOP
PNDOT:  MOV     A,C
        ORA     A
        JNZ     PNBAD
 A
        INX     H
        DCR     B
        JNZ     C36LOOP
        RET

PRINTSHORT:
        PUSH    H
        MVI     B,8
PSBASE: MOV     A,M
        CPI     ' '
        CZ      PSNOP
        CNZ     PUTC
        INX     H
        DCR            MOV     A,B
        ORA     A
        JZ      PNBAD
        MVI     C,1
        MVI     B,0
        LXI     D,NEWNAME+8
        INX     H
        JMP     PNLOOP
PNEND:  MOV     A,C
        ORA     A
        JZ      PNBCHK
        MOV     B
        JNZ     PSBASE
        POP     H
        LXI     D,8
        DAD     D
        MOV     A,M
        CPI     ' '
        RZ
        MVI     A,'.'
        CALL    PUTC
        MVI     B,3
PSEXT:  MOV     A,M
        CPI     ' '
        A,B
        ORA     A
        JZ      PNBAD
PNBCHK: LDA     NEWNAME
        CPI     ' '
        JZ      PNBAD
        MVI     A,1
        RET
PNBAD:  LXI     H,BADNAME
        CALL    STATUS
        XRA     A
        RET

NEWEXISTS:
        LCZ      PSNOP
        CNZ     PUTC
        INX     H
        DCR     B
        JNZ     PSEXT
PSNOP:  RET

PRINTZ: MOV     A,M
        ORA     A
        RZ
        CALL    PUTC
        INX     H
        JMP     PRINTZ

PUTC:   PUSH    B
     XI     H,DSTFCB
        CALL    CLEAR36
        LDA     SRCDRIVE
        STA     DSTFCB
        LXI     H,NEWNAME
        LXI     D,DSTFCB+1
        MVI     B,11
NECOPY: MOV     A,M
        STAX    D
        INX     H
        INX     D
        D   PUSH    D
        PUSH    H
        MOV     E,A
        MVI     C,CONOUT
        CALL    BDOS
        POP     H
        POP     D
        POP     B
        RET

GETKEY: PUSH    B
        PUSH    D
        PUSH    H
GKWAIT: MVI     E,0FFH
 CR     B
        JNZ     NECOPY
        LXI     D,DIRBUF
        MVI     C,SETDMA
        CALL    BDOS
        LXI     D,DSTFCB
        MVI     C,SFIRST
        CALL    BDOS
        CPI     0FFH
        MVI     A,0
        RZ
        MVI     A,1       MVI     C,DIRIO
        CALL    BDOS
        ORA     A
        JZ      GKWAIT
        POP     H
        POP     D
        POP     B
        RET

SHOWSTART:
        PUSH    PSW
        MVI     A,0CH
        CALL    PUTC
        LXI     H
        RET

BUILDREN:
        CALL    BUILDSRC
        LDA     SRCDRIVE
        STA     SRCFCB+16
        LXI     H,NEWNAME
        LXI     D,SRCFCB+17
        MVI     B,11
BRCOPY: MOV     A,M
        STAX    D
        INX     H
        INX ,STARTMSG
        CALL    PRINTZ
        POP     PSW
        ADI     'A'-1
        CALL    PUTC
        MVI     A,':'
        CALL    PUTC
        LXI     H,WAITMSG
        CALL    PRINTZ
        RET

SHOWREAD:
        PUSH    PSW
        LXI     D
        DCR     B
        JNZ     BRCOPY
        RET

; ---------------------------------------------------------------------------
; Common helpers

YESNO:  CALL    GETKEY
        CPI     'a'
        JC      YNUP
        CPI     'z'+1
      H,READMSG
        CALL    STATUS
        POP     PSW
        ADI     'A'-1
        CALL    PUTC
        MVI     A,':'
        CALL    PUTC
        RET

; ---------------------------------------------------------------------------
; Data

STARTMSG:
        DB      'P2FILE: READING DRIVE ',0
WAITMSG:DB      ' - PLEASE WAIT',0
READMSG:DB      'P2FILE: READING DRIVE ',0
UNKSIZE:DB      '    ?',0
HELP:   DB      'TAB PANEL  W/S MOVE  SPACE MARK  C COPY  D DELETE'
        DB      '  R RENAME   0
CPNUM:  DB      0
MODAL:  DB      0
FOOTMSG:DB      0
KEYTMP: DB      0
MODROWNO:
        DB      0
INLEN:  DB      0
LEAD:   DB      0
SZIDX:  DB      0
SZLEFT:
        DB      0
CPBCOUNT:
        DB      0
CPBLEFT:
        DB      0
  V DRIVE  Q QUIT',0
DRIVEMSG:
        DB      ' DRIVE ',0
FILEMSG:DB      ' FILES ',0
DRVHEAD:DB      'SELECT DRIVE',0
DRVOPTS:DB      'A:  B:  C:  D:  E:  F:',0
DRVPROMPT:
        DB      'PRESS A-F OR ESC TO CANCEL',0
DRVREADY:
        DB      CPEOF:  DB      0

PLIST:  DW      0
SLIST:  DW      0
WORKLIST:
        DW      0
STOREPTR:
        DW      0
CNTPTR: DW      0
DIRPTR: DW      0
ENTRYPTR:
        DW      0
INPTR:  DW      0
CPTOTREC:
        DW      0
CPRECDONE:
        'INSERT DISK BEFORE SELECTING',0
BYEMSG: DB      'P2FILE finished.',13,10,0
NOFILES:DB      'No files in the active panel.',0
SAMEDRV:DB      'Choose two different drives before copying.',0
COPYOK: DB      'Copy complete.',0
COPYERR:DB      'Copy finiDW      0
CPBUFPTR:
        DW      0

SRCHFCB:DS      36
SRCFCB: DS      36
DSTFCB: DS      36
NEWNAME:DS      11
NEWBUF: DS      13
LFILES:DS      MAXFILE*ENTSIZ
RFILES:DS      MAXFILE*ENTSIZ
DIRBUF: DS      128
BUFFER: DS      CPBUFR*128

shed with a disk error.',0
CPHEAD: DB      'COPYING FILES',0
CPFILE: DB      'FILE: ',0
CPSTEP: DB      'FILE ',0
CPOF:   DB      ' OF ',0
CPRECS: DB      'RECORDS ',0
CPACK:  DB      'PRESS A KEY TO CONTINUE',0
OVER1:  DB      'Overwrite ',0
OVER2        DS      128
STACK:

        END     START
ňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňň:  DB      '? (Y/N)',0
DELASK: DB      'Delete selected file(s)? (Y/N)',0
DELOK:  DB      'Delete complete.',0
DELERR: DB      'Delete finished with an error.',0
NEWASK: DB      'New name (ESC cancels): ',0
BADNAME:DB      'Invalid CP/M 8.3 filename.'ňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňň,0
NAMEUSED:
        DB      'That filename already exists.',0
RENOK:  DB      'Rename complete.',0
RENERR: DB      'Rename failed.',0

ACTIVE: DB      0
LDRIVE: DB      1
RDRIVE: DB      2
LCOUNT: DB      0
RCOUNT: DB      0
LCUR:   DB      0
ňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňRCUR:   DB      0
LTOP:   DB      0
RTOP:   DB      0

PCOL:   DB      0
PDRIVE: DB      0
PCOUNT: DB      0
PCUR:   DB      0
PTOP:   DB      0
PACTIVE:DB      0
DRAWIDX:DB      0
DRAWROW:DB      0
DRAWLEFT:
        DB      0
LINEIDX:DB     ňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňň 0
LINEOK: DB      0
LINEATT:DB      NORMATT
OLDCUR: DB      0
OLDTOP: DB      0

SRCDRIVE:
        DB      0
DSTDRIVE:
        DB      0
SCOUNT: DB      0
SCUR:   DB      0
SELMODE:DB      0
LOOPIDX:DB      0
OPERROR:DB      0
CPTOTAL:DB   ňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňň; P2EDIT.ASM - small CP/M text editor for the Philips P2000C
;
; Assemble on the P2000C with Digital Research's tools:
;     ASM P2EDIT
;     LOAD P2EDIT
;     P2EDIT [D:]FILE.TXT
;
; The interface follows the compact style of X16 Edit and GNU nano.     MVI     C,GETDRV
        CALL    BDOS
        INR     A
        STA     CURDRV
        LDA     NAMED
        ORA     A
        JZ      STNEW
        CALL    LOADFIL
        JMP     STDRAW
STNEW:  LDA     MSGON
        ORA     A
        JNZ   It uses
; documented CP/M 2.2 BDOS calls and documented P2000C terminal controls only.
;
; Text is stored as LF-delimited bytes.  CR is discarded while loading and
; restored before LF while saving.  The CP/M 1AH end marker is not kept in RAM.
;
;     STDRAW
        LXI     H,NEWMSG
        CALL    SETMSG
STDRAW: CALL    DRAW

; The UK/NL keyboard cursor quadrant emits the WordStar diamond: ^S left,
; ^D right, ^E up, and ^X down.  Also accept the terminal cursor-control
; bytes used by emulaBuffer invariants:
;   closed gap: BUFBEG through BUFEND-1 is one contiguous text stream
;   open gap:   text is below GAPLO and from GAPHI through BUFLIM-1
;               GAPLO through GAPHI-1 is free. CURPTR=GAPLO, BUFEND=BUFLIM
; TOPPTR is the firstors.  Snapshot display state before dispatching.
MAIN:   CALL    GETKEY
        STA     KEYTMP
        LHLD    TOPPTR
        SHLD    OLDTOP
        LHLD    LEFTCOL
        SHLD    OLDLEFT
        LHLD    COLNUM
        SHLD    EDITCOL
        LDt logical line displayed in the 20-row text viewport.

BDOS    EQU     0005H
CONOUT  EQU     02H
DIRIO   EQU     06H
OPENF   EQU     0FH
CLOSEF  EQU     10H
DELETE  EQU     13H
READSEQ EQU     14H
WRITSEQ EQU     15H
MAKEF   EQU     16H
RENAME  A     MSGON
        STA     OLDMSG
        XRA     A
        STA     MSGON
        STA     EDITCLR
        STA     EDITONE
        LDA     KEYTMP
        CPI     01H
        JZ      KHOME
        CPI     02H
        JZ      KWRDL
        CPI    EQU     17H
GETDRV  EQU     19H
SETDMA  EQU     1AH

LF      EQU     0AH
CR      EQU     0DH
EOFCHR  EQU     1AH

TEXTROW EQU     20
HDRCOL  EQU     26
NORMATT EQU     40H
INVATT  EQU     50H

; The initialized image ends at 1A10H and fixed sc 03H
        JZ      KWRDR
        CPI     04H
        JZ      KRIGHT
        CPI     05H
        JZ      KUP
        CPI     06H
        JZ      KRIGHT
        CPI     07H
        JZ      KHELP
        CPI     08H
        JZ      KBACK
       ratch buffers extend through
; 1C6BH.  The initial stack at 2FF0H leaves 4,996 bytes above reserved data.
; Text uses 3000H-BFFFH (36 KiB).  C000H is reserved by Philips CP/M.
BUFBEG  EQU     3000H
BUFLIM  EQU     0C000H
STACK   EQU     2FF0H

      CPI     09H
        JZ      KTAB
        CPI     0AH
        JZ      KDOWN
        CPI     0BH
        JZ      KCUT
        CPI     0CH
        JZ      KEND
        CPI     0DH
        JZ      KENTER
        CPI     0EH
        JZ      KNEW
     ORG     0100H

; Initialise an empty, closed gap buffer before parsing the CP/M command tail.
START:  LXI     SP,STACK
        LXI     H,BUFBEG
        SHLD    BUFEND
        SHLD    CURPTR
        SHLD    TOPPTR
        XRA     A
        STA        CPI     0FH
        JZ      KSAVE
        CPI     10H
        JZ      KPASTE
        CPI     12H
        JZ      KOPEN
        CPI     13H
        JZ      KLEFT
        CPI     15H
        JZ      KLEFT
        CPI     16H
        JZ         NAMED
        STA     MODIF
        STA     TRUNC
        STA     MSGON
        STA     GAPOPEN
        STA     LEFTCOL
        STA     LEFTCOL+1
        LXI     H,1
        SHLD    LINENUM
        SHLD    TOTLINES
        CALL    GETTAIL
   KPGDN
        CPI     17H
        JZ      KFIND
        CPI     18H
        JZ      KDOWN
        CPI     19H
        JZ      KPGUP
        CPI     1AH
        JZ      KUP
        CPI     1BH
        JZ      KEXIT
        CPI     7FH
        JZ      KDEL
        CPI     20H
        JC      MAIN
        CPI     7FH
        JNC     MAIN
        CALL    MARKEND
        LDA     KEYTMP
        CALL    INSERT
        ORA     A
        JNZ     KINSGOOD
        STA     EDITONE
        JMP    AC: CPI     ' '
        RZ
        CPI     09H
        RZ
        CPI     LF
        RET

KLEFT:  CALL    CURLEFT
        LDA     MOVOK
        ORA     A
        JZ      NAVREF
        LDA     MOVCHR
        CPI     LF
        JZ      KLEFTLF EDITREF
KINSGOOD:
        CALL    COLINC
        JMP     EDITREF

KHOME:  CALL    CLOSEGAP
        LHLD    CURPTR
        CALL    LINSTRT
        SHLD    CURPTR
        CALL    COLZERO
        JMP     NAVREF

KEND:   CALL    CLOSEGAP
        
        CPI     09H
        JZ      KLEFTTB
        CALL    COLDEC
        JMP     NAVREF
KLEFTLF:
        CALL    DECLIN
KLEFTTB:
        CALL    GETCOL
        JMP     NAVREF

KRIGHT: CALL    CURRIGHT
        LDA     MOVOK
        ORA     ALHLD    CURPTR
        CALL    LINEND
        SHLD    CURPTR
        CALL    GETCOL
        JMP     NAVREF

; Ctrl-B skips separators to the left, then backs over one word.  Crossing
; the separator before that word is undone so the cursor rests at 
        JZ      NAVREF
        LDA     MOVCHR
        CPI     LF
        JZ      KRGHTLF
        CPI     09H
        JZ      KRGHTTB
        CALL    COLINC
        JMP     NAVREF
KRGHTLF:
        CALL    INCLIN
        CALL    COLZERO
        Jits start.
KWRDL:
KWLSP:  CALL    CURLEFT
        LDA     MOVOK
        ORA     A
        JZ      KWLDON
        LDA     MOVCHR
        CALL    ISSPAC
        JNZ     KWLWRD
        LDA     MOVCHR
        CPI     LF
        CZ      DECLIN
     MP     NAVREF
KRGHTTB:
        CALL    COLTAB
        JMP     NAVREF

KUP:    CALL    CLOSEGAP
        CALL    UPONE
        CALL    GETCOL
        JMP     NAVREF

KDOWN:  CALL    CLOSEGAP
        CALL    DOWNONE
        CALL    GETCOL
          JMP     KWLSP
KWLWRD: CALL    CURLEFT
        LDA     MOVOK
        ORA     A
        JZ      KWLDON
        LDA     MOVCHR
        CALL    ISSPAC
        JNZ     KWLWRD
        CALL    CURRIGHT
KWLDON: CALL    GETCOL
        JMP     NAVREF
 JMP     NAVREF

KPGUP:  CALL    CLOSEGAP
        MVI     B,TEXTROW-1
KPU1:   PUSH    B
        CALL    UPONE
        POP     B
        DCR     B
        JNZ     KPU1
        CALL    GETCOL
        JMP     NAVREF

KPGDN:  CALL    CLOSEGAP
    
; Ctrl-C first leaves the current word, then skips separators until the
; next word.  Line state is maintained when a skipped separator is LF.
KWRDR:
KWRRWD: CALL    PEEKCUR
        LDA     MOVOK
        ORA     A
        JZ      KWRDON
        LDA    MVI     B,TEXTROW-1
KPD1:   PUSH    B
        CALL    DOWNONE
        POP     B
        DCR     B
        JNZ     KPD1
        CALL    GETCOL
        JMP     NAVREF

KBACK:  XRA     A
        STA     EDITLF
        STA     EDITTAB
        S     MOVCHR
        CALL    ISSPAC
        JZ      KWRRSP
        CALL    CURRIGHT
        JMP     KWRRWD
KWRRSP: CALL    PEEKCUR
        LDA     MOVOK
        ORA     A
        JZ      KWRDON
        LDA     MOVCHR
        CALL    ISSPAC
      TA     MOVOK
        LHLD    CURPTR
        LXI     D,BUFBEG
        CALL    CMPHD
        JZ      KBEDIT
        MVI     A,1
        STA     MOVOK
        DCX     H
        MOV     A,M
        CPI     LF
        JZ      KBACKLF
        CPI       JNZ     KWRDON
        CALL    CURRIGHT
        LDA     MOVCHR
        CPI     LF
        CZ      INCLIN
        JMP     KWRRSP
KWRDON: CALL    GETCOL
        JMP     NAVREF

; Return Z when A is a word separator: space, tab, or line feed.
ISSP09H
        JNZ     KBEDIT
        MVI     A,1
        STA     EDITTAB
        JMP     KBEDIT
KBACKLF:
        MVI     A,1
        STA     EDITLF
KBEDIT: CALL    BACKSP
        LDA     MOVOK
        ORA     A
        JZ      EDITREF
        LDA     EDITLF
        ORA     A
        JZ      KBACKTB
        CALL    DECLIN
        CALL    GETCOL
        JMP     KREDRAW
KBACKTB:
        LDA     EDITTAB
        ORA     A
        JZ      KBACKCH
        CALL    GETCOL
        CALL    MARKDELfilename area, and DRAWPART changes one
; text row.  Most navigation and typing stays on the two cheapest paths.
KREDRAW:
        CALL    ENSURE
        CALL    DRAWVIEW
        JMP     MAIN

KFULL:  CALL    ENSURE
        CALL    DRAW
        JMP
        JMP     EDITREF
KBACKCH:
        CALL    COLDEC
        CALL    MARKDEL
        JMP     EDITREF

KDEL:   XRA     A
        STA     EDITLF
        CALL    PEEKCUR
        LDA     MOVOK
        ORA     A
        JZ      KDEDIT
        L     MAIN

KHEAD:  CALL    ENSURE
        CALL    DRAWHEAD
        JMP     MAIN

; Navigation leaves text unchanged. Repaint it only when the viewport moved.
NAVREF: CALL    ENSURE
        CALL    VIEWCHG
        ORA     A
        JNZ     KREDRAWDA     MOVCHR
        CPI     LF
        JNZ     KDEDIT
        MVI     A,1
        STA     EDITLF
KDEDIT: CALL    DELCUR
        LDA     MOVOK
        ORA     A
        JZ      EDITREF
        LDA     EDITLF
        ORA     A
        JZ      KD
        CALL    HIDECUR
        CALL    DRAWDYN
        CALL    UPDSTAT
        CALL    PLACECUR
        JMP     MAIN

; Ordinary insert/delete operations affect only the suffix at the edit point.
; Avoid clearing and repainting the unchanged prefELCHR
        JMP     KREDRAW
KDELCHR:
        MVI     A,1
        STA     EDITCLR
        JMP     EDITREF

KENTER: MVI     A,LF
        CALL    INSERT
        ORA     A
        JZ      KREDRAW
        CALL    COLZERO
        JMP     KREDRAW
ix.  At end-of-line a typed
; character therefore costs one character write; a middle insertion rewrites
; only the shifted suffix.  Deletion also erases the now-unused row tail.
EDITREF:
        CALL    ENSURE
        CALL    VIEWCHG
        ORA    
KTAB:   CALL    GETCOL
        LDA     COLNUM
        ANI     07H
        MOV     B,A
        MVI     A,8
        SUB     B
        MOV     B,A
KTAB1:  PUSH    B
        MVI     A,' '
        CALL    INSERT
        POP     B
        DCR     B
 A
        JNZ     KREDRAW
        CALL    HIDECUR
        CALL    DRAWDYN
        CALL    DRAWPART
        CALL    UPDSTAT
        CALL    PLACECUR
        JMP     MAIN

; Commands such as Write change only header/status presentation.
STATREF:
        JNZ     KTAB1
        CALL    GETCOL
        JMP     EDITREF

KCUT:   CALL    CLOSEGAP
        CALL    CUTLINE
        CALL    GETCOL
        JMP     KREDRAW

KPASTE: CALL    PASTELN
        CALL    GETCOL
        JMP     KREDRAW

KSAV        CALL    HIDECUR
        CALL    DRAWHDR
        CALL    DRAWSTAT
        CALL    PLACECUR
        JMP     MAIN

; Repaint the status row when a command created a message or when this key
; cleared the message that was displayed previously.
E:  CALL    SAVEFIL
        JMP     STATREF

KOPEN:  CALL    OPENNEW
        CALL    GETCOL
        JMP     KHEAD

KNEW:   CALL    NEWBUF
        CALL    GETCOL
        JMP     KHEAD

KFIND:  CALL    CLOSEGAP
        CALL    FINDTXT
        CAUPDSTAT:
        LDA     OLDMSG
        MOV     B,A
        LDA     MSGON
        ORA     B
        RZ
        JMP     DRAWSTAT

; ---------------------------------------------------------------------------
; Cursor movement and buffer editing

LL    GETPOS
        JMP     NAVREF

KHELP:  CALL    HELPSCR
        JMP     KFULL

KEXIT:  CALL    DOEXIT
        JMP     KREDRAW

; Refresh tiers: DRAW repaints everything, DRAWVIEW omits the static footer,
; DRAWHEAD additionally rebuilds the ; Vertical movement updates the maintained current-line counter only when the
; cursor actually changed lines.  LINENUM/TOTLINES avoid rescanning the file
; for each header update.  COLNUM is likewise maintained during local motion.
UPONE:  LHLD    CURPTR
        SHLD    NAVOLD
        CALL    MOVEUP
        LHLD    CURPTR
        XCHG
        LHLD    NAVOLD
        CALL    CMPHD
        RZ
        JMP     DECLIN

DOWNONE:
        LHLD    CURPTR
        SHLD    NAVOLD
        CALL    MOVEDN     SUB     E
        STA     WANTCOL
        MOV     A,H
        SBB     D
        STA     WANTCOL+1
        XCHG
        DCX     H
        CALL    LINSTRT
        SHLD    MOVEST
        CALL    LINEND
        SHLD    MOVEEND
        JMP     M
        LHLD    CURPTR
        XCHG
        LHLD    NAVOLD
        CALL    CMPHD
        RZ
        JMP     INCLIN

INCLIN: LHLD    LINENUM
        INX     H
        SHLD    LINENUM
        RET

DECLIN: LHLD    LINENUM
        DCX     H
    OVETGT

MOVEDN: LHLD    CURPTR
        CALL    LINSTRT
        XCHG
        LHLD    CURPTR
        MOV     A,L
        SUB     E
        STA     WANTCOL
        MOV     A,H
        SBB     D
        STA     WANTCOL+1
        XCHG
        CALL     SHLD    LINENUM
        RET

INCTOT: LHLD    TOTLINES
        INX     H
        SHLD    TOTLINES
        RET

DECTOT: LHLD    TOTLINES
        DCX     H
        SHLD    TOTLINES
        RET

COLZERO:
        LXI     H,0
        SHLD    C   LINEND
        XCHG
        LHLD    BUFEND
        CALL    CMPHD
        XCHG
        RZ
        INX     H
        SHLD    MOVEST
        CALL    LINEND
        SHLD    MOVEEND

MOVETGT:
        LHLD    MOVEEND
        XCHG
        LHLD   OLNUM
        RET

COLINC: LHLD    COLNUM
        INX     H
        SHLD    COLNUM
        RET

COLDEC: LHLD    COLNUM
        DCX     H
        SHLD    COLNUM
        RET

COLTAB: LHLD    COLNUM
        LXI     D,8
        DAD     D
       MOVEST
        MOV     A,E
        SUB     L
        MOV     C,A
        MOV     A,D
        SBB     H
        MOV     B,A
        LDA     WANTCOL+1
        CMP     B
        JC      MTWANT
        JNZ     MTEND
        LDA     WANTCOL
         MOV     A,L
        ANI     0F8H
        MOV     L,A
        SHLD    COLNUM
        RET

; Record the new visual edit column after Backspace moved the cursor left.
MARKDEL:
        LHLD    COLNUM
        SHLD    EDITCOL
        MVI     A,1
    CMP     C
        JC      MTWANT
        JZ      MTEND
MTEND:  XCHG
        SHLD    CURPTR
        RET
MTWANT: LHLD    MOVEST
        LDA     WANTCOL
        MOV     E,A
        LDA     WANTCOL+1
        MOV     D,A
        DAD     D
        S     STA     EDITCLR
        RET

; Mark a printable insertion that is appending immediately before LF or EOF.
; DRAWPART can write that character directly without scanning the logical line.
MARKEND:
        CALL    PEEKCUR
        LDA     MOVOK
  HLD    CURPTR
        RET

; Insert A at the cursor.  The first local edit opens all remaining free RAM as
; a gap and moves the suffix once.  Later local edits touch only the gap edges.
INSERT: STA     INSTMP
        CALL    OPENGAP
        LDA          ORA     A
        JZ      MEYES
        LDA     MOVCHR
        CPI     LF
        RNZ
MEYES:  MVI     A,1
        STA     EDITONE
        RET

; Move vertically to the same byte offset where possible, or the new line end.
; GETCOL later con GAPOPEN
        ORA     A
        JZ      INSFULL
        LHLD    GAPLO
        XCHG
        LHLD    GAPHI
        CALL    CMPHD
        JZ      INSFULL
        XCHG
        LDA     INSTMP
        MOV     M,A
        INX     H
        SHLD    verts that raw offset to a visual column when tabs occur.
MOVEUP: LHLD    CURPTR
        CALL    LINSTRT
        SHLD    LINETMP
        LXI     D,BUFBEG
        CALL    CMPHD
        RZ
        XCHG
        LHLD    CURPTR
        MOV     A,L
   GAPLO
        SHLD    CURPTR
        MVI     A,1
        STA     MODIF
        LDA     INSTMP
        CPI     LF
        JNZ     INSGOOD
        CALL    INCLIN
        CALL    INCTOT
INSGOOD:
        MVI     A,1
        RET
INSFULL:
        LXI     H,FULLMSG
        CALL    SETMSG
        XRA     A
        RET

BACKSP: LHLD    CURPTR
        LXI     D,BUFBEG
        CALL    CMPHD
        RZ
        LDA     GAPOPEN
        ORA     A
        JZ      BACKOLD
        LHLD    GAPLO
    
        MOV     C,L
        LHLD    BUFEND
        XCHG
        LXI     H,BUFLIM
        MOV     A,L
        SUB     E
        MOV     L,A
        MOV     A,H
        SBB     D
        MOV     H,A
        XCHG
        LHLD    CURPTR
        DA    DCX     H
        MOV     A,M
        STA     DELTMP
        SHLD    GAPLO
        SHLD    CURPTR
        JMP     DELMARK
BACKOLD:
        DCX     H
        SHLD    CURPTR
        JMP     DELCUR

; Delete byte at CURPTR.
DELCUR: LDA     GAPD     D
        SHLD    GAPHI
        LHLD    CURPTR
        XCHG
        LHLD    BUFEND
        CALL    CMPHD
        JZ      GAPSET
        LHLD    BUFEND
        DCX     H
        LXI     D,BUFLIM-1
GAPBACK:
        MOV     A,M
        STAX OPEN
        ORA     A
        JZ      DELOLD
        LHLD    GAPHI
        LXI     D,BUFLIM
        CALL    CMPHD
        RZ
        MOV     A,M
        STA     DELTMP
        INX     H
        SHLD    GAPHI
        JMP     DELMARK
DELOLD: LHL   D
        MOV     A,H
        CMP     B
        JNZ     GAPBNX
        MOV     A,L
        CMP     C
        JZ      GAPSET
GAPBNX: DCX     H
        DCX     D
        JMP     GAPBACK
GAPSET: LXI     H,BUFLIM
        SHLD    BUFEND
        MD    CURPTR
        XCHG
        LHLD    BUFEND
        CALL    CMPHD
        RZ
        LHLD    CURPTR
        MOV     A,M
        STA     DELTMP
        LHLD    BUFEND
        MOV     B,H
        MOV     C,L
        LHLD    CURPTR
        XCHVI     A,1
        STA     GAPOPEN
        RET

; Compact the two occupied segments when a command needs contiguous text.
; Saving, searching, line cut, and vertical line scans deliberately pay this
; one-off cost.  Sustained local editing keeps the G
        LHLD    CURPTR
        INX     H
DELSHFT:
        MOV     A,H
        CMP     B
        JNZ     DELCOPY
        MOV     A,L
        CMP     C
        JZ      DELDONE
DELCOPY:
        MOV     A,M
        STAX    D
        INX     H
 gap open.
CLOSEGAP:
        LDA     GAPOPEN
        ORA     A
        RZ
        LHLD    GAPLO
        XCHG
        LHLD    GAPHI
GAPFWD: LXI     B,BUFLIM
        MOV     A,H
        CMP     B
        JNZ     GAPFCP
        MOV     A,L
              INX     D
        JMP     DELSHFT
DELDONE:
        LHLD    BUFEND
        DCX     H
        SHLD    BUFEND
DELMARK:
        MVI     A,1
        STA     MODIF
        LDA     DELTMP
        CPI     LF
        RNZ
        JMP     DECTOT
 CMP     C
        JZ      GAPCLO
GAPFCP: MOV     A,M
        STAX    D
        INX     H
        INX     D
        JMP     GAPFWD
GAPCLO: XCHG
        SHLD    BUFEND
        LHLD    CURPTR
        SHLD    GAPLO
        SHLD    GAPHI
        XR
; Open the gap by copying the suffix backwards to the top of the text area:
;
;   before: [prefix|suffix|free...............................]
;   after:  [prefix|gap........................|suffix at top]
;
; Copying backwards permits overlap.  The gA     A
        STA     GAPOPEN
        RET

; Move the cursor and gap one byte left/right.  MOVOK reports success and
; MOVCHR is the crossed byte, allowing the caller to maintain line state.
CURLEFT:
        XRA     A
        STA     MOVOK
     ap then contains every unused byte.
OPENGAP:
        LDA     GAPOPEN
        ORA     A
        RNZ
        LHLD    BUFEND
        LXI     D,BUFLIM
        CALL    CMPHD
        RZ
        LHLD    CURPTR
        SHLD    GAPLO
        MOV     B,H   LHLD    CURPTR
        LXI     D,BUFBEG
        CALL    CMPHD
        RZ
        LDA     GAPOPEN
        ORA     A
        JZ      CURLOLD
        LHLD    GAPLO
        DCX     H
        MOV     A,M
        STA     MOVCHR
        SHLD    GAPLO
        SHLD    CURPTR
        LHLD    GAPHI
        DCX     H
        SHLD    GAPHI
        LDA     MOVCHR
        MOV     M,A
        JMP     CUROK
CURLOLD:
        LHLD    CURPTR
        DCX     H
        MOV     A,M
        STA     MOVCHRLEN
        MOV     B,A
        LXI     D,CLIPBUF
CUTCOPY:
        MOV     A,M
        STAX    D
        CPI     LF
        JNZ     CUTCPN
        MVI     A,1
        STA     CUTLF
CUTCPN:
        INX     H
        INX     D
        DCR     B
        SHLD    CURPTR
CUROK:  MVI     A,1
        STA     MOVOK
        RET

CURRIGHT:
        CALL    PEEKCUR
        LDA     MOVOK
        ORA     A
        RZ
        LDA     GAPOPEN
        ORA     A
        JZ      CURROLD
        LHLD
        JNZ     CUTCOPY
        LHLD    BUFEND
        MOV     B,H
        MOV     C,L
        LHLD    MOVEST
        XCHG
        LHLD    MOVEEND
CUTMOVE:
        MOV     A,H
        CMP     B
        JNZ     CUTCOPY1
        MOV     A,L
        GAPHI
        MOV     A,M
        PUSH    PSW
        INX     H
        SHLD    GAPHI
        LHLD    GAPLO
        POP     PSW
        MOV     M,A
        INX     H
        SHLD    GAPLO
        SHLD    CURPTR
        RET
CURROLD:
           CMP     C
        JZ      CUTTAIL
CUTCOPY1:
        MOV     A,M
        STAX    D
        INX     H
        INX     D
        JMP     CUTMOVE
CUTTAIL:
        LHLD    BUFEND
        LDA     CLIPLEN
        MOV     E,A
        MVI     D,0
  LHLD    CURPTR
        INX     H
        SHLD    CURPTR
        RET

PEEKCUR:
        XRA     A
        STA     MOVOK
        LDA     GAPOPEN
        ORA     A
        JZ      PEEKOLD
        LHLD    GAPHI
        LXI     D,BUFLIM
        CAL       MOV     A,L
        SUB     E
        MOV     L,A
        MOV     A,H
        SBB     D
        MOV     H,A
        SHLD    BUFEND
        LHLD    MOVEST
        SHLD    CURPTR
        LHLD    BUFEND
        XCHG
        LHLD    CURPTR
 L    CMPHD
        RZ
        JMP     PEEKGET
PEEKOLD:
        LHLD    CURPTR
        XCHG
        LHLD    BUFEND
        CALL    CMPHD
        XCHG
        RZ
PEEKGET:
        MOV     A,M
        STA     MOVCHR
        MVI     A,1
        ST       CALL    CMPHD
        JC      CUTMOD
        XCHG
        SHLD    CURPTR
CUTMOD: MVI     A,1
        STA     MODIF
        LDA     CUTLF
        ORA     A
        JZ      CUTMSG1
        CALL    DECTOT
CUTMSG1:
        LXI     H,CUTMSG
 A     MOVOK
        RET

; Copy and remove the current logical line.  Its LF is included unless this is
; the final unterminated line.  Clipboard lines are limited to 255 bytes.
CUTLINE:
        XRA     A
        STA     CUTLF
        LHLD    CURPT       CALL    SETMSG
        RET
CUTZERO:
        XRA     A
        STA     CLIPLEN
        RET
CUTLONG:
        LXI     H,LONGMSG
        CALL    SETMSG
        RET

; Paste through INSERT so gap capacity, line totals, and modified state folloR
        CALL    LINSTRT
        SHLD    MOVEST
        CALL    LINEND
        SHLD    MOVEEND
        XCHG
        LHLD    BUFEND
        CALL    CMPHD
        XCHG
        JZ      CUTLEN
        INX     H
        SHLD    MOVEEND
CUTLEN: XCHGw
; exactly the same path as typed text.
PASTELN:
        LDA     CLIPLEN
        ORA     A
        JZ      PASTNON
        MOV     B,A
        LXI     H,CLIPBUF
PASTLP: MOV     A,M
        INX     H
        PUSH    H
        PUSH    B
        
        LHLD    MOVEST
        MOV     A,E
        SUB     L
        MOV     C,A
        MOV     A,D
        SBB     H
        ORA     A
        JNZ     CUTLONG
        MOV     A,C
        ORA     A
        JZ      CUTZERO
        STA     CLIPCALL    INSERT
        POP     B
        POP     H
        DCR     B
        JNZ     PASTLP
        LXI     H,PASTMSG
        CALL    SETMSG
        RET
PASTNON:
        LXI     H,NOCLIP
        CALL    SETMSG
        RET

; Return start/end of the logical line containing pointer HL.  LINEND and all
; forward iterators cross an open gap through SKIPGAP.
LINSTRT:
        PUSH    D
LSLOOP: LXI     D,BUFBEG
        CALL    CMPHD
        JZ      LSDONE
        DCX     H
        MOV     A,M  LHLD    TOPPTR
        CALL    NEXTLIN
        SHLD    TOPPTR
        DCR     B
        JMP     ENSROWS
ENSROW: MOV     A,B
        STA     CURROW
        LHLD    LEFTCOL
        XCHG
        LHLD    COLNUM
        CALL    CMPHD
        JNC   
        CPI     LF
        JZ      LSNEXT
        JMP     LSLOOP
LSNEXT: INX     H
LSDONE: POP     D
        RET

LINEND: PUSH    D
LELOOP: CALL    SKIPGAP
        XCHG
        LHLD    BUFEND
        CALL    CMPHD
        XCHG
        JZ       ENSRGT
        CALL    LEFTCHN
        RET
ENSRGT: LXI     D,79
        LHLD    LEFTCOL
        DAD     D
        XCHG
        LHLD    COLNUM
        CALL    CMPHD
        JC      ENSDONE
        JZ      ENSDONE
        LXI     D,40
        M LEDONE
        MOV     A,M
        CPI     LF
        JZ      LEDONE
        INX     H
        JMP     LELOOP
LEDONE: POP     D
        RET

; Translate the first byte of the gap to the first byte of the suffix.
; Other physical addresses are reOV     A,L
        SUB     E
        MOV     L,A
        MOV     A,H
        SBB     D
        MOV     H,A
        SHLD    LEFTCOL
ENSDONE:
        RET

; Keep the cursor near the middle after crossing either horizontal edge.
; A 40-column step turned unchanged.
SKIPGAP:
        LDA     GAPOPEN
        ORA     A
        RZ
        PUSH    D
        XCHG
        LHLD    GAPLO
        CALL    CMPHD
        JNZ     GAPNOSK
        LHLD    GAPHI
        POP     D
        RET
GAPNOSK:
  avoids a full viewport redraw for every character.
LEFTCHN:
        MOV     A,H
        ORA     A
        JNZ     LEFTSUB
        MOV     A,L
        CPI     40
        JC      LEFTZER
LEFTSUB:
        LXI     D,40
        MOV     A,L
        SU      XCHG
        POP     D
        RET

; Compare HL with DE, preserving both.  Flags match unsigned HL-DE.
CMPHD:  MOV     A,H
        CMP     D
        RNZ
        MOV     A,L
        CMP     E
        RET

; -------------------------------B     E
        MOV     L,A
        MOV     A,H
        SBB     D
        MOV     H,A
        SHLD    LEFTCOL
        RET
LEFTZER:
        LXI     H,0
        SHLD    LEFTCOL
        RET

NEXTLIN:
        CALL    LINEND
        XCHG
        --------------------------------------------
; Viewport calculations and screen drawing

; Keep CURPTR visible.  TOPPTR moves by logical lines, while LEFTCOL moves in
; 40-column chunks.  CURROW is cached for cursor placement and DRAWPART.
ENSURE:
  LHLD    BUFEND
        CALL    CMPHD
        XCHG
        RZ
        INX     H
        RET

; Compute one-based line and zero-based visual column at CURPTR.
GETPOS: LXI     H,1
        SHLD    LINENUM
        LXI     H,BUFBEG
        SHLD    POS      LHLD    TOPPTR
        XCHG
        LHLD    CURPTR
        CALL    CMPHD
        JNC     ENSCNT
        CALL    LINSTRT
        SHLD    TOPPTR
ENSCNT: LHLD    TOPPTR
        MVI     B,0
ENSLP:  XCHG
        LHLD    CURPTR
        CALL    CPTR
GPLOOP: LHLD    POSPTR
        XCHG
        LHLD    CURPTR
        CALL    CMPHD
        XCHG
        JZ      GETCOL
        MOV     A,M
        CPI     LF
        JNZ     GPNEXT
        PUSH    H
        LHLD    LINENUM
        INX     H
MPHD
        XCHG
        JZ      ENSROWS
        MOV     A,M
        CPI     LF
        JNZ     ENSNX
        INR     B
ENSNX:  INX     H
        JMP     ENSLP
ENSROWS:
        MOV     A,B
        CPI     TEXTROW
        JC      ENSROW
              SHLD    LINENUM
        POP     H
GPNEXT: INX     H
        SHLD    POSPTR
        JMP     GPLOOP

GETCOL: LHLD    CURPTR
        CALL    LINSTRT
        SHLD    GCPTR
        XRA     A
        STA     COLNUM
        STA     COLNUM+1
GCLOOP: LHLD    GCPTR
        XCHG
        LHLD    CURPTR
        CALL    CMPHD
        XCHG
        RZ
        MOV     A,M
        CPI     09H
        JZ      GCTAB
        INX     H
        SHLD    GCPTR
        LHLD    COLNUM
        INX     Hd visual column.  EDITCOL is the
; column before insertion (or after Backspace), so an append writes one cell
; while a middle edit writes just the shifted suffix.  Scanning still begins
; at the logical line start because tab widths depend on the prece
        SHLD    COLNUM
        JMP     GCLOOP
GCTAB:  INX     H
        SHLD    GCPTR
        LHLD    COLNUM
        LXI     D,8
        DAD     D
        MOV     A,L
        ANI     0F8H
        MOV     L,A
        SHLD    COLNUM
        JMP ding text.
DRAWPART:
        LDA     EDITONE
        ORA     A
        JNZ     DRAWCHAR
        LHLD    EDITCOL
        XCHG
        LHLD    LEFTCOL
        CALL    CMPHD
        JNC     DPSTART
        XCHG
DPSTART:
        SHLD    EMITCOL
      GCLOOP

HIDECUR:
        MVI     A,1BH
        CALL    PUTC
        MVI     A,'c'
        JMP     PUTC

; Physical screen layout:
;   row 0 header, rows 1-20 text, row 21 status, rows 22-23 shortcuts.
; DRAWVIEW never emits the shortcut rows,      XCHG
        LHLD    LEFTCOL
        MOV     A,E
        SUB     L
        MOV     C,A
        MOV     A,D
        SBB     H
        ORA     A
        RNZ
        MOV     A,C
        CPI     80
        RNC
        LDA     CURROW
         so scrolling cannot disturb them.
DRAW:   MVI     A,1
        STA     FOOTON
        STA     HEADON
        JMP     DRAWENT

; Refresh header, text viewport and status without rewriting the static menu.
DRAWVIEW:
        XRA     A
        STA    INR     A
        MOV     B,A
        CALL    POS
        MVI     A,NORMATT
        CALL    SETATTR
        XRA     A
        STA     VISCOL
        STA     VISCOL+1
        MOV     A,C
        STA     OUTCOL
        LHLD    CURPTR
        CALL  FOOTON
        STA     HEADON
        JMP     DRAWENT

; Refresh a changed filename/header without repainting the static footer.
DRAWHEAD:
        XRA     A
        STA     FOOTON
        INR     A
        STA     HEADON
DRAWENT:
        CALL     LINSTRT
        SHLD    DRAWPTR
        CALL    DLBODY
        LDA     EDITCLR
        ORA     A
        RZ
        LDA     OUTCOL
        CPI     80
        RNC
        JMP     ERASE

; Fast path for the overwhelmingly common append case.  E  HIDECUR
        LDA     HEADON
        ORA     A
        JZ      DRAWDY1
        CALL    DRAWHDR
        JMP     DRAWHDN
DRAWDY1:
        CALL    DRAWDYN
DRAWHDN:
        LHLD    TOPPTR
        SHLD    DRAWPTR
        MVI     A,1
        STA DITCOL was visible
; before the insertion; if advancing the cursor scrolled, EDITREF selected a
; full viewport redraw before reaching here.
DRAWCHAR:
        LHLD    EDITCOL
        XCHG
        LHLD    LEFTCOL
        MOV     A,E
        SUB         DRAWROW
DRLOOP: LDA     DRAWROW
        CPI     TEXTROW+1
        JZ      DRFOOT
        MOV     B,A
        MVI     C,0
        CALL    POS
        MVI     A,NORMATT
        CALL    SETATTR
        CALL    ERASE
        CALL    DRAWLIN
    L
        MOV     C,A
        LDA     CURROW
        INR     A
        MOV     B,A
        CALL    POS
        MVI     A,NORMATT
        CALL    SETATTR
        LDA     KEYTMP
        JMP     PUTC

PLACECUR:
        LDA     CURROW
        INR     LDA     DRAWROW
        INR     A
        STA     DRAWROW
        JMP     DRLOOP
DRFOOT: CALL    DRAWSTAT
        LDA     FOOTON
        ORA     A
        CNZ     DRAWHELP
        JMP     PLACECUR

; Redraw a logical row from the first change    A
        MOV     B,A
        LHLD    COLNUM
        XCHG
        LHLD    LEFTCOL
        MOV     A,E
        SUB     L
        MOV     C,A
        CALL    POS
        MVI     A,NORMATT
        CALL    SETATTR
        MVI     A,1BH
        CALL    PUTC
        MVI     A,'C'
        CALL    PUTC
        RET

; Return non-zero when a scrolling operation changed the viewport.
VIEWCHG:
        LHLD    TOPPTR
        XCHG
        LHLD    OLDTOP
        CALL    CMPHD
        JNZ     VCY       JZ      DSDEF
        LXI     H,MSGBUF
        JMP     PRINTZ
DSDEF:  LXI     H,DEFSTAT
        JMP     PRINTZ

DRAWHELP:
        MVI     B,22
        MVI     C,0
        CALL    POS
        MVI     A,INVATT
        CALL    SETATTR
     ES
        LHLD    LEFTCOL
        XCHG
        LHLD    OLDLEFT
        CALL    CMPHD
        JNZ     VCYES
        XRA     A
        RET
VCYES:  MVI     A,1
        RET

DRAWHDR:
        MVI     B,0
        MVI     C,0
        CALL    POS
    CALL    ERASE
        LXI     H,HELP1
        CALL    PRINTZ
        MVI     B,23
        MVI     C,0
        CALL    POS
        CALL    ERASE
        LXI     H,HELP2
        CALL    PRINTZ
        MVI     A,NORMATT
        CALL    SETATTR
        MVI     A,INVATT
        CALL    SETATTR
        CALL    ERASE
        LXI     H,APPTIT
        CALL    PRINTZ
        LDA     NAMED
        ORA     A
        JZ      DHNEW
        LXI     H,FILEFCB
        CALL    PRNAME
        JMP     D       RET

; Draw one logical line from DRAWPTR.  VISCOL tracks the complete visual line,
; including tab expansion.  OUTCOL counts only characters emitted on screen.
; Once 80 columns are visible, scan directly to LF without drawing the tail.
DRAWLIRAWDYN
DHNEW:  LXI     H,NONAME
        CALL    PRINTZ
        JMP     DRAWDYN

; The filename is static during ordinary editing.  Rewrite only the changing
; modified marker, line counters and column field at a fixed header position.
DRAWDYN:
    N:
        XRA     A
        STA     VISCOL
        STA     VISCOL+1
        STA     OUTCOL
        LHLD    LEFTCOL
        SHLD    EMITCOL
DLBODY:
        LHLD    DRAWPTR
DLLP:   CALL    SKIPGAP
        XCHG
        LHLD    BUFEND
        CALL    MVI     B,0
        MVI     C,HDRCOL
        CALL    POS
        MVI     A,INVATT
        CALL    SETATTR
        CALL    ERASE
DHMOD:  LDA     MODIF
        ORA     A
        JZ      DHCLEAN
        LXI     H,MODTXT
        CALL    PRINTZ
     CMPHD
        XCHG
        JZ      DLDONE
        MOV     A,M
        CPI     LF
        JZ      DLNL
        CPI     09H
        JZ      DLTAB
        MOV     E,A
        CALL    DLEMIT
        INX     H
        LDA     OUTCOL
        CPI        JMP     DHPOS
DHCLEAN:LXI     H,CLNTXT
        CALL    PRINTZ
DHPOS:  LXI     H,LNTXT
        CALL    PRINTZ
        LHLD    LINENUM
        XRA     A
        STA     LEAD
        CALL    PRINT16
        MVI     A,'/'
        CALL    PUTC    80
        JC      DLLP
        JMP     DLSKIP
DLTAB:  PUSH    H
        LHLD    VISCOL
        LXI     D,8
        DAD     D
        MOV     A,L
        ANI     0F8H
        STA     TABEND
        MOV     A,H
        STA     TABEND+1
     
        LHLD    TOTLINES
        XRA     A
        STA     LEAD
        CALL    PRINT16
        LXI     H,COLTXT
        CALL    PRINTZ
        LHLD    COLNUM
        INX     H
        XRA     A
        STA     LEAD
        CALL    PRINT16
       POP     H
DLTAB1: MVI     E,' '
        CALL    DLEMIT
        LHLD    VISCOL
        XCHG
        LHLD    TABEND
        CALL    CMPHD
        XCHG
        JNZ     DLTAB1
        INX     H
        LDA     OUTCOL
        CPI     80
        J    MVI     A,NORMATT
        CALL    SETATTR
        RET

DRAWSTAT:
        MVI     B,21
        MVI     C,0
        CALL    POS
        MVI     A,NORMATT
        CALL    SETATTR
        CALL    ERASE
        LDA     MSGON
        ORA     A
 C      DLLP
DLSKIP: CALL    SKIPGAP
        XCHG
        LHLD    BUFEND
        CALL    CMPHD
        XCHG
        JZ      DLDONE
        MOV     A,M
        INX     H
        CPI     LF
        JNZ     DLSKIP
        SHLD    DRAWPTR
        RET
DLNL:   INX     H
        SHLD    DRAWPTR
        RET
DLDONE: SHLD    DRAWPTR
        RET

; Advance visual column and emit E once it reaches EMITCOL.  Full-row drawing
; sets EMITCOL to LEFTCOL; partial drawing sets it to the first changed colum      JMP     PNLOOP
PNNODR: DCX     H
PNLOOP: MOV     A,M
        ORA     A
        JZ      PNEND
        CPI     '.'
        JZ      PNDOT
        CPI     21H
        JC      PNBAD
        CPI     7FH
        JNC     PNBAD
        CPI     '*'n.
DLEMIT: PUSH    H
        MOV     A,E
        STA     DRAWC
        LHLD    EMITCOL
        XCHG
        LHLD    VISCOL
        CALL    CMPHD
        JC      DLENO
        LDA     OUTCOL
        CPI     80
        JNC     DLENO
        LDA  
        JZ      PNBAD
        CPI     '?'
        JZ      PNBAD
        CPI     '/'
        JZ      PNBAD
        CPI     ':'
        JZ      PNBAD
        CPI     ';'
        JZ      PNBAD
        CPI     '<'
        JZ      PNBAD
        CPI    DRAWC
        CPI     20H
        JNC     DLEPR
        MVI     A,'.'
DLEPR:  CALL    PUTC
        LDA     OUTCOL
        INR     A
        STA     OUTCOL
DLENO:  LHLD    VISCOL
        INX     H
        SHLD    VISCOL
        POP     H
        '='
        JZ      PNBAD
        CPI     '>'
        JZ      PNBAD
        CPI     '['
        JZ      PNBAD
        CPI     ']'
        JZ      PNBAD
        CALL    UPPER
        MOV     C,A
        LDA     PART
        ORA     A
           RET

; ---------------------------------------------------------------------------
; File name parsing and CP/M file operations

GETTAIL:
        LDA     005DH
        CPI     ' '
        RZ
        ORA     A
        RZ
        LXI     H,005 JNZ     PNNEXT
        LDA     BASECNT
        CPI     8
        JNC     PNBAD
        MOV     E,A
        MVI     D,0
        PUSH    H
        LXI     H,NEWFCB+1
        DAD     D
        MOV     M,C
        POP     H
        LDA     BASECNTCH
        LXI     D,FILEFCB
        CALL    COPY36
        MVI     A,1
        STA     NAMED
        RET

; Parse INBUF into NEWFCB.  Returns A=1 on success.
PARSNEW:
        LXI     H,NEWFCB
        MVI     B,36
        XRA     A
PNCLR:  MOV 
        INR     A
        STA     BASECNT
        INX     H
        JMP     PNLOOP
PNNEXT: LDA     EXTCNT
        CPI     3
        JNC     PNBAD
        MOV     E,A
        MVI     D,0
        PUSH    H
        LXI     H,NEWFCB+9
        DAD      M,A
        INX     H
        DCR     B
        JNZ     PNCLR
        LDA     CURDRV
        STA     NEWFCB
        LXI     H,NEWFCB+1
        MVI     B,11
        MVI     A,' '
PNFILL: MOV     M,A
        INX     H
        DCR     B
         D
        MOV     M,C
        POP     H
        LDA     EXTCNT
        INR     A
        STA     EXTCNT
        INX     H
        JMP     PNLOOP
PNDOT:  LDA     PART
        ORA     A
        JNZ     PNBAD
        LDA     BASECNT
        ORA  JNZ     PNFILL
        XRA     A
        STA     BASECNT
        STA     EXTCNT
        STA     PART
        LXI     H,INBUF
        MOV     A,M
        ORA     A
        JZ      PNBAD
        CALL    UPPER
        STA     PARTCHR
        INX      A
        JZ      PNBAD
        MVI     A,1
        STA     PART
        INX     H
        JMP     PNLOOP
PNEND:  LDA     BASECNT
        ORA     A
        JZ      PNBAD
        LDA     PART
        ORA     A
        JZ      PNGOOD
           H
        MOV     A,M
        CPI     ':'
        JNZ     PNNODR
        LDA     PARTCHR
        CPI     'A'
        JC      PNBAD
        CPI     'P'+1
        JNC     PNBAD
        SUI     'A'-1
        STA     NEWFCB
        INX     H
   LDA     EXTCNT
        ORA     A
        JZ      PNBAD
PNGOOD: MVI     A,1
        RET
PNBAD:  LXI     H,BADNAME
        CALL    SETMSG
        XRA     A
        RET

UPPER:  CPI     'a'
        RC
        CPI     'z'+1
        RNC
        SUI     20H
        RET

; Read sequential 128-byte CP/M records into contiguous text.  CR and the 1AH
; end marker are file-format bytes rather than editor bytes.  If BUFLIM is
; reached, retain a read-only prefix so Save cannot destroy the original.L    SETMSG
        RET
LOADNEW:
        LXI     H,BUFBEG
        SHLD    BUFEND
        SHLD    CURPTR
        SHLD    TOPPTR
        LXI     H,1
        SHLD    LINENUM
        SHLD    TOTLINES
        XRA     A
        STA     MODIF
        
LOADFIL:
        CALL    CLOSEGAP
        CALL    RESETFC
        LXI     D,FILEFCB
        MVI     C,OPENF
        CALL    BDOS
        CPI     0FFH
        JZ      LOADNEW
        LXI     H,BUFBEG
        SHLD    BUFEND
        SHLD    CURPTRSTA     TRUNC
        LXI     H,NEWFMSG
        CALL    SETMSG
        RET

RESETFC:
        LXI     H,FILEFCB+12
        MVI     B,24
        XRA     A
RFLOOP: MOV     M,A
        INX     H
        DCR     B
        JNZ     RFLOOP
        RET
        SHLD    TOPPTR
        LXI     H,1
        SHLD    LINENUM
        SHLD    TOTLINES
        XRA     A
        STA     GAPOPEN
        STA     TRUNC
LOADREC:
        LXI     D,DISKBUF
        MVI     C,SETDMA
        CALL    BDOS
       

; Save through a temporary FCB on the destination drive.  Only after all
; records close successfully is the old name deleted and the temporary file
; renamed, reducing the chance of losing the original after an I/O failure.
SAVEFIL:
        CALL   LXI     D,FILEFCB
        MVI     C,READSEQ
        CALL    BDOS
        ORA     A
        JNZ     LOADDON
        LXI     H,DISKBUF
        MVI     B,128
LOADBYT:
        MOV     A,M
        CPI     EOFCHR
        JZ      LOADDON
        CPI    CLOSEGAP
        LDA     TRUNC
        ORA     A
        JZ      SVNAME
        LXI     H,NOSAVEM
        CALL    SETMSG
        RET
SVNAME: LDA     NAMED
        ORA     A
        JNZ     SAVEDO
        LXI     H,WRITEPM
        CALL    INPUT   CR
        JZ      LOADNXT
        MOV     C,A
        LHLD    BUFEND
        LXI     D,BUFLIM
        CALL    CMPHD
        JZ      LOADFUL
        MOV     A,C
        MOV     M,A
        INX     H
        SHLD    BUFEND
        MOV     A,C
        ORA     A
        RZ
        CALL    PARSNEW
        ORA     A
        RZ
        LXI     H,NEWFCB
        LXI     D,FILEFCB
        CALL    COPY36
        MVI     A,1
        STA     NAMED
SAVEDO: CALL    BUILDTMP
        LXI     D,TM
        CPI     LF
        CZ      INCTOT
        LXI     H,DISKBUF
        LDA     LOADIDX
        MOV     E,A
        MVI     D,0
        DAD     D
LOADNXT:
        INX     H
        LDA     LOADIDX
        INR     A
        STA     LOADIDX
PFCB
        MVI     C,DELETE
        CALL    BDOS
        LXI     D,TMPFCB
        MVI     C,MAKEF
        CALL    BDOS
        CPI     0FFH
        JZ      SAVEERR
        LXI     H,BUFBEG
        SHLD    SAVEPTR
        LXI     H,DISKBUF
            DCR     B
        JNZ     LOADBYT
        XRA     A
        STA     LOADIDX
        JMP     LOADREC
LOADFUL:
        MVI     A,1
        STA     TRUNC
LOADDON:
        LXI     D,FILEFCB
        MVI     C,CLOSEF
        CALL    BDOS
        SHLD    OUTPTR
        XRA     A
        STA     OUTCNT
        STA     IOERR
SVLOOP: LHLD    SAVEPTR
        XCHG
        LHLD    BUFEND
        CALL    CMPHD
        XCHG
        JZ      SVEOF
        MOV     A,M
        INX     H
           XRA     A
        STA     GAPOPEN
        STA     MODIF
        STA     LOADIDX
        LDA     TRUNC
        ORA     A
        JZ      LOADOK
        LXI     H,TRUNMSG
        CALL    SETMSG
        RET
LOADOK: LXI     H,READMSG
        CAL SHLD    SAVEPTR
        CPI     LF
        JNZ     SVCHAR
        MVI     A,CR
        CALL    OUTBYTE
        MVI     A,LF
SVCHAR: CALL    OUTBYTE
        LDA     IOERR
        ORA     A
        JNZ     SVCLOSE
        JMP     SVLOOP
SVEOF:  MVI     A,EOFCHR
        CALL    OUTBYTE
SVPAD:  LDA     OUTCNT
        ORA     A
        JZ      SVCLOSE
        MVI     A,EOFCHR
        CALL    OUTBYTE
        JMP     SVPAD
SVCLOSE:
        LXI     D,TMPFCB
        MVI     C,CLOSEF
        CA BTCLR
        LDA     FILEFCB
        STA     TMPFCB
        LXI     H,TMPNAME
        LXI     D,TMPFCB+1
        MVI     B,11
BTCPY:  MOV     A,M
        STAX    D
        INX     H
        INX     D
        DCR     B
        JNZ     BTCPY
  LL    BDOS
        CPI     0FFH
        JNZ     SVCHK
        MVI     A,1
        STA     IOERR
SVCHK:  LDA     IOERR
        ORA     A
        JNZ     SAVEERR
        CALL    RESETFC
        LXI     D,FILEFCB
        MVI     C,DELETE
        CA      RET

BUILDRN:
        LXI     H,TMPFCB+12
        MVI     B,24
        XRA     A
BRCLR:  MOV     M,A
        INX     H
        DCR     B
        JNZ     BRCLR
        LDA     FILEFCB
        STA     TMPFCB+16
        LXI     H,FILEFCB+1
LL    BDOS
        CALL    BUILDRN
        LXI     D,TMPFCB
        MVI     C,RENAME
        CALL    BDOS
        CPI     0FFH
        JZ      SAVEREN
        XRA     A
        STA     MODIF
        LXI     H,WROTE1
        CALL    SETMSG
              LXI     D,TMPFCB+17
        MVI     B,11
BRCPY:  MOV     A,M
        STAX    D
        INX     H
        INX     D
        DCR     B
        JNZ     BRCPY
        RET

OPENNEW:
        CALL    DISOK
        ORA     A
        RZ
        LXI     H,MSGBUF
        CALL    STRLEN
        XCHG
        LXI     H,FILEFCB
        CALL    NAMEBUF
        RET
SAVEERR:
        LXI     D,TMPFCB
        MVI     C,DELETE
        CALL    BDOS
        LXI     H,SAVEMSG
        CALL    SETMSG  LXI     H,OPENPM
        CALL    INPUT
        ORA     A
        RZ
        CALL    PARSNEW
        ORA     A
        RZ
        LXI     H,NEWFCB
        LXI     D,FILEFCB
        CALL    COPY36
        MVI     A,1
        STA     NAMED
     
        RET
SAVEREN:
        LXI     H,RENAMEM
        CALL    SETMSG
        RET

; Append A to the 128-byte output record and flush it through BDOS when full.
OUTBYTE:
        PUSH    B
        PUSH    D
        PUSH    H
        MOV     B,A   XRA     A
        STA     LEFTCOL
        STA     LEFTCOL+1
        CALL    LOADFIL
        RET

NEWBUF: CALL    DISOK
        ORA     A
        RZ
        LXI     H,BUFBEG
        SHLD    BUFEND
        SHLD    CURPTR
        SHLD    TOPPTR
        LHLD    OUTPTR
        MOV     M,B
        INX     H
        SHLD    OUTPTR
        LDA     OUTCNT
        INR     A
        STA     OUTCNT
        CPI     128
        JNZ     OUTDONE
        LXI     D,DISKBUF
        MVI     C,SETDMA

        LXI     H,1
        SHLD    LINENUM
        SHLD    TOTLINES
        XRA     A
        STA     GAPOPEN
        STA     NAMED
        STA     MODIF
        STA     TRUNC
        STA     LEFTCOL
        STA     LEFTCOL+1
        LXI     H        CALL    BDOS
        LXI     D,TMPFCB
        MVI     C,WRITSEQ
        CALL    BDOS
        ORA     A
        JZ      OUTRST
        MVI     A,1
        STA     IOERR
OUTRST: LXI     H,DISKBUF
        SHLD    OUTPTR
        XRA     A
  ,NEWMSG
        CALL    SETMSG
        RET

; Confirm discarding a modified buffer.  Returns A=1 when operation may go on.
DISOK:  LDA     MODIF
        ORA     A
        JZ      DISYES
        LXI     H,DISCARD
        CALL    YESNO
        RET      STA     OUTCNT
OUTDONE:
        POP     H
        POP     D
        POP     B
        RET

BUILDTMP:
        LXI     H,TMPFCB
        MVI     B,36
        XRA     A
BTCLR:  MOV     M,A
        INX     H
        DCR     B
        JNZ    
DISYES: MVI     A,1
        RET

; ---------------------------------------------------------------------------
; Search, help and exit

; Forward, case-sensitive search over contiguous text.  The dispatcher closes
; the gap before entering, so the inner comparison can use simple addresses.
FINDTXT:
        LXI     H,FINDPM
        CALL    INPUT
        ORA     A
        RZ
        LHLD    CURPTR
        SHLD    FINDPTR
FINDNXT:
        LHLD    FINDPTR
        XCHG
        LHLD    BUFEND

        LXI     H,INBUF
        MVI     M,0
        SHLD    INPTR
        XRA     A
        STA     INLEN
INKEY:  CALL    GETKEY
        CPI     1BH
        JZ      INCAN
        CPI     CR
        JZ      INDONE
        CPI     08H
        JZ         CALL    CMPHD
        XCHG
        JZ      FINDNO
        SHLD    CANDPTR
        LXI     D,INBUF
FINDCMP:
        LDAX    D
        ORA     A
        JZ      FINDFND
        PUSH    D
        XCHG
        LHLD    BUFEND
        CALL        INBACK
        CPI     7FH
        JZ      INBACK
        CPI     20H
        JC      INKEY
        CPI     7FH
        JNC     INKEY
        MOV     B,A
        LDA     INLEN
        CPI     31
        JNC     INKEY
        MOV     A,B
   CMPHD
        XCHG
        POP     D
        JZ      FINDNO
        LDAX    D
        CMP     M
        JNZ     FINDINC
        INX     H
        INX     D
        JMP     FINDCMP
FINDINC:
        LHLD    FINDPTR
        INX     H
        SHL      LHLD    INPTR
        MOV     M,A
        INX     H
        MVI     M,0
        SHLD    INPTR
        LDA     INLEN
        INR     A
        STA     INLEN
        MOV     A,B
        CALL    PUTC
        JMP     INKEY
INBACK: LDA     INLED    FINDPTR
        JMP     FINDNXT
FINDFND:
        LHLD    CANDPTR
        SHLD    CURPTR
        LXI     H,FOUNDMS
        CALL    SETMSG
        RET
FINDNO: LXI     H,NOTFOUND
        CALL    SETMSG
        RET

HELPSCR:
        MVI     AN
        ORA     A
        JZ      INKEY
        DCR     A
        STA     INLEN
        LHLD    INPTR
        DCX     H
        MVI     M,0
        SHLD    INPTR
        MVI     A,08H
        CALL    PUTC
        MVI     A,' '
        CALL   ,0CH
        CALL    PUTC
        MVI     A,INVATT
        CALL    SETATTR
        LXI     H,HELPTIT
        CALL    PRINTZ
        MVI     A,NORMATT
        CALL    SETATTR
        LXI     H,HELPTXT
        CALL    PRINTZ
        CALL    GETKEY PUTC
        MVI     A,08H
        CALL    PUTC
        JMP     INKEY
INDONE: LDA     INLEN
        ORA     A
        RZ
        MVI     A,1
        RET
INCAN:  XRA     A
        RET

YESNO:  CALL    PROMROW
        CALL    PRINTZ
YNKEY:  CA
        RET

DOEXIT: LDA     MODIF
        ORA     A
        JZ      EXITNOW
        LXI     H,SAVEASK
        CALL    ASK3
        CPI     'C'
        RZ
        CPI     'N'
        JZ      EXITNOW
        CALL    SAVEFIL
        LDA     MODILL    GETKEY
        CALL    UPPER
        CPI     'Y'
        JZ      YNYES
        CPI     'N'
        JNZ     YNKEY
        XRA     A
        RET
YNYES:  MVI     A,1
        RET

; Ask for Y/N/C and return the uppercase character.
ASK3:   CAF
        ORA     A
        RNZ
EXITNOW:
        MVI     A,NORMATT
        CALL    SETATTR
        MVI     A,0CH
        CALL    PUTC
        MVI     A,1BH
        CALL    PUTC
        MVI     A,'C'
        CALL    PUTC
        LXI     H,BYEMSGLL    PROMROW
        CALL    PRINTZ
A3KEY:  CALL    GETKEY
        CALL    UPPER
        CPI     'Y'
        RZ
        CPI     'N'
        RZ
        CPI     'C'
        JNZ     A3KEY
        RET

PROMROW:
        MVI     A,1BH
        CALL
        CALL    PRINTZ
        JMP     0000H

; ---------------------------------------------------------------------------
; Prompts, text and terminal helpers

INPUT:  PUSH    H
        CALL    PROMROW
        POP     H
        CALL    PRINTZ    PUTC
        MVI     A,'c'
        CALL    PUTC
        MVI     B,21
        MVI     C,0
        CALL    POS
        MVI     A,INVATT
        CALL    SETATTR
        CALL    ERASE
        RET

SETMSG: LXI     D,MSGBUF
        MVI     B,79
SMCOPY: MOV     A,M
        ORA     A
        JZ      SMDONE
        STAX    D
        INX     H
        INX     D
        DCR     B
        JNZ     SMCOPY
SMDONE: XRA     A
        STAX    D
        MVI     A,1
        STA     MSGON
        RE  JMP     STRLEN

PRINT16:
        LXI     D,10000
        CALL    PDIGIT
        LXI     D,1000
        CALL    PDIGIT
        LXI     D,100
        CALL    PDIGIT
        LXI     D,10
        CALL    PDIGIT
        MOV     A,L
        ADI    T

COPY36: MVI     B,36
C36LP:  MOV     A,M
        STAX    D
        INX     H
        INX     D
        DCR     B
        JNZ     C36LP
        RET

PRNAME: MOV     A,M
        ORA     A
        JZ      PNDDEF
        ADI     'A'-1
        '0'
        JMP     PUTC

PDIGIT: MVI     B,0
PDLOOP: MOV     A,H
        CMP     D
        JC      PDDONE
        JNZ     PDSUB
        MOV     A,L
        CMP     E
        JC      PDDONE
PDSUB:  MOV     A,L
        SUB     E
        MOV    CALL    PUTC
        MVI     A,':'
        CALL    PUTC
PNDDEF: INX     H
        MVI     B,8
PNBASE: MOV     A,M
        ANI     7FH
        CPI     ' '
        CZ      PNVOID
        CNZ     PUTC
        INX     H
        DCR     B
        J  L,A
        MOV     A,H
        SBB     D
        MOV     H,A
        INR     B
        JMP     PDLOOP
PDDONE: LDA     LEAD
        ORA     A
        JNZ     PDOUT
        MOV     A,B
        ORA     A
        RZ
        MVI     A,1
        NZ     PNBASE
        MOV     A,M
        ANI     7FH
        CPI     ' '
        RZ
        MVI     A,'.'
        CALL    PUTC
        MVI     B,3
PNEXT:  MOV     A,M
        ANI     7FH
        CPI     ' '
        CZ      PNVOID
        CNZ  STA     LEAD
PDOUT:  MOV     A,B
        ADI     '0'
        JMP     PUTC

PRINTZ: MOV     A,M
        ORA     A
        RZ
        CALL    PUTC
        INX     H
        JMP     PRINTZ

ERASE:  MVI     A,1BH
        CALL    PUTC
        MVI    PUTC
        INX     H
        DCR     B
        JNZ     PNEXT
PNVOID: RET

; Append an FCB name to a zero-terminated destination DE.
NAMEBUF:
        PUSH    D
        MOV     A,M
        ORA     A
        JZ      NBDEF
        ADI     'A'-    A,'K'
        JMP     PUTC

SETATTR:MOV     B,A
        MVI     A,1BH
        CALL    PUTC
        MVI     A,'0'
        CALL    PUTC
        MOV     A,B
        JMP     PUTC

POS:    PUSH    B
        MVI     A,1BH
        CALL    PUTC
 1
        STAX    D
        INX     D
        MVI     A,':'
        STAX    D
        INX     D
NBDEF:  INX     H
        MVI     B,8
NBBAS:  MOV     A,M
        CPI     ' '
        JZ      NBBNX
        STAX    D
        INX     D
NBBNX:  INX       MVI     A,'Y'
        CALL    PUTC
        POP     B
        MOV     A,B
        ADI     20H
        CALL    PUTC
        MOV     A,C
        ADI     20H
        JMP     PUTC

PUTC:   PUSH    B
        PUSH    D
        PUSH    H
           H
        DCR     B
        JNZ     NBBAS
        MOV     A,M
        CPI     ' '
        JZ      NBDONE
        MVI     A,'.'
        STAX    D
        INX     D
        MVI     B,3
NBEXT:  MOV     A,M
        CPI     ' '
        JZ        MOV     E,A
        MVI     C,CONOUT
        CALL    BDOS
        POP     H
        POP     D
        POP     B
        RET

GETKEY: PUSH    B
        PUSH    D
        PUSH    H
GKWAIT: MVI     E,0FFH
        MVI     C,DIRIO
        CALL   NBEXNX
        STAX    D
        INX     D
NBEXNX: INX     H
        DCR     B
        JNZ     NBEXT
NBDONE: XRA     A
        STAX    D
        POP     D
        RET

STRLEN: MOV     A,M
        ORA     A
        RZ
        INX     H
       BDOS
        ORA     A
        JZ      GKWAIT
        POP     H
        POP     D
        POP     B
        RET

; ---------------------------------------------------------------------------
; Display strings and program state

APPTIT: DB      ' P2EDIT  ',0
NONAME: DB      '<new buffer>',0
MODTXT: DB      '  *',0
CLNTXT: DB      '   ',0
LNTXT:  DB      '   Ln ',0
COLTXT: DB      ' Col ',0
DEFSTAT:
        DB      'P2000C cursor keys move; TAB inserts spaces; DEL deletes',0
HELP1:  DB    
DISCARD:DB      'Discard unsaved changes? (Y/N) ',0
SAVEASK:DB      'Save changes before exit? (Y/N/C) ',0
SAVEMSG:DB      'Disk error while writing; original file was not replaced',0
RENAMEM:DB      'Saved as $P2EDIT$.$$$ but could not install final n  '^G Help  ^O Write  ^R Open  ^Y PgUp  ^K Cut line'
        DB      '  ^W Find',0
HELP2:  DB      'Esc Exit ^N New    ^V PgDn  ^P Paste   ^A/^L Home/End'
        DB      '  BS/DEL',0

HELPTIT:
        DB      ' P2EDIT help',13,10,13,10,0
HELPTXT:
ame',0
WROTE1: DB      'Wrote ',0
CUTMSG: DB      'Line cut',0
PASTMSG:DB      'Clipboard pasted',0
NOCLIP: DB      'Clipboard is empty',0
LONGMSG:DB      'Line is too long for the 255-byte clipboard',0
FOUNDMS:DB      'Found',0
NOTFOUND:
        D        DB      'Cursor keys    Move through the text',13,10
        DB      '^B / ^C       Move to previous/next word',13,10
        DB      '^A / ^L       Start or end of the current line',13,10
        DB      'PgUp / PgDn  Move one screen',13,10
  B      'Text not found after cursor',0
BYEMSG: DB      'P2EDIT finished.',13,10,0
TMPNAME:DB      '$P2EDIT$$$$'

; One-byte editor, redraw, and movement state.
NAMED:  DB      0
MODIF:  DB      0
TRUNC:  DB      0
MSGON:  DB      0
OLDMSG: DB           DB      'Backspace     Delete left of the cursor',13,10
        DB      'Delete        Delete under the cursor',13,10
        DB      'Return        Insert a line break',13,10
        DB      'Tab           Insert spaces to the next tab stop',13,1 0
GAPOPEN:DB     0
CURDRV: DB      1
KEYTMP: DB      0
CURROW: DB      0
EDITLF: DB      0
EDITTAB:DB     0
EDITCLR:DB     0
EDITONE:DB     0
DELTMP: DB      0
CUTLF:  DB      0
FOOTON: DB      0
HEADON: DB      0
MOVOK:  DB      0
MOVCHR: D0,13,10
        DB      '^O  Write file          ^R  Open file',13,10
        DB      '^N  New buffer          ^W  Find text',13,10
        DB      '^K  Cut current line    ^P  Paste line',13,10
        DB      '^Y  Previous page       ^V  Next page',1B      0
DRAWROW:DB      0
OUTCOL: DB      0
DRAWC:  DB      0
INSTMP: DB      0

; Maintained document position and horizontal viewport state.
WANTCOL:DW     0
LINENUM:DW     1
TOTLINES:DW    1
COLNUM: DW      0
LEFTCOL:DW     0
EDITCOL:DW    3,10
        DB      'Esc Exit                ^G Help',13,10,13,10
        DB      'The * in the header means the buffer has changed.',13,10
        DB      'Text capacity: 36 KiB. Files are written with CR/LF.',13,10
        DB      'Search is forward 0
EMITCOL:DW     0
VISCOL: DW      0
TABEND: DW      0

; Physical buffer pointers.  GAPLO/GAPHI delimit unused RAM while GAPOPEN=1.
BUFEND: DW      BUFBEG
CURPTR: DW      BUFBEG
GAPLO:  DW      BUFBEG
GAPHI:  DW      BUFBEG
TOPPTR: DW      BUFB and case-sensitive.',13,10,13,10
        DB      'Press any key to return to the editor.',0

NEWMSG: DB      'New buffer',0
NEWFMSG:DB      'New file',0
READMSG:DB      'File read',0
TRUNMSG:DB      'File is too large; loaded prefix is read-only',0EG
OLDTOP: DW      BUFBEG
DRAWPTR:DW     BUFBEG
LINETMP:DW     0
MOVEST: DW      0
MOVEEND:DW     0
SAVEPTR:DW     0
OUTPTR: DW      0
FINDPTR:DW     0
CANDPTR:DW     0
INPTR:  DW      0
POSPTR: DW      0
GCPTR:  DW      0
OLDLEFT:DW     0
NA
NOSAVEM:DB      'Cannot write a truncated file; open or create a new buffer',0
FULLMSG:DB      'Text buffer full',0
BADNAME:DB      'Invalid CP/M filename',0
WRITEPM:DB      'Write file: ',0
OPENPM: DB      'Open file: ',0
FINDPM: DB      'Find: ',0VOLD: DW      BUFBEG

; Parser, record-I/O, number-printing, and clipboard counters.
BASECNT:DB      0
EXTCNT: DB      0
PART:   DB      0
PARTCHR:DB      0
INLEN:  DB      0
LOADIDX:DB      0
OUTCNT: DB      0
IOERR:  DB      0
LEAD:   DB      0
CLIPLEN:DB      0

; CP/M FCBs and fixed scratch buffers remain in the program's low-memory area.
FILEFCB:DS      36
NEWFCB: DS      36
TMPFCB: DS      36
DISKBUF:DS      128
INBUF:  DS      32
MSGBUF: DS      80
CLIPBUF:DS      255


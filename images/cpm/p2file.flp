╔═Řçççç§═Ř┴H▒╔═.2B!2ćw:B╔!Ds+q*C&␀═Ź:D═╔├␀␀├␀├␀═␀╔╔╔Ű_␀Űůoîg╔_␀{Áoz┤g╔^#VŰ)┬Ź╔_␀{Ľozťg╔i`N#FĹośg╔o&␀Ľoťg╔_␀{ľ_z#×WŰ╔ňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňň; P2FILE.ASM - two-panel CP/M file manager for the Philips P2000C
;
; Assemble on the P2000C with Digital Research's tools:
;     ASM P2FILE
;     LOAD P2FILE
;     P2FILE
;
; Keys: TAB panel, W/S move, SPACE mark, C copy, D delete, R rename,
;    AWCUR
        JMP     KEYLOOP

KUP:    CALL    SAVENAV
        CALL    MOVEUP
        CALL    NAVDRAW
        JMP     KEYLOOP

KDOWN:  CALL    SAVENAV
        CALL    MOVEDOWN
        CALL    NAVDRAW
        JMP     KEYLOOP

KMARK:  CALL    MA   V choose drive, Q quit.
;
; Intel 8080 source.  The program uses only documented CP/M 2.2 BDOS calls
; and documented P2000C terminal escape sequences.

BDOS    EQU     0005H
CONOUT  EQU     02H
DIRIO   EQU     06H
OPENF   EQU     0FH
CLOSEF  ERKFILE
        CALL    REDRAWC
        JMP     KEYLOOP

KCOPY:  CALL    COPYFILES
        JMP     KEYLOOP

KDEL:
        CALL    DELFILES
        JMP     KEYLOOP

KREN:
        CALL    RENFILE
        JMP     KEYLOOP

KDRIVE:CALL    PICKDRIVQU     10H
SFIRST  EQU     11H
SNEXT   EQU     12H
DELETE  EQU     13H
READSEQ EQU     14H
WRITSEQ EQU     15H
MAKEF   EQU     16H
RENAME  EQU     17H
SETDMA  EQU     1AH
FSIZE   EQU     23H

MAXFILE EQU     128
ROWS    EQU     22
FIRST   EQU E
        JMP     MAIN

KQUIT:  MVI     A,0CH
        CALL    PUTC
        LXI     H,BYEMSG
        CALL    PRINTZ
        JMP     0000H

; ---------------------------------------------------------------------------
; Directory loading

LOADL:     1
ENTSIZ  EQU     16
NORMATT EQU     40H
INVATT  EQU     50H
BOLDINV EQU     11H

        ORG     0100H

START:  LXI     SP,STACK
        CALL    LOADL
        CALL    LOADR

MAIN:   CALL    DRAW
KEYLOOP:CALL    GETKEY
        STA     KEY LDA     LDRIVE
        STA     SRCHFCB
        LXI     H,LFILES
        SHLD    BASEPTR
        SHLD    STOREPTR
        LXI     H,LCOUNT
        SHLD    CNTPTR
        CALL    READDIR
        CALL    NORML
        RET

LOADR:  LDA     RDRIVE
TMP
        LDA     MODAL
        ORA     A
        JZ      KEYFOOT
        XRA     A
        STA     MODAL
        CALL    DRAW
        JMP     KEYLOAD
KEYFOOT:
        LDA     FOOTMSG
        ORA     A
        JZ      KEYLOAD
        CALL            STA     SRCHFCB
        LXI     H,RFILES
        SHLD    BASEPTR
        SHLD    STOREPTR
        LXI     H,RCOUNT
        SHLD    CNTPTR
        CALL    READDIR
        CALL    NORMR
        RET

READDIR:
        LXI     H,SRCHFCB+1
  DRAWHELP
KEYLOAD:LDA     KEYTMP
        CPI     'a'
        JC      KEYUP
        CPI     'z'+1
        JNC     KEYUP
        SUI     20H
KEYUP:  CPI     09H
        JZ      KTAB
        CPI     'W'
        JZ      KUP
        CPI     'S'
           MVI     B,11
RDFILL: MVI     M,'?'
        INX     H
        DCR     B
        JNZ     RDFILL
        MVI     B,24
        XRA     A
RDZERO: MOV     M,A
        INX     H
        DCR     B
        JNZ     RDZERO
        LHLD    CNTPTR
      JZ      KDOWN
        CPI     ' '
        JZ      KMARK
        CPI     'C'
        JZ      KCOPY
        CPI     'D'
        JZ      KDEL
        CPI     'R'
        JZ      KREN
        CPI     'V'
        JZ      KDRIVE
        CPI     'Q'     MVI     M,0
        LXI     D,DIRBUF
        MVI     C,SETDMA
        CALL    BDOS
        LXI     D,SRCHFCB
        MVI     C,SFIRST
        CALL    BDOS
RDLOOP: CPI     0FFH
        JZ      RDDONE
        ANI     03H
        RLC
        R
        JZ      KQUIT
        JMP     KEYLOOP

KTAB:   LDA     ACTIVE
        XRI     1
        STA     ACTIVE
        CALL    SETL
        CALL    DRAWHDR
        CALL    DRAWCUR
        CALL    SETR
        CALL    DRAWHDR
        CALL    DRLC
        RLC
        RLC
        RLC
        MOV     E,A
        MVI     D,0
        LXI     H,DIRBUF
        DAD     D
        INX     H
        SHLD    DIRPTR
        LXI     D,8
        DAD     D
        MVI     B,0
        MOV     A,M
        ANI     80H
        JZ      RDATTRS
        MVI     B,1
RDATTRS:INX     H
        MOV     A,M
        ANI     80H
        JZ      RDATTRA
        MOV     A,B
        ORI     2
        MOV     B,A
RDATTRA:INX     H
        MOV     A,M
       INR     A
        STA     SIZEIDX
        JMP     RDSIZE

NORML:  LDA     LCOUNT
        MOV     B,A
        LDA     LCUR
        CALL    NORM
        STA     LCUR
        CPI     ROWS
        JC      NORMZL
        SUI     ROWS-1
        J     ANI     80H
        JZ      RDATTRD
        MOV     A,B
        ORI     4
        MOV     B,A
RDATTRD:MOV     A,B
        STA     ATTRTMP
        LHLD    DIRPTR
        XCHG
        LHLD    STOREPTR
        MVI     B,11
RDCOPY: LDAX    D
 MP     NORMSL
NORMZL: XRA     A
NORMSL:
        STA     LTOP
        RET

NORMR:  LDA     RCOUNT
        MOV     B,A
        LDA     RCUR
        CALL    NORM
        STA     RCUR
        CPI     ROWS
        JC      NORMZR
        SUI     ROW       ANI     7FH
        MOV     M,A
        INX     D
        INX     H
        DCR     B
        JNZ     RDCOPY
        MVI     M,0
        INX     H
        MVI     M,0
        INX     H
        MVI     M,0
        INX     H
        MVI   S-1
        JMP     NORMSR
NORMZR: XRA     A
NORMSR:
        STA     RTOP
        RET

NORM:   MOV     C,A
        MOV     A,B
        ORA     A
        JZ      NORMZERO
        MOV     A,C
        CMP     B
        RC
        MOV     A,B
    M,0
        INX     H
        LDA     ATTRTMP
        MOV     M,A
        INX     H
        SHLD    STOREPTR
        LHLD    CNTPTR
        INR     M
        MOV     A,M
        CPI     MAXFILE
        JZ      RDDONE
        LXI     D,SRCHFCB      DCR     A
        RET
NORMZERO:
        XRA     A
        RET

; ---------------------------------------------------------------------------
; Screen drawing

DRAW:   MVI     A,0CH
        CALL    PUTC
        CALL    DRAWL
        CALL  
        MVI     C,SNEXT
        CALL    BDOS
        JMP     RDLOOP

RDDONE: XRA     A
        STA     SIZEIDX
        LHLD    BASEPTR
        SHLD    WORKLIST
RDSIZE: LDA     SIZEIDX
        MOV     B,A
        LHLD    CNTPTR
        MOV     A  DRAWR
        CALL    DRAWHELP
        RET

DRAWHELP:
        MVI     B,23
        MVI     C,0
        CALL    POS
        MVI     A,INVATT
        CALL    SETATTR
        MVI     A,1BH
        CALL    PUTC
        MVI     A,'K'
        CALL,M
        CMP     B
        RZ
        MOV     A,B
        CALL    WENTRY
        SHLD    ENTRYPTR
        LXI     H,SRCFCB
        CALL    CLEAR36
        LDA     SRCHFCB
        STA     SRCFCB
        LHLD    ENTRYPTR
        XCHG
        LX    PUTC
        LXI     H,HELP
        CALL    PRINTZ
        MVI     A,NORMATT
        CALL    SETATTR
        XRA     A
        STA     FOOTMSG
        RET

DRAWL:  CALL    SETL
        CALL    DRAWP
        RET

SETL:   XRA     A
        I     H,SRCFCB+1
        MVI     B,11
RDSZCP: LDAX    D
        MOV     M,A
        INX     D
        INX     H
        DCR     B
        JNZ     RDSZCP
        LXI     D,SRCFCB
        MVI     C,FSIZE
        CALL    BDOS
        LHLD    ENTRYPSTA     PCOL
        LDA     LDRIVE
        STA     PDRIVE
        LDA     LCOUNT
        STA     PCOUNT
        LDA     LCUR
        STA     PCUR
        LDA     LTOP
        STA     PTOP
        LXI     H,LFILES
        SHLD    PLIST
        LTR
        LXI     D,12
        DAD     D
        LDA     SRCFCB+33
        MOV     M,A
        INX     H
        LDA     SRCFCB+34
        MOV     M,A
        INX     H
        LDA     SRCFCB+35
        MOV     M,A
        LDA     SIZEIDX
    DA     ACTIVE
        XRI     1
        STA     PACTIVE
        RET

DRAWR:  CALL    SETR
        CALL    DRAWP
        RET

SETR:   MVI     A,41
        STA     PCOL
        LDA     RDRIVE
        STA     PDRIVE
        LDA     RCOUNT
        STA     PCOUNT
        LDA     RCUR
        STA     PCUR
        LDA     RTOP
        STA     PTOP
        LXI     H,RFILES
        SHLD    PLIST
        LDA     ACTIVE
        STA     PACTIVE
        RET

DRAWP:  CALL    DRAWHDR
        CALL  MVI     A,FIRST
        STA     DRAWROW
        MVI     A,ROWS
        STA     DRAWLEFT
DPLOOP: LDA     DRAWROW
        CALL    DRAWLINE
        LDA     DRAWIDX
        INR     A
        STA     DRAWIDX
        LDA     DRAWROW
        INR     A    DRAWROWS
        RET

DRAWHDR:
        MVI     A,INVATT
        STA     LINEATT
        LDA     PACTIVE
        ORA     A
        JZ      DPHATTR
        MVI     A,BOLDINV
        STA     LINEATT
DPHATTR:MVI     B,0
        LDA     PCOL
  
        STA     DRAWROW
        LDA     DRAWLEFT
        DCR     A
        STA     DRAWLEFT
        JNZ     DPLOOP
        RET

DRAWLINE:
        LDA     DRAWIDX
        STA     LINEIDX
        MOV     D,A
        LDA     PCOUNT
        CMP        MOV     C,A
        CALL    POS
        LDA     LINEATT
        CALL    SETATTR
        MVI     B,39
DPHCLR: MVI     A,' '
        CALL    PUTC
        DCR     B
        JNZ     DPHCLR
        MVI     B,0
        LDA     PCOL
        MOV     D
        MVI     A,0
        JC      DLVALID
        JZ      DLVALID
        MVI     A,1
DLVALID:STA     LINEOK
        MVI     A,NORMATT
        STA     LINEATT
        LDA     LINEOK
        ORA     A
        JZ      DLATTR
        LDA       C,A
        CALL    POS
        LDA     PACTIVE
        ORA     A
        MVI     A,' '
        JZ      DPHMARK
        MVI     A,'*'
DPHMARK:CALL    PUTC
        LXI     H,DRIVEMSG
        CALL    PRINTZ
        LDA     PDRIVE
        ADI    PACTIVE
        ORA     A
        JZ      DLATTR
        LDA     PCUR
        MOV     D,A
        LDA     LINEIDX
        CMP     D
        JNZ     DLATTR
        MVI     A,INVATT
        STA     LINEATT
DLATTR: LDA     DRAWROW
        MOV       'A'-1
        CALL    PUTC
        MVI     A,':'
        CALL    PUTC
        MVI     A,' '
        CALL    PUTC
        MVI     A,' '
        CALL    PUTC
        LDA     PCOUNT
        CALL    PRINT3
        LXI     H,FILEMSG
        CALL   B,A
        LDA     PCOL
        MOV     C,A
        CALL    POS
        LDA     LINEATT
        CALL    SETATTR
        MVI     B,39
DLBLANK:MVI     A,' '
        CALL    PUTC
        DCR     B
        JNZ     DLBLANK
        LDA     LINEOK
   PRINTZ
        LDA     PCOUNT
        ORA     A
        JZ      DPHPOS
        LDA     PCUR
        INR     A
DPHPOS: CALL    PRINT3
        MVI     A,'/'
        CALL    PUTC
        LDA     PCOUNT
        CALL    PRINT3
        MVI     A,' '      ORA     A
        JZ      DLNORM
        LDA     DRAWROW
        MOV     B,A
        LDA     PCOL
        MOV     C,A
        CALL    POS
        LDA     LINEIDX
        MOV     D,A
        LDA     PACTIVE
        ORA     A
        JZ     
        CALL    PUTC
        LDA     PTOP
        ORA     A
        MVI     A,' '
        JZ      DPHUP
        MVI     A,'^'
DPHUP:  CALL    PUTC
        LDA     PTOP
        ADI     ROWS
        MOV     B,A
        LDA     PCOUNT
        CMP  DLNOCUR
        LDA     PCUR
        CMP     D
        MVI     A,' '
        JNZ     DLCURS
        MVI     A,'>'
        JMP     DLCURS
DLNOCUR:MVI     A,' '
DLCURS: CALL    PUTC
        LDA     LINEIDX
        CALL    PENTRY
        PUSH    H    B
        MVI     A,' '
        JC      DPHDOWN
        JZ      DPHDOWN
        MVI     A,'v'
DPHDOWN:CALL    PUTC
        MVI     A,NORMATT
        CALL    SETATTR
        RET

DRAWROWS:
        LDA     PTOP
        STA     DRAWIDX
      
        LXI     D,11
        DAD     D
        MOV     A,M
        ORA     A
        MVI     A,' '
        JZ      DLSEL
        MVI     A,'*'
DLSEL:  CALL    PUTC
        MVI     A,' '
        CALL    PUTC
        POP     H
        PUSH    H
        CALL    PRINTNAME
        POP     H
        MVI     A,' '
        CALL    PUTC
        PUSH    H
        LXI     D,12
        DAD     D
        MOV     E,M
        INX     H
        MOV     D,M
        XCHG
        LXI     D,7
        ,0
PDLOOP: MOV     A,H
        CMP     D
        JC      PDDONE
        JNZ     PDSUB
        MOV     A,L
        CMP     E
        JC      PDDONE
PDSUB:  MOV     A,L
        SUB     E
        MOV     L,A
        MOV     A,H
        SBB     D
DAD     D
        CALL    HALF
        CALL    HALF
        CALL    HALF
        CALL    PRINT5
        MVI     A,'K'
        CALL    PUTC
        MVI     A,' '
        CALL    PUTC
        POP     H
        LXI     D,15
        DAD     D
             MOV     H,A
        INR     B
        JMP     PDLOOP
PDDONE: MOV     A,B
        ORA     A
        JNZ     PDNUM
        LDA     LEAD
        ORA     A
        MVI     A,' '
        JZ      PDOUT
        MVI     A,'0'
        JMP     PDO   MOV     A,M
        STA     ATTRTMP
        ANI     1
        MVI     A,'-'
        JZ      DLAR
        MVI     A,'R'
DLAR:   CALL    PUTC
        LDA     ATTRTMP
        ANI     2
        MVI     A,'-'
        JZ      DLAS
        MVI     AUT
PDNUM:  MVI     A,1
        STA     LEAD
        MOV     A,B
        ADI     '0'
PDOUT:  CALL    PUTC
        RET

HALF:   ORA     A
        MOV     A,H
        RAR
        MOV     H,A
        MOV     A,L
        RAR
        MOV     L,A
 ,'S'
DLAS:   CALL    PUTC
        LDA     ATTRTMP
        ANI     4
        MVI     A,'-'
        JZ      DLAA
        MVI     A,'A'
DLAA:   CALL    PUTC
DLNORM: MVI     A,NORMATT
        CALL    SETATTR
        RET

PENTRY: LHLD    PLIST
ENTR       RET

SETATTR:MOV     B,A
        MVI     A,1BH
        CALL    PUTC
        MVI     A,'0'
        CALL    PUTC
        MOV     A,B
        CALL    PUTC
        RET

POS:    PUSH    B
        MVI     A,1BH
        CALL    PUTC
        MYA: ORA     A
        RZ
        LXI     D,ENTSIZ
ENTLOOP:DAD     D
        DCR     A
        JNZ     ENTLOOP
        RET

PRINTNAME:
        MVI     B,8
PNBASE: MOV     A,M
        CALL    PUTC
        INX     H
        DCR     B
        JNZVI     A,'Y'
        CALL    PUTC
        POP     B
        MOV     A,B
        ADI     20H
        CALL    PUTC
        MOV     A,C
        ADI     20H
        CALL    PUTC
        RET

STATUS: PUSH    H
        MVI     B,23
        MVI     C     PNBASE
        MVI     A,'.'
        CALL    PUTC
        MVI     B,3
PNEXT:  MOV     A,M
        CALL    PUTC
        INX     H
        DCR     B
        JNZ     PNEXT
        RET

PRINT3: MOV     L,A
        MVI     H,0
        XRA     ,0
        CALL    POS
        MVI     A,1BH
        CALL    PUTC
        MVI     A,'K'
        CALL    PUTC
        POP     H
        CALL    PRINTZ
        MVI     A,1
        STA     FOOTMSG
        RET

; -----------------------------------A
        STA     LEAD
        LXI     D,100
        CALL    PDIV
        LXI     D,10
        CALL    PDIV
        MOV     A,L
        ADI     '0'
        CALL    PUTC
        RET

PRINT5: XRA     A
        STA     LEAD
        LXI     D,1000----------------------------------------
; Navigation and marking

SAVENAV:LDA     ACTIVE
        ORA     A
        JNZ     SAVER
        LDA     LCUR
        STA     OLDCUR
        LDA     LTOP
        STA     OLDTOP
        RET
SAVER:  LDA    0
        CALL    PDIV
        LXI     D,1000
        CALL    PDIV
        LXI     D,100
        CALL    PDIV
        LXI     D,10
        CALL    PDIV
        MOV     A,L
        ADI     '0'
        CALL    PUTC
        RET

PDIV:   MVI     B RCUR
        STA     OLDCUR
        LDA     RTOP
        STA     OLDTOP
        RET

NAVDRAW:LDA     ACTIVE
        ORA     A
        JNZ     NAVR
        CALL    SETL
        JMP     NAVSET
NAVR:   CALL    SETR
NAVSET: LDA     PCUR
        MOV     B,A
        LDA     OLDCUR
        CMP     B
        JNZ     NAVCHG
        LDA     PTOP
        MOV     B,A
        LDA     OLDTOP
        CMP     B
        RZ
NAVCHG:CALL    DRAWHDR
        LDA     PTOP
        MOV     B,A
        LDA COUNT
        MOV     B,A
        LDA     LCUR
        INR     A
        CMP     B
        RNC
        STA     LCUR
        MOV     B,A
        LDA     LTOP
        ADI     ROWS
        CMP     B
        JC      LDSCROLL
        JZ      LDSCROL    OLDTOP
        CMP     B
        JZ      NAVROWS
        CALL    DRAWROWS
        RET
NAVROWS:
        LDA     OLDCUR
        STA     DRAWIDX
        MOV     B,A
        LDA     PTOP
        MOV     C,A
        MOV     A,B
        SUB     CL
        RET
LDSCROLL:
        LDA     LTOP
        INR     A
        STA     LTOP
        RET
RDOWN:  LDA     RCOUNT
        MOV     B,A
        LDA     RCUR
        INR     A
        CMP     B
        RNC
        STA     RCUR
        MOV  
        ADI     FIRST
        STA     DRAWROW
        CALL    DRAWLINE
        LDA     PCUR
        MOV     B,A
        LDA     OLDCUR
        CMP     B
        RZ
        MOV     A,B
        STA     DRAWIDX
        MOV     B,A
        LDA       B,A
        LDA     RTOP
        ADI     ROWS
        CMP     B
        JC      RDSCROLL
        JZ      RDSCROLL
        RET
RDSCROLL:
        LDA     RTOP
        INR     A
        STA     RTOP
        RET

MARKFILE:
        LDA     ACTI PTOP
        MOV     C,A
        MOV     A,B
        SUB     C
        ADI     FIRST
        STA     DRAWROW
        CALL    DRAWLINE
        RET

REDRAWC:LDA     ACTIVE
        ORA     A
        JNZ     REDRAWR
        CALL    SETL
        JVE
        ORA     A
        JNZ     RMARK
        LDA     LCOUNT
        ORA     A
        RZ
        LDA     LCUR
        LXI     H,LFILES
        JMP     DOMARK
RMARK:  LDA     RCOUNT
        ORA     A
        RZ
        LDA     RCUR
      MP     REDSET
REDRAWR:CALL    SETR
REDSET: CALL    DRAWCUR
        RET

DRAWCUR:LDA     PCOUNT
        ORA     A
        RZ
        LDA     PCUR
        STA     DRAWIDX
        MOV     B,A
        LDA     PTOP
        MOV     C,A
        MOV    LXI     H,RFILES
DOMARK: SHLD    WORKLIST
        CALL    WENTRY
        LXI     D,11
        DAD     D
        MOV     A,M
        XRI     1
        MOV     M,A
        RET

WENTRY: LHLD    WORKLIST
        JMP     ENTRYA

PICKDRIVE:
        A,B
        SUB     C
        ADI     FIRST
        STA     DRAWROW
        CALL    DRAWLINE
        RET

MOVEUP: LDA     ACTIVE
        ORA     A
        JNZ     RUP
        LDA     LCUR
        ORA     A
        RZ
        DCR     A
       CALL    SHOWDRIVES
PDKEY:  CALL    GETKEY
        CPI     1BH
        RZ
        CPI     'a'
        JC      PDUP
        CPI     'z'+1
        JNC     PDUP
        SUI     20H
PDUP:   CPI     'A'
        JC      PDKEY
        CPI     'G'
      STA     LCUR
        MOV     B,A
        LDA     LTOP
        MOV     C,A
        MOV     A,B
        CMP     C
        RNC
        STA     LTOP
        RET
RUP:    LDA     RCUR
        ORA     A
        RZ
        DCR     A
        STA         JNC     PDKEY
        SUI     'A'-1
        MOV     B,A
        LDA     ACTIVE
        ORA     A
        JNZ     PDRIGHT
        MOV     A,B
        STA     LDRIVE
        CALL    LOADL
        RET
PDRIGHT:MOV     A,B
        STA     RDRIV  RCUR
        MOV     B,A
        LDA     RTOP
        MOV     C,A
        MOV     A,B
        CMP     C
        RNC
        STA     RTOP
        RET

MOVEDOWN:
        LDA     ACTIVE
        ORA     A
        JNZ     RDOWN
        LDA     LE
        CALL    LOADR
        RET

SHOWDRIVES:
        CALL    MODBOX
        MVI     B,9
        MVI     C,34
        CALL    POS
        LXI     H,DRVHEAD
        CALL    PRINTZ
        MVI     B,10
        MVI     C,29
        CALL    POS
        LXI     H,DRVOPTS
        CALL    PRINTZ
        MVI     B,11
        MVI     C,27
        CALL    POS
        LXI     H,DRVPROMPT
        CALL    PRINTZ
        MVI     A,NORMATT
        CALL    SETATTR
        RET

; ----------------A     SCUR
        LXI     H,LFILES
        SHLD    SLIST
        RET
SRCRIGHT:
        LDA     RDRIVE
        STA     SRCDRIVE
        LDA     LDRIVE
        STA     DSTDRIVE
        LDA     RCOUNT
        STA     SCOUNT
        LDA     RCUR
 -----------------------------------------------------------
; Copy

COPYFILES:
        CALL    SETSOURCE
        LDA     SRCDRIVE
        MOV     B,A
        LDA     DSTDRIVE
        CMP     B
        JNZ     CPDIFF
        LXI     H,SAMEDRV
          STA     SCUR
        LXI     H,RFILES
        SHLD    SLIST
        RET

FINDSEL:XRA     A
        STA     LOOPIDX
FSLOOP: LDA     LOOPIDX
        MOV     B,A
        LDA     SCOUNT
        CMP     B
        JZ      FSNONE
        MOV        CALL    STATUS
        RET
CPDIFF:
        LDA     SCOUNT
        ORA     A
        JNZ     CPHAVE
        LXI     H,NOFILES
        CALL    STATUS
        RET
CPHAVE: CALL    FINDSEL
        STA     SELMODE
        CALL    COUNTCP
         A,B
        CALL    SENTRY
        LXI     D,11
        DAD     D
        MOV     A,M
        ORA     A
        MVI     A,1
        RNZ
        LDA     LOOPIDX
        INR     A
        STA     LOOPIDX
        JMP     FSLOOP
FSNONE: XRA     A XRA     A
        STA     OPERROR
        STA     LOOPIDX
        STA     CPNUM
CPLOOP: LDA     LOOPIDX
        MOV     B,A
        LDA     SCOUNT
        CMP     B
        JZ      CPDONE
        LDA     SELMODE
        ORA     A
        JZ    
        RET

COUNTCP:LDA     SELMODE
        ORA     A
        JNZ     CCSEL
        MVI     A,1
        STA     CPTOTAL
        RET
CCSEL:  XRA     A
        STA     CPTOTAL
        STA     LOOPIDX
CCLOOP: LDA     LOOPIDX
        MOV     B,A  CPCUR
        MOV     A,B
        CALL    SENTRY
        LXI     D,11
        DAD     D
        MOV     A,M
        ORA     A
        JZ      CPNEXT
        JMP     CPONE
CPCUR:  LDA     SCUR
        CMP     B
        JNZ     CPNEXT
CPONE:  M
        LDA     SCOUNT
        CMP     B
        RZ
        MOV     A,B
        CALL    SENTRY
        LXI     D,11
        DAD     D
        MOV     A,M
        ORA     A
        JZ      CCNEXT
        LDA     CPTOTAL
        INR     A
     OV     A,B
        CALL    SENTRY
        SHLD    ENTRYPTR
        LDA     CPNUM
        INR     A
        STA     CPNUM
        CALL    SHOWCOPY
        CALL    COPYONE
CPNEXT: LDA     LOOPIDX
        INR     A
        STA     LOOPIDX
        J   STA     CPTOTAL
CCNEXT: LDA     LOOPIDX
        INR     A
        STA     LOOPIDX
        JMP     CCLOOP

SENTRY: LHLD    SLIST
        JMP     ENTRYA

COPYONE:
        CALL    BUILDFCBS
        LXI     D,DIRBUF
        MVI     C,SETDMA
   MP     CPLOOP
CPDONE: CALL    LOADL
        CALL    LOADR
        CALL    DRAW
        LDA     OPERROR
        ORA     A
        JNZ     SHOWCPERR
        CALL    SHOWCPDONE
        RET

SHOWCPERR:
        CALL    SHOWERROR
        RET

SETSO     CALL    BDOS
        LXI     D,DSTFCB
        MVI     C,SFIRST
        CALL    BDOS
        CPI     0FFH
        JZ      CPNEW
        CALL    ASKOVER
        ORA     A
        RZ
        CALL    BUILDFCBS
        LXI     D,DSTFCB
        MURCE:
        LDA     ACTIVE
        ORA     A
        JNZ     SRCRIGHT
        LDA     LDRIVE
        STA     SRCDRIVE
        LDA     RDRIVE
        STA     DSTDRIVE
        LDA     LCOUNT
        STA     SCOUNT
        LDA     LCUR
        STVI     C,DELETE
        CALL    BDOS
CPNEW:  CALL    BUILDFCBS
        LXI     D,SRCFCB
        MVI     C,OPENF
        CALL    BDOS
        CPI     0FFH
        JZ      CPFAIL
        LXI     D,DSTFCB
        MVI     C,MAKEF
        CALL    BDOS
        CPI     0FFH
        JZ      CPMKERR
CPRECORD:
        LXI     D,BUFFER
        MVI     C,SETDMA
        CALL    BDOS
        LXI     D,SRCFCB
        MVI     C,READSEQ
        CALL    BDOS
        ORA     A
        JNZ     CPCLOSE
   Y:
        CALL    MODBOX
        MVI     B,9
        MVI     C,32
        CALL    POS
        LXI     H,CPHEAD
        CALL    PRINTZ
        MVI     B,10
        MVI     C,22
        CALL    POS
        LXI     H,CPFILE
        CALL    PRINTZ     LXI     D,BUFFER
        MVI     C,SETDMA
        CALL    BDOS
        LXI     D,DSTFCB
        MVI     C,WRITSEQ
        CALL    BDOS
        ORA     A
        JZ      CPRECORD
        MVI     A,1
        STA     OPERROR
CPCLOSE:LXI     D,D
        LHLD    ENTRYPTR
        CALL    PRINTSHORT
        MVI     B,11
        MVI     C,29
        CALL    POS
        LXI     H,CPSTEP
        CALL    PRINTZ
        LDA     CPNUM
        CALL    PRINT3
        LXI     H,CPOF
        CALL   STFCB
        MVI     C,CLOSEF
        CALL    BDOS
        LXI     D,SRCFCB
        MVI     C,CLOSEF
        CALL    BDOS
        RET
CPMKERR:LXI     D,SRCFCB
        MVI     C,CLOSEF
        CALL    BDOS
CPFAIL: MVI     A,1
        STA     OPE PRINTZ
        LDA     CPTOTAL
        CALL    PRINT3
        MVI     B,12
        MVI     C,34
        CALL    POS
        LXI     H,CPWAIT
        CALL    PRINTZ
        MVI     A,NORMATT
        CALL    SETATTR
        RET

SHOWCPDONE:
   RROR
        RET

ASKOVER:CALL    MODBOX
        MVI     B,10
        MVI     C,22
        CALL    POS
        LXI     H,OVER1
        CALL    PRINTZ
        LHLD    ENTRYPTR
        CALL    PRINTSHORT
        LXI     H,OVER2
        CALL    PR     CALL    MODBOX
        MVI     B,10
        MVI     C,33
        CALL    POS
        LXI     H,COPYOK
        CALL    PRINTZ
        JMP     SHOWACK

SHOWERROR:
        CALL    MODBOX
        MVI     B,10
        MVI     C,25
        CALL INTZ
        MVI     A,NORMATT
        CALL    SETATTR
OVKEY:  CALL    GETKEY
        CPI     'a'
        JC      OVUP
        CPI     'z'+1
        JNC     OVUP
        SUI     20H
OVUP:   CPI     'Y'
        JZ      OVYES
        CPI     'N'
   POS
        LXI     H,COPYERR
        CALL    PRINTZ
SHOWACK:MVI     B,11
        MVI     C,31
        CALL    POS
        LXI     H,CPACK
        CALL    PRINTZ
        MVI     A,NORMATT
        CALL    SETATTR
        MVI     A,1
        ST        JNZ     OVKEY
        XRA     A
        RET
OVYES:  CALL    SHOWCOPY
        MVI     A,1
        RET

; Four-row inverse-video copy modal. It deliberately stays clear of row 23,
; so the keyboard legend remains visible throughout the operatA     MODAL
        RET

BUILDFCBS:
        LXI     H,SRCFCB
        CALL    CLEAR36
        LXI     H,DSTFCB
        CALL    CLEAR36
        LDA     SRCDRIVE
        STA     SRCFCB
        LDA     DSTDRIVE
        STA     DSTFCB
        LHLD  ion.
MODBOX: MVI     B,9
MBLOOP:CALL    MODROW
        INR     B
        MOV     A,B
        CPI     13
        JNZ     MBLOOP
        RET

MODROW:MOV     A,B
        STA     MODROWNO
        MVI     C,20
        CALL    POS
        MVI     A,  ENTRYPTR
        XCHG
        LXI     H,SRCFCB+1
        MVI     B,11
BFSRC:  LDAX    D
        MOV     M,A
        INX     D
        INX     H
        DCR     B
        JNZ     BFSRC
        LHLD    ENTRYPTR
        XCHG
        LXI     H,DSINVATT
        CALL    SETATTR
        MVI     D,40
MRCLEAR:MVI     A,' '
        CALL    PUTC
        DCR     D
        JNZ     MRCLEAR
        LDA     MODROWNO
        MOV     B,A
        MVI     C,20
        CALL    POS
        RET

SHOWCOPTFCB+1
        MVI     B,11
BFDST:  LDAX    D
        MOV     M,A
        INX     D
        INX     H
        DCR     B
        JNZ     BFDST
        RET

; ---------------------------------------------------------------------------
; Delete

DELFILES:
        CALL    SETSOURCE
        LDA     SCOUNT
        ORA     A
        JNZ     DELHAVE
        LXI     H,NOFILES
        CALL    STATUS
        RET
DELHAVE:CALL    FINDSEL
        STA     SELMODE
        LXI     H,DELASK
        CA  H,LFILES
        JMP     RENSET
RENR:   LDA     RCOUNT
        ORA     A
        JZ      RENNONE
        LDA     RDRIVE
        STA     SRCDRIVE
        LDA     RCUR
        LXI     H,RFILES
RENSET: SHLD    WORKLIST
        CALL    WENTRY
    LL    STATUS
        CALL    YESNO
        ORA     A
        RZ
        XRA     A
        STA     OPERROR
        STA     LOOPIDX
DELLOOP:LDA     LOOPIDX
        MOV     B,A
        LDA     SCOUNT
        CMP     B
        JZ      DELDONE
         SHLD    ENTRYPTR
        CALL    GETNEW
        ORA     A
        RZ
        CALL    NEWEXISTS
        ORA     A
        JZ      RENDO
        LXI     H,NAMEUSED
        CALL    STATUS
        RET
RENDO:  CALL    BUILDREN
        LXI     D,S   LDA     SELMODE
        ORA     A
        JZ      DELCUR
        MOV     A,B
        CALL    SENTRY
        LXI     D,11
        DAD     D
        MOV     A,M
        ORA     A
        JZ      DELNEXT
        JMP     DELONE
DELCUR: LDA     SCRCFCB
        MVI     C,RENAME
        CALL    BDOS
        CPI     0FFH
        LXI     H,RENOK
        JNZ     RENRES
        LXI     H,RENERR
RENRES: PUSH    H
        CALL    LOADL
        CALL    LOADR
        CALL    DRAW
        POP     HUR
        CMP     B
        JNZ     DELNEXT
DELONE: MOV     A,B
        CALL    SENTRY
        SHLD    ENTRYPTR
        CALL    BUILDSRC
        LXI     D,SRCFCB
        MVI     C,DELETE
        CALL    BDOS
        CPI     0FFH
        JNZ    
        CALL    STATUS
        RET
RENNONE:LXI     H,NOFILES
        CALL    STATUS
        RET

GETNEW: LXI     H,NEWBUF
        MVI     M,0
        SHLD    INPTR
        XRA     A
        STA     INLEN
        LXI     H,NEWASK
        CALL  DELNEXT
        MVI     A,1
        STA     OPERROR
DELNEXT:LDA     LOOPIDX
        INR     A
        STA     LOOPIDX
        JMP     DELLOOP
DELDONE:CALL    LOADL
        CALL    LOADR
        CALL    DRAW
        LDA     OPERROR
        ORA     STATUS
GNKEY:  CALL    GETKEY
        CPI     1BH
        JZ      GNCANCEL
        CPI     0DH
        JZ      GNDONE
        CPI     08H
        JZ      GNBACK
        CPI     7FH
        JZ      GNBACK
        CPI     'a'
        JC      GN   A
        LXI     H,DELOK
        JZ      DELSTAT
        LXI     H,DELERR
DELSTAT:CALL    STATUS
        RET

BUILDSRC:
        LXI     H,SRCFCB
        CALL    CLEAR36
        LDA     SRCDRIVE
        STA     SRCFCB
        LHLD    ENTRYPTUP
        CPI     'z'+1
        JNC     GNUP
        SUI     20H
GNUP:   CPI     21H
        JC      GNKEY
        CPI     7FH
        JNC     GNKEY
        MOV     B,A
        LDA     INLEN
        CPI     12
        JNC     GNKEY
        MOVR
        XCHG
        LXI     H,SRCFCB+1
        MVI     B,11
BSONE:  LDAX    D
        MOV     M,A
        INX     D
        INX     H
        DCR     B
        JNZ     BSONE
        RET

; ----------------------------------------------------     A,B
        LHLD    INPTR
        MOV     M,A
        INX     H
        MVI     M,0
        SHLD    INPTR
        LDA     INLEN
        INR     A
        STA     INLEN
        MOV     A,B
        CALL    PUTC
        JMP     GNKEY
GNBACK: -----------------------
; Rename

RENFILE:LDA     ACTIVE
        ORA     A
        JNZ     RENR
        LDA     LCOUNT
        ORA     A
        JZ      RENNONE
        LDA     LDRIVE
        STA     SRCDRIVE
        LDA     LCUR
        LXI   LDA     INLEN
        ORA     A
        JZ      GNKEY
        DCR     A
        STA     INLEN
        LHLD    INPTR
        DCX     H
        SHLD    INPTR
        MVI     M,0
        MVI     A,08H
        CALL    PUTC
        MVI     A,' '
        CALL    PUTC
        MVI     A,08H
        CALL    PUTC
        JMP     GNKEY
GNDONE: CALL    PARSENEW
        RET
GNCANCEL:
        XRA     A
        RET

PARSENEW:
        LXI     H,NEWNAME
        MVI     B,11
        MVI     A,' '
PNRIVE
        STA     DSTFCB
        LXI     H,NEWNAME
        LXI     D,DSTFCB+1
        MVI     B,11
NECOPY: MOV     A,M
        STAX    D
        INX     H
        INX     D
        DCR     B
        JNZ     NECOPY
        LXI     D,DIRBUF
  CLR:  MOV     M,A
        INX     H
        DCR     B
        JNZ     PNCLR
        LXI     H,NEWBUF
        LXI     D,NEWNAME
        MVI     B,0
        MVI     C,0
PNLOOP: MOV     A,M
        ORA     A
        JZ      PNEND
        CPI     '.      MVI     C,SETDMA
        CALL    BDOS
        LXI     D,DSTFCB
        MVI     C,SFIRST
        CALL    BDOS
        CPI     0FFH
        MVI     A,0
        RZ
        MVI     A,1
        RET

BUILDREN:
        CALL    BUILDSRC
        '
        JZ      PNDOT
        CPI     '*'
        JZ      PNBAD
        CPI     '?'
        JZ      PNBAD
        CPI     '/'
        JZ      PNBAD
        CPI     ':'
        JZ      PNBAD
        CPI     ';'
        JZ      PNBAD
        CPLDA     SRCDRIVE
        STA     SRCFCB+16
        LXI     H,NEWNAME
        LXI     D,SRCFCB+17
        MVI     B,11
BRCOPY: MOV     A,M
        STAX    D
        INX     H
        INX     D
        DCR     B
        JNZ     BRCOPY
        RETI     '<'
        JZ      PNBAD
        CPI     '='
        JZ      PNBAD
        CPI     '>'
        JZ      PNBAD
        CPI     '['
        JZ      PNBAD
        CPI     ']'
        JZ      PNBAD
        MOV     A,C
        ORA     A
      

; ---------------------------------------------------------------------------
; Common helpers

YESNO:  CALL    GETKEY
        CPI     'a'
        JC      YNUP
        CPI     'z'+1
        JNC     YNUP
        SUI     20H
YNUP:   CPI     'Y'
  JNZ     PNEXTC
        MOV     A,B
        CPI     8
        JNC     PNBAD
        MOV     A,M
        STAX    D
        INX     D
        INR     B
        INX     H
        JMP     PNLOOP
PNEXTC: MOV     A,B
        CPI     3
        JNC           JZ      YNYES
        CPI     'N'
        JNZ     YESNO
        XRA     A
        RET
YNYES:  MVI     A,1
        RET

CLEAR36:MVI     B,36
        XRA     A
C36LOOP:MOV     M,A
        INX     H
        DCR     B
        JNZ     C36LO  PNBAD
        MOV     A,M
        STAX    D
        INX     D
        INR     B
        INX     H
        JMP     PNLOOP
PNDOT:  MOV     A,C
        ORA     A
        JNZ     PNBAD
        MOV     A,B
        ORA     A
        JZ      PNBAD
OP
        RET

PRINTSHORT:
        PUSH    H
        MVI     B,8
PSBASE: MOV     A,M
        CPI     ' '
        CZ      PSNOP
        CNZ     PUTC
        INX     H
        DCR     B
        JNZ     PSBASE
        POP     H
        LXI             MVI     C,1
        MVI     B,0
        LXI     D,NEWNAME+8
        INX     H
        JMP     PNLOOP
PNEND:  MOV     A,C
        ORA     A
        JZ      PNBCHK
        MOV     A,B
        ORA     A
        JZ      PNBAD
PNBCHK: LDA    D,8
        DAD     D
        MOV     A,M
        CPI     ' '
        RZ
        MVI     A,'.'
        CALL    PUTC
        MVI     B,3
PSEXT:  MOV     A,M
        CPI     ' '
        CZ      PSNOP
        CNZ     PUTC
        INX     H
       NEWNAME
        CPI     ' '
        JZ      PNBAD
        MVI     A,1
        RET
PNBAD:  LXI     H,BADNAME
        CALL    STATUS
        XRA     A
        RET

NEWEXISTS:
        LXI     H,DSTFCB
        CALL    CLEAR36
        LDA     SRCD  DCR     B
        JNZ     PSEXT
PSNOP:  RET

PRINTZ: MOV     A,M
        ORA     A
        RZ
        CALL    PUTC
        INX     H
        JMP     PRINTZ

PUTC:   PUSH    B
        PUSH    D
        PUSH    H
        MOV     E,A
        MVI     C,CONOUT
        CALL    BDOS
        POP     H
        POP     D
        POP     B
        RET

GETKEY: PUSH    B
        PUSH    D
        PUSH    H
GKWAIT: MVI     E,0FFH
        MVI     C,DIRIO
        CALL    BDOS
        ORA     :DB      NORMATT
OLDCUR: DB      0
OLDTOP: DB      0

SRCDRIVE:
        DB      0
DSTDRIVE:
        DB      0
SCOUNT: DB      0
SCUR:   DB      0
SELMODE:DB      0
LOOPIDX:DB      0
OPERROR:DB      0
CPTOTAL:DB      0
CPNUM:  DB      0
MODALA
        JZ      GKWAIT
        POP     H
        POP     D
        POP     B
        RET


╔═Řçççç§═Ř┴H▒╔═.2B!2ćw:B╔!Ds+q*C&␀═Ź:D═╔├␀␀├␀├␀═␀╔╔╔Ű_␀Űůoîg╔_␀{Áoz┤g╔^#VŰ)┬Ź╔_␀{Ľozťg╔i`N#FĹośg╔o&␀Ľoťg╔_␀{ľ_z#×WŰ╔ňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňň; P2FILE.ASM - two-panel CP/M file manager for the Philips P2000C
;
; Assemble on the P2000C with Digital Research's tools:
;     ASM P2FILE
;     LOAD P2FILE
;     P2FILE
;
; Keys: TAB panel, W/S move, SPACE mark, C copy, D delete, R rename,
;    ALL    SETL
        CALL    DRAWHDR
        CALL    DRAWCUR
        CALL    SETR
        CALL    DRAWHDR
        CALL    DRAWCUR
        JMP     KEYLOOP

KUP:    CALL    SAVENAV
        CALL    MOVEUP
        CALL    NAVDRAW
        JMP     KEYL   V choose drive, Q quit.
;
; Intel 8080 source.  The program uses only documented CP/M 2.2 BDOS calls
; and documented P2000C terminal escape sequences.

BDOS    EQU     0005H
CONOUT  EQU     02H
DIRIO   EQU     06H
OPENF   EQU     0FH
CLOSEF  EOOP

KDOWN:  CALL    SAVENAV
        CALL    MOVEDOWN
        CALL    NAVDRAW
        JMP     KEYLOOP

KMARK:  CALL    MARKFILE
        CALL    REDRAWC
        JMP     KEYLOOP

KCOPY:  CALL    COPYFILES
        JMP     KEYLOOP

KDEL:
       QU     10H
SFIRST  EQU     11H
SNEXT   EQU     12H
DELETE  EQU     13H
READSEQ EQU     14H
WRITSEQ EQU     15H
MAKEF   EQU     16H
RENAME  EQU     17H
SETDMA  EQU     1AH
FSIZE   EQU     23H

MAXFILE EQU     128
ROWS    EQU     22
FIRST   EQU  CALL    DELFILES
        JMP     KEYLOOP

KREN:
        CALL    RENFILE
        JMP     KEYLOOP

KDRIVE:CALL    PICKDRIVE
        JMP     MAIN

KQUIT:  MVI     A,0CH
        CALL    PUTC
        LXI     H,BYEMSG
        CALL    PRINTZ
          1
ENTSIZ  EQU     15
NORMATT EQU     40H
INVATT  EQU     50H
BOLDINV EQU     11H

        ORG     0100H

START:  LXI     SP,STACK
        LDA     LDRIVE
        CALL    SHOWSTART
        CALL    LOADL
        CALL    DRAWSHELL
        LDA   JMP     0000H

; ---------------------------------------------------------------------------
; Directory loading

LOADL:  LDA     LDRIVE
        STA     SRCHFCB
        LXI     H,LFILES
        SHLD    STOREPTR
        LXI     H,LCOUNT
            RDRIVE
        CALL    SHOWREAD
        CALL    LOADR

MAIN:   CALL    DRAW
KEYLOOP:CALL    GETKEY
        STA     KEYTMP
        LDA     MODAL
        ORA     A
        JZ      KEYFOOT
        XRA     A
        STA     MODAL
        CALL  SHLD    CNTPTR
        CALL    READDIR
        CALL    NORML
        RET

LOADR:  LDA     RDRIVE
        STA     SRCHFCB
        LXI     H,RFILES
        SHLD    STOREPTR
        LXI     H,RCOUNT
        SHLD    CNTPTR
        CALL    READDIR
   DRAW
        JMP     KEYLOAD
KEYFOOT:
        LDA     FOOTMSG
        ORA     A
        JZ      KEYLOAD
        CALL    DRAWHELP
KEYLOAD:LDA     KEYTMP
        CPI     'a'
        JC      KEYUP
        CPI     'z'+1
        JNC     KEYUP
           CALL    NORMR
        RET

READDIR:
        LXI     H,SRCHFCB+1
        MVI     B,11
RDFILL: MVI     M,'?'
        INX     H
        DCR     B
        JNZ     RDFILL
        MVI     B,24
        XRA     A
RDZERO: MOV     M,A
        INX    SUI     20H
KEYUP:  CPI     09H
        JZ      KTAB
        CPI     'W'
        JZ      KUP
        CPI     'S'
        JZ      KDOWN
        CPI     ' '
        JZ      KMARK
        CPI     'C'
        JZ      KCOPY
        CPI     'D'
      H
        DCR     B
        JNZ     RDZERO
        LHLD    CNTPTR
        MVI     M,0
        LXI     D,DIRBUF
        MVI     C,SETDMA
        CALL    BDOS
        LXI     D,SRCHFCB
        MVI     C,SFIRST
        CALL    BDOS
RDLOOP: CPI       JZ      KDEL
        CPI     'R'
        JZ      KREN
        CPI     'V'
        JZ      KDRIVE
        CPI     'Q'
        JZ      KQUIT
        JMP     KEYLOOP

KTAB:   LDA     ACTIVE
        XRI     1
        STA     ACTIVE
        C     0FFH
        JZ      RDDONE
        ANI     03H
        RLC
        RLC
        RLC
        RLC
        RLC
        MOV     E,A
        MVI     D,0
        LXI     H,DIRBUF
        DAD     D
        INX     H
        SHLD    DIRPTR
        LHLD    DIRPTR
        XCHG
        LHLD    STOREPTR
        MVI     B,11
RDCOPY: LDAX    D
        ANI     7FH
        MOV     M,A
        INX     D
        INX     H
        DCR     B
        JNZ     RDCOPY
        MVI     M,0
        INX        SUI     ROWS-1
        JMP     NORMSR
NORMZR: XRA     A
NORMSR:
        STA     RTOP
        RET

NORM:   MOV     C,A
        MOV     A,B
        ORA     A
        JZ      NORMZERO
        MOV     A,C
        CMP     B
        RC
         H
        MVI     M,0
        INX     H
        MVI     M,0
        INX     H
        MVI     M,0FFH
        INX     H
        SHLD    STOREPTR
        LHLD    CNTPTR
        INR     M
        MOV     A,M
        CPI     MAXFILE
        JZ    MOV     A,B
        DCR     A
        RET
NORMZERO:
        XRA     A
        RET

; ---------------------------------------------------------------------------
; Screen drawing

DRAW:   CALL    DRAWSHELL
        CALL    FILLSIZES
        RE     RDDONE
        LXI     D,SRCHFCB
        MVI     C,SNEXT
        CALL    BDOS
        JMP     RDLOOP

RDDONE: RET

; Resolve an entry's size only when its row becomes active. Byte 14 of the
; panel entry is FFH until BDOS function 35 has popuT

DRAWSHELL:
        MVI     A,0CH
        CALL    PUTC
        CALL    DRAWL
        CALL    DRAWR
        CALL    DRAWHELP
        RET

; Populate exact sizes only for the two visible windows. The initial panel
; drawing therefore appears immlated bytes 12-14.
ENSURESIZE:
        LDA     LINEIDX
        CALL    PENTRY
        SHLD    ENTRYPTR
        LXI     D,14
        DAD     D
        MOV     A,M
        CPI     0FFH
        RNZ
        LXI     H,SRCFCB
        CALL    CLEAR36
ediately, followed by one visibly updated row
; per BDOS function-35 query. Cached rows are skipped on later redraws.
FILLSIZES:
        CALL    SETL
        CALL    FILLPANEL
        CALL    SETR
        CALL    FILLPANEL
        RET

FILLPANEL:        LDA     PDRIVE
        STA     SRCFCB
        LHLD    ENTRYPTR
        XCHG
        LXI     H,SRCFCB+1
        MVI     B,11
RDSZCP: LDAX    D
        MOV     M,A
        INX     D
        INX     H
        DCR     B
        JNZ     RDSZC
        LDA     PTOP
        STA     SZIDX
        MVI     A,ROWS
        STA     SZLEFT
FZLOOP: LDA     SZLEFT
        ORA     A
        RZ
        LDA     SZIDX
        MOV     B,A
        LDA     PCOUNT
        CMP     B
        RC
        P
        LXI     D,SRCFCB
        MVI     C,FSIZE
        CALL    BDOS
        LHLD    ENTRYPTR
        LXI     D,12
        DAD     D
        LDA     SRCFCB+33
        MOV     M,A
        INX     H
        LDA     SRCFCB+34
        MOV     M,ARZ
        MOV     A,B
        CALL    PENTRY
        LXI     D,14
        DAD     D
        MOV     A,M
        CPI     0FFH
        JNZ     FZNEXT
        LDA     SZIDX
        STA     LINEIDX
        CALL    ENSURESIZE
        LDA     SZIDX

        INX     H
        LDA     SRCFCB+35
        MOV     M,A
        RET

NORML:  LDA     LCOUNT
        MOV     B,A
        LDA     LCUR
        CALL    NORM
        STA     LCUR
        CPI     ROWS
        JC      NORMZL
        SUI            STA     DRAWIDX
        MOV     B,A
        LDA     PTOP
        MOV     C,A
        MOV     A,B
        SUB     C
        ADI     FIRST
        STA     DRAWROW
        CALL    DRAWLINE
FZNEXT: LDA     SZIDX
        INR     A
        STA ROWS-1
        JMP     NORMSL
NORMZL: XRA     A
NORMSL:
        STA     LTOP
        RET

NORMR:  LDA     RCOUNT
        MOV     B,A
        LDA     RCUR
        CALL    NORM
        STA     RCUR
        CPI     ROWS
        JC      NORMZR
      SZIDX
        LDA     SZLEFT
        DCR     A
        STA     SZLEFT
        JMP     FZLOOP

DRAWHELP:
        MVI     B,23
        MVI     C,0
        CALL    POS
        MVI     A,INVATT
        CALL    SETATTR
        MVI     A,1BH
        CALL    PUTC
        MVI     A,'K'
        CALL    PUTC
        LXI     H,HELP
        CALL    PRINTZ
        MVI     A,NORMATT
        CALL    SETATTR
        XRA     A
        STA     FOOTMSG
        RET

DRAWL:  CALL    SETL
        CAL    PRINT3
        LXI     H,FILEMSG
        CALL    PRINTZ
        LDA     PCOUNT
        ORA     A
        JZ      DPHPOS
        LDA     PCUR
        INR     A
DPHPOS: CALL    PRINT3
        MVI     A,'/'
        CALL    PUTC
        LDA    LL    DRAWP
        RET

SETL:   XRA     A
        STA     PCOL
        LDA     LDRIVE
        STA     PDRIVE
        LDA     LCOUNT
        STA     PCOUNT
        LDA     LCUR
        STA     PCUR
        LDA     LTOP
        STA     PTOP
    PCOUNT
        CALL    PRINT3
        MVI     A,' '
        CALL    PUTC
        LDA     PTOP
        ORA     A
        MVI     A,' '
        JZ      DPHUP
        MVI     A,'^'
DPHUP:  CALL    PUTC
        LDA     PTOP
        ADI     ROWS
       LXI     H,LFILES
        SHLD    PLIST
        LDA     ACTIVE
        XRI     1
        STA     PACTIVE
        RET

DRAWR:  CALL    SETR
        CALL    DRAWP
        RET

SETR:   MVI     A,41
        STA     PCOL
        LDA     RDRIVE      MOV     B,A
        LDA     PCOUNT
        CMP     B
        MVI     A,' '
        JC      DPHDOWN
        JZ      DPHDOWN
        MVI     A,'v'
DPHDOWN:CALL    PUTC
        MVI     A,NORMATT
        CALL    SETATTR
        RET

DRAWROWS:
        STA     PDRIVE
        LDA     RCOUNT
        STA     PCOUNT
        LDA     RCUR
        STA     PCUR
        LDA     RTOP
        STA     PTOP
        LXI     H,RFILES
        SHLD    PLIST
        LDA     ACTIVE
        STA     PACTIV
        LDA     PTOP
        STA     DRAWIDX
        MVI     A,FIRST
        STA     DRAWROW
        MVI     A,ROWS
        STA     DRAWLEFT
DPLOOP: LDA     DRAWROW
        CALL    DRAWLINE
        LDA     DRAWIDX
        INR     A
        STA E
        RET

DRAWP:  CALL    DRAWHDR
        CALL    DRAWROWS
        RET

DRAWHDR:
        MVI     A,INVATT
        STA     LINEATT
        LDA     PACTIVE
        ORA     A
        JZ      DPHATTR
        MVI     A,BOLDINV
        STA        DRAWIDX
        LDA     DRAWROW
        INR     A
        STA     DRAWROW
        LDA     DRAWLEFT
        DCR     A
        STA     DRAWLEFT
        JNZ     DPLOOP
        RET

DRAWLINE:
        LDA     DRAWIDX
        STA     LINEIDX
    LINEATT
DPHATTR:MVI     B,0
        LDA     PCOL
        MOV     C,A
        CALL    POS
        LDA     LINEATT
        CALL    SETATTR
        MVI     B,39
DPHCLR: MVI     A,' '
        CALL    PUTC
        DCR     B
        JNZ     DPHCLR
      MOV     D,A
        LDA     PCOUNT
        CMP     D
        MVI     A,0
        JC      DLVALID
        JZ      DLVALID
        MVI     A,1
DLVALID:STA     LINEOK
        MVI     A,NORMATT
        STA     LINEATT
        LDA     LINEOK
          MVI     B,0
        LDA     PCOL
        MOV     C,A
        CALL    POS
        LDA     PACTIVE
        ORA     A
        MVI     A,' '
        JZ      DPHMARK
        MVI     A,'*'
DPHMARK:CALL    PUTC
        LXI     H,DRIVEMSG
            ORA     A
        JZ      DLATTR
        LDA     PACTIVE
        ORA     A
        JZ      DLATTR
        LDA     PCUR
        MOV     D,A
        LDA     LINEIDX
        CMP     D
        JNZ     DLATTR
        MVI     A,INVATT
        STA CALL    PRINTZ
        LDA     PDRIVE
        ADI     'A'-1
        CALL    PUTC
        MVI     A,':'
        CALL    PUTC
        MVI     A,' '
        CALL    PUTC
        MVI     A,' '
        CALL    PUTC
        LDA     PCOUNT
        CAL     LINEATT
DLATTR: LDA     DRAWROW
        MOV     B,A
        LDA     PCOL
        MOV     C,A
        CALL    POS
        LDA     LINEATT
        CALL    SETATTR
        MVI     B,39
DLBLANK:MVI     A,' '
        CALL    PUTC
        DCR     B
        JNZ     DLBLANK
        LDA     LINEOK
        ORA     A
        JZ      DLNORM
        LDA     DRAWROW
        MOV     B,A
        LDA     PCOL
        MOV     C,A
        CALL    POS
        LDA     LINEIDX
        MOV     D,A
        A
        STA     LEAD
        LXI     D,100
        CALL    PDIV
        LXI     D,10
        CALL    PDIV
        MOV     A,L
        ADI     '0'
        CALL    PUTC
        RET

PRINT5: XRA     A
        STA     LEAD
        LXI     D,    LDA     PACTIVE
        ORA     A
        JZ      DLNOCUR
        LDA     PCUR
        CMP     D
        MVI     A,' '
        JNZ     DLCURS
        MVI     A,'>'
        JMP     DLCURS
DLNOCUR:MVI     A,' '
DLCURS: CALL    PUTC
        LDA10000
        CALL    PDIV
        LXI     D,1000
        CALL    PDIV
        LXI     D,100
        CALL    PDIV
        LXI     D,10
        CALL    PDIV
        MOV     A,L
        ADI     '0'
        CALL    PUTC
        RET

PDIV:   MVI       LINEIDX
        CALL    PENTRY
        PUSH    H
        LXI     D,11
        DAD     D
        MOV     A,M
        ORA     A
        MVI     A,' '
        JZ      DLSEL
        MVI     A,'*'
DLSEL:  CALL    PUTC
        MVI     A,' '
       B,0
PDLOOP: MOV     A,H
        CMP     D
        JC      PDDONE
        JNZ     PDSUB
        MOV     A,L
        CMP     E
        JC      PDDONE
PDSUB:  MOV     A,L
        SUB     E
        MOV     L,A
        MOV     A,H
        SBB        CALL    PUTC
        POP     H
        PUSH    H
        CALL    PRINTNAME
        POP     H
        MVI     A,' '
        CALL    PUTC
        PUSH    H
        LXI     D,14
        DAD     D
        MOV     A,M
        CPI     0FFH
       D
        MOV     H,A
        INR     B
        JMP     PDLOOP
PDDONE: MOV     A,B
        ORA     A
        JNZ     PDNUM
        LDA     LEAD
        ORA     A
        MVI     A,' '
        JZ      PDOUT
        MVI     A,'0'
        JMP      JZ      DLUNKSZ
        DCX     H
        DCX     H
        MOV     E,M
        INX     H
        MOV     D,M
        XCHG
        LXI     D,7
        DAD     D
        CALL    HALF
        CALL    HALF
        CALL    HALF
        CALL    PR PDOUT
PDNUM:  MVI     A,1
        STA     LEAD
        MOV     A,B
        ADI     '0'
PDOUT:  CALL    PUTC
        RET

HALF:   ORA     A
        MOV     A,H
        RAR
        MOV     H,A
        MOV     A,L
        RAR
        MOV     L,INT5
        JMP     DLSIZED
DLUNKSZ:
        LXI     H,UNKSIZE
        CALL    PRINTZ
DLSIZED:
        MVI     A,'K'
        CALL    PUTC
        POP     H
DLNORM: MVI     A,NORMATT
        CALL    SETATTR
        RET

PENTRY: LHLD    PLIST
A
        RET

SETATTR:MOV     B,A
        MVI     A,1BH
        CALL    PUTC
        MVI     A,'0'
        CALL    PUTC
        MOV     A,B
        CALL    PUTC
        RET

POS:    PUSH    B
        MVI     A,1BH
        CALL    PUTC
     ENTRYA: ORA     A
        RZ
        LXI     D,ENTSIZ
ENTLOOP:DAD     D
        DCR     A
        JNZ     ENTLOOP
        RET

PRINTNAME:
        MVI     B,8
PNBASE: MOV     A,M
        CALL    PUTC
        INX     H
        DCR     B
          MVI     A,'Y'
        CALL    PUTC
        POP     B
        MOV     A,B
        ADI     20H
        CALL    PUTC
        MOV     A,C
        ADI     20H
        CALL    PUTC
        RET

STATUS: PUSH    H
        MVI     B,23
        MVI   JNZ     PNBASE
        MVI     A,'.'
        CALL    PUTC
        MVI     B,3
PNEXT:  MOV     A,M
        CALL    PUTC
        INX     H
        DCR     B
        JNZ     PNEXT
        RET

PRINT3: MOV     L,A
        MVI     H,0
        XRA    C,0
        CALL    POS
        MVI     A,1BH
        CALL    PUTC
        MVI     A,'K'
        CALL    PUTC
        POP     H
        CALL    PRINTZ
        MVI     A,1
        STA     FOOTMSG
        RET

; ---------------------------------------------------------------------------
; Navigation and marking

SAVENAV:LDA     ACTIVE
        ORA     A
        JNZ     SAVER
        LDA     LCUR
        STA     OLDCUR
        LDA     LTOP
        STA     OLDTOP
        RET
SAVER:  LDA    RZ
        DCR     A
        STA     LCUR
        MOV     B,A
        LDA     LTOP
        MOV     C,A
        MOV     A,B
        CMP     C
        RNC
        STA     LTOP
        RET
RUP:    LDA     RCUR
        ORA     A
        RZ
       RCUR
        STA     OLDCUR
        LDA     RTOP
        STA     OLDTOP
        RET

NAVDRAW:LDA     ACTIVE
        ORA     A
        JNZ     NAVR
        CALL    SETL
        JMP     NAVSET
NAVR:   CALL    SETR
NAVSET: LDA     PCUR
           DCR     A
        STA     RCUR
        MOV     B,A
        LDA     RTOP
        MOV     C,A
        MOV     A,B
        CMP     C
        RNC
        STA     RTOP
        RET

MOVEDOWN:
        LDA     ACTIVE
        ORA     A
        J   MOV     B,A
        LDA     OLDCUR
        CMP     B
        JNZ     NAVCHG
        LDA     PTOP
        MOV     B,A
        LDA     OLDTOP
        CMP     B
        RZ
NAVCHG:CALL    DRAWHDR
        LDA     PTOP
        MOV     B,A
        NZ     RDOWN
        LDA     LCOUNT
        MOV     B,A
        LDA     LCUR
        INR     A
        CMP     B
        RNC
        STA     LCUR
        MOV     B,A
        LDA     LTOP
        ADI     ROWS
        CMP     B
        JC      LDLDA     OLDTOP
        CMP     B
        JZ      NAVROWS
        CALL    DRAWROWS
        CALL    FILLPANEL
        RET
NAVROWS:
        LDA     OLDCUR
        STA     DRAWIDX
        MOV     B,A
        LDA     PTOP
        MOV     C,A
       SCROLL
        JZ      LDSCROLL
        RET
LDSCROLL:
        LDA     LTOP
        INR     A
        STA     LTOP
        RET
RDOWN:  LDA     RCOUNT
        MOV     B,A
        LDA     RCUR
        INR     A
        CMP     B
        RNC
     MOV     A,B
        SUB     C
        ADI     FIRST
        STA     DRAWROW
        CALL    DRAWLINE
        LDA     PCUR
        MOV     B,A
        LDA     OLDCUR
        CMP     B
        RZ
        MOV     A,B
        STA     DRAWIDX
         STA     RCUR
        MOV     B,A
        LDA     RTOP
        ADI     ROWS
        CMP     B
        JC      RDSCROLL
        JZ      RDSCROLL
        RET
RDSCROLL:
        LDA     RTOP
        INR     A
        STA     RTOP
        RET

   MOV     B,A
        LDA     PTOP
        MOV     C,A
        MOV     A,B
        SUB     C
        ADI     FIRST
        STA     DRAWROW
        CALL    DRAWLINE
        RET

REDRAWC:LDA     ACTIVE
        ORA     A
        JNZ     REDRAWR
MARKFILE:
        LDA     ACTIVE
        ORA     A
        JNZ     RMARK
        LDA     LCOUNT
        ORA     A
        RZ
        LDA     LCUR
        LXI     H,LFILES
        JMP     DOMARK
RMARK:  LDA     RCOUNT
        ORA     A
        R        CALL    SETL
        JMP     REDSET
REDRAWR:CALL    SETR
REDSET: CALL    DRAWCUR
        RET

DRAWCUR:LDA     PCOUNT
        ORA     A
        RZ
        LDA     PCUR
        STA     DRAWIDX
        MOV     B,A
        LDA     PTOP
   Z
        LDA     RCUR
        LXI     H,RFILES
DOMARK: SHLD    WORKLIST
        CALL    WENTRY
        LXI     D,11
        DAD     D
        MOV     A,M
        XRI     1
        MOV     M,A
        RET

WENTRY: LHLD    WORKLIST
        JMP      MOV     C,A
        MOV     A,B
        SUB     C
        ADI     FIRST
        STA     DRAWROW
        CALL    DRAWLINE
        RET

MOVEUP: LDA     ACTIVE
        ORA     A
        JNZ     RUP
        LDA     LCUR
        ORA     A
        ENTRYA

PICKDRIVE:
        CALL    SHOWDRIVES
PDKEY:  CALL    GETKEY
        CPI     1BH
        RZ
        CPI     'a'
        JC      PDUP
        CPI     'z'+1
        JNC     PDUP
        SUI     20H
PDUP:   CPI     'A'
        JC      PDKEY
        CPI     'G'
        JNC     PDKEY
        SUI     'A'-1
        MOV     B,A
        PUSH    B
        CALL    SHOWREAD
        POP     B
        LDA     ACTIVE
        ORA     A
        JNZ     PDRIGHT
        MOV     A,B
       SHLD    ENTRYPTR
        LDA     CPNUM
        INR     A
        STA     CPNUM
        CALL    PREPCOPY
        CALL    SHOWCOPY
        CALL    COPYONE
CPNEXT: LDA     LOOPIDX
        INR     A
        STA     LOOPIDX
        JMP     CPLOOP
CPD STA     LDRIVE
        CALL    LOADL
        RET
PDRIGHT:MOV     A,B
        STA     RDRIVE
        CALL    LOADR
        RET

SHOWDRIVES:
        CALL    MODBOX
        MVI     B,9
        MVI     C,34
        CALL    POS
        LXI     H,DONE: CALL    LOADL
        CALL    LOADR
        CALL    DRAW
        LDA     OPERROR
        ORA     A
        JNZ     SHOWCPERR
        CALL    SHOWCPDONE
        RET

SHOWCPERR:
        CALL    SHOWERROR
        RET

SETSOURCE:
        LDARVHEAD
        CALL    PRINTZ
        MVI     B,10
        MVI     C,29
        CALL    POS
        LXI     H,DRVOPTS
        CALL    PRINTZ
        MVI     B,11
        MVI     C,27
        CALL    POS
        LXI     H,DRVPROMPT
        CALL       ACTIVE
        ORA     A
        JNZ     SRCRIGHT
        LDA     LDRIVE
        STA     SRCDRIVE
        LDA     RDRIVE
        STA     DSTDRIVE
        LDA     LCOUNT
        STA     SCOUNT
        LDA     LCUR
        STA     SCUR
        PRINTZ
        MVI     B,12
        MVI     C,26
        CALL    POS
        LXI     H,DRVREADY
        CALL    PRINTZ
        MVI     A,NORMATT
        CALL    SETATTR
        RET

; ------------------------------------------------------------  LXI     H,LFILES
        SHLD    SLIST
        RET
SRCRIGHT:
        LDA     RDRIVE
        STA     SRCDRIVE
        LDA     LDRIVE
        STA     DSTDRIVE
        LDA     RCOUNT
        STA     SCOUNT
        LDA     RCUR
        STA     SCU---------------
; Copy

COPYFILES:
        CALL    SETSOURCE
        LDA     SRCDRIVE
        MOV     B,A
        LDA     DSTDRIVE
        CMP     B
        JNZ     CPDIFF
        LXI     H,SAMEDRV
        CALL    STATUS
        RET
CPDIFF:
 R
        LXI     H,RFILES
        SHLD    SLIST
        RET

FINDSEL:XRA     A
        STA     LOOPIDX
FSLOOP: LDA     LOOPIDX
        MOV     B,A
        LDA     SCOUNT
        CMP     B
        JZ      FSNONE
        MOV     A,B
        CAL       LDA     SCOUNT
        ORA     A
        JNZ     CPHAVE
        LXI     H,NOFILES
        CALL    STATUS
        RET
CPHAVE: CALL    FINDSEL
        STA     SELMODE
        CALL    COUNTCP
        XRA     A
        STA     OPERROR
       L    SENTRY
        LXI     D,11
        DAD     D
        MOV     A,M
        ORA     A
        MVI     A,1
        RNZ
        LDA     LOOPIDX
        INR     A
        STA     LOOPIDX
        JMP     FSLOOP
FSNONE: XRA     A
        RET

C STA     LOOPIDX
        STA     CPNUM
CPLOOP: LDA     LOOPIDX
        MOV     B,A
        LDA     SCOUNT
        CMP     B
        JZ      CPDONE
        LDA     SELMODE
        ORA     A
        JZ      CPCUR
        MOV     A,B
        CALL  OUNTCP:LDA     SELMODE
        ORA     A
        JNZ     CCSEL
        MVI     A,1
        STA     CPTOTAL
        RET
CCSEL:  XRA     A
        STA     CPTOTAL
        STA     LOOPIDX
CCLOOP: LDA     LOOPIDX
        MOV     B,A
        LDA       SENTRY
        LXI     D,11
        DAD     D
        MOV     A,M
        ORA     A
        JZ      CPNEXT
        JMP     CPONE
CPCUR:  LDA     SCUR
        CMP     B
        JNZ     CPNEXT
CPONE:  MOV     A,B
        CALL    SENTRY
        SCOUNT
        CMP     B
        RZ
        MOV     A,B
        CALL    SENTRY
        LXI     D,11
        DAD     D
        MOV     A,M
        ORA     A
        JZ      CCNEXT
        LDA     CPTOTAL
        INR     A
        STA     CPTOTAL
CCNEXT: LDA     LOOPIDX
        INR     A
        STA     LOOPIDX
        JMP     CCLOOP

SENTRY: LHLD    SLIST
        JMP     ENTRYA

; Cache the selected file's exact record count and initialise its individual
; copy-progress counter. P2000C       ORA     A
        JNZ     CPWRERR
        LHLD    CPRECDONE
        INX     H
        SHLD    CPRECDONE
        MOV     A,L
        ANI     1FH
        JNZ     CPRECORD
        CALL    SHOWFILEPROG
        JMP     CPRECORD
CPWRERR:
       logical volumes fit in the displayed 16 bits.
PREPCOPY:
        LHLD    ENTRYPTR
        LXI     D,14
        DAD     D
        MOV     A,M
        CPI     0FFH
        JNZ     CPPKNOWN
        CALL    BUILDSRC
        LXI     D,SRCFCB
        MV MVI     A,1
        STA     OPERROR
        JMP     CPCLOSE
CPRDEOF:
        CALL    SHOWFILEPROG
CPCLOSE:LXI     D,DSTFCB
        MVI     C,CLOSEF
        CALL    BDOS
        LXI     D,SRCFCB
        MVI     C,CLOSEF
        CALL    BDOS
    I     C,FSIZE
        CALL    BDOS
        LHLD    ENTRYPTR
        LXI     D,12
        DAD     D
        LDA     SRCFCB+33
        MOV     M,A
        INX     H
        LDA     SRCFCB+34
        MOV     M,A
        INX     H
        LDA     SR    RET
CPMKERR:LXI     D,SRCFCB
        MVI     C,CLOSEF
        CALL    BDOS
CPFAIL: MVI     A,1
        STA     OPERROR
        RET

ASKOVER:CALL    MODBOX
        MVI     B,10
        MVI     C,22
        CALL    POS
        LXI     H,OVER1CFCB+35
        MOV     M,A
CPPKNOWN:
        LHLD    ENTRYPTR
        LXI     D,12
        DAD     D
        MOV     E,M
        INX     H
        MOV     D,M
        XCHG
        SHLD    CPTOTREC
        LXI     H,0
        SHLD    CPRECDONE
        CALL    PRINTZ
        LHLD    ENTRYPTR
        CALL    PRINTSHORT
        LXI     H,OVER2
        CALL    PRINTZ
        MVI     A,NORMATT
        CALL    SETATTR
OVKEY:  CALL    GETKEY
        CPI     'a'
        JC      OVUP
        
        RET

COPYONE:
        CALL    BUILDFCBS
        LXI     D,DIRBUF
        MVI     C,SETDMA
        CALL    BDOS
        LXI     D,DSTFCB
        MVI     C,SFIRST
        CALL    BDOS
        CPI     0FFH
        JZ      CPNEW
        CACPI     'z'+1
        JNC     OVUP
        SUI     20H
OVUP:   CPI     'Y'
        JZ      OVYES
        CPI     'N'
        JNZ     OVKEY
        XRA     A
        RET
OVYES:  CALL    SHOWCOPY
        MVI     A,1
        RET

; Four-row inverLL    ASKOVER
        ORA     A
        RZ
        CALL    BUILDFCBS
        LXI     D,DSTFCB
        MVI     C,DELETE
        CALL    BDOS
CPNEW:  CALL    BUILDFCBS
        LXI     D,SRCFCB
        MVI     C,OPENF
        CALL    BDOS
        Cse-video copy modal. It deliberately stays clear of row 23,
; so the keyboard legend remains visible throughout the operation.
MODBOX: MVI     B,9
MBLOOP:CALL    MODROW
        INR     B
        MOV     A,B
        CPI     13
        JNZ     MBLOOPPI     0FFH
        JZ      CPFAIL
        LXI     D,DSTFCB
        MVI     C,MAKEF
        CALL    BDOS
        CPI     0FFH
        JZ      CPMKERR
CPRECORD:
        LXI     D,BUFFER
        MVI     C,SETDMA
        CALL    BDOS
        LXI   
        RET

MODROW:MOV     A,B
        STA     MODROWNO
        MVI     C,20
        CALL    POS
        MVI     A,INVATT
        CALL    SETATTR
        MVI     D,40
MRCLEAR:MVI     A,' '
        CALL    PUTC
        DCR     D
        JNZ     D,SRCFCB
        MVI     C,READSEQ
        CALL    BDOS
        ORA     A
        JNZ     CPRDEOF
        LXI     D,BUFFER
        MVI     C,SETDMA
        CALL    BDOS
        LXI     D,DSTFCB
        MVI     C,WRITSEQ
        CALL    BDOS
    MRCLEAR
        LDA     MODROWNO
        MOV     B,A
        MVI     C,20
        CALL    POS
        RET

SHOWCOPY:
        CALL    MODBOX
        MVI     B,9
        MVI     C,32
        CALL    POS
        LXI     H,CPHEAD
        CALL    PRINTZ
        MVI     B,10
        MVI     C,22
        CALL    POS
        LXI     H,CPFILE
        CALL    PRINTZ
        LHLD    ENTRYPTR
        CALL    PRINTSHORT
        MVI     B,11
        MVI     C,29
        CALL    POS
        LXI  -----------------------------------------------------------
; Delete

DELFILES:
        CALL    SETSOURCE
        LDA     SCOUNT
        ORA     A
        JNZ     DELHAVE
        LXI     H,NOFILES
        CALL    STATUS
        RET
DELHAVE:CALL    H,CPSTEP
        CALL    PRINTZ
        LDA     CPNUM
        CALL    PRINT3
        LXI     H,CPOF
        CALL    PRINTZ
        LDA     CPTOTAL
        CALL    PRINT3
        CALL    SHOWFILEPROG
        MVI     A,NORMATT
        CALL    SE   FINDSEL
        STA     SELMODE
        LXI     H,DELASK
        CALL    STATUS
        CALL    YESNO
        ORA     A
        RZ
        XRA     A
        STA     OPERROR
        STA     LOOPIDX
DELLOOP:LDA     LOOPIDX
        MOV     B,A
TATTR
        RET

SHOWFILEPROG:
        MVI     B,12
        MVI     C,29
        CALL    POS
        LXI     H,CPRECS
        CALL    PRINTZ
        LHLD    CPRECDONE
        CALL    PRINT5
        MVI     A,'/'
        CALL    PUTC
                LDA     SCOUNT
        CMP     B
        JZ      DELDONE
        LDA     SELMODE
        ORA     A
        JZ      DELCUR
        MOV     A,B
        CALL    SENTRY
        LXI     D,11
        DAD     D
        MOV     A,M
        ORA  LHLD    CPTOTREC
        CALL    PRINT5
        RET

SHOWCPDONE:
        CALL    MODBOX
        MVI     B,10
        MVI     C,33
        CALL    POS
        LXI     H,COPYOK
        CALL    PRINTZ
        JMP     SHOWACK

SHOWERROR:
           A
        JZ      DELNEXT
        JMP     DELONE
DELCUR: LDA     SCUR
        CMP     B
        JNZ     DELNEXT
DELONE: MOV     A,B
        CALL    SENTRY
        SHLD    ENTRYPTR
        CALL    BUILDSRC
        LXI     D,SRCFCB
        MVI CALL    MODBOX
        MVI     B,10
        MVI     C,25
        CALL    POS
        LXI     H,COPYERR
        CALL    PRINTZ
SHOWACK:MVI     B,11
        MVI     C,31
        CALL    POS
        LXI     H,CPACK
        CALL    PRINTZ
        MV    C,DELETE
        CALL    BDOS
        CPI     0FFH
        JNZ     DELNEXT
        MVI     A,1
        STA     OPERROR
DELNEXT:LDA     LOOPIDX
        INR     A
        STA     LOOPIDX
        JMP     DELLOOP
DELDONE:CALL    LOADL
        CAI     A,NORMATT
        CALL    SETATTR
        MVI     A,1
        STA     MODAL
        RET

BUILDFCBS:
        LXI     H,SRCFCB
        CALL    CLEAR36
        LXI     H,DSTFCB
        CALL    CLEAR36
        LDA     SRCDRIVE
        STA    LL    LOADR
        CALL    DRAW
        LDA     OPERROR
        ORA     A
        LXI     H,DELOK
        JZ      DELSTAT
        LXI     H,DELERR
DELSTAT:CALL    STATUS
        RET

BUILDSRC:
        LXI     H,SRCFCB
        CALL    CLEAR36
 SRCFCB
        LDA     DSTDRIVE
        STA     DSTFCB
        LHLD    ENTRYPTR
        XCHG
        LXI     H,SRCFCB+1
        MVI     B,11
BFSRC:  LDAX    D
        MOV     M,A
        INX     D
        INX     H
        DCR     B
        JN        LDA     SRCDRIVE
        STA     SRCFCB
        LHLD    ENTRYPTR
        XCHG
        LXI     H,SRCFCB+1
        MVI     B,11
BSONE:  LDAX    D
        MOV     M,A
        INX     D
        INX     H
        DCR     B
        JNZ     BSOZ     BFSRC
        LHLD    ENTRYPTR
        XCHG
        LXI     H,DSTFCB+1
        MVI     B,11
BFDST:  LDAX    D
        MOV     M,A
        INX     D
        INX     H
        DCR     B
        JNZ     BFDST
        RET

; ----------------NE
        RET

; ---------------------------------------------------------------------------
; Rename

RENFILE:LDA     ACTIVE
        ORA     A
        JNZ     RENR
        LDA     LCOUNT
        ORA     A
        JZ      RENNONE
        LDA     LDRIVE
        STA     SRCDRIVE
        LDA     LCUR
        LXI     H,LFILES
        JMP     RENSET
RENR:   LDA     RCOUNT
        ORA     A
        JZ      RENNONE
        LDA     RDRIVE
        STA     SRCDRIVE
        LDA     RCUR
       
        MVI     A,08H
        CALL    PUTC
        MVI     A,' '
        CALL    PUTC
        MVI     A,08H
        CALL    PUTC
        JMP     GNKEY
GNDONE: CALL    PARSENEW
        RET
GNCANCEL:
        XRA     A
        RET

PARSENEW:
  LXI     H,RFILES
RENSET: SHLD    WORKLIST
        CALL    WENTRY
        SHLD    ENTRYPTR
        CALL    GETNEW
        ORA     A
        RZ
        CALL    NEWEXISTS
        ORA     A
        JZ      RENDO
        LXI     H,NAMEUSED
        C       LXI     H,NEWNAME
        MVI     B,11
        MVI     A,' '
PNCLR:  MOV     M,A
        INX     H
        DCR     B
        JNZ     PNCLR
        LXI     H,NEWBUF
        LXI     D,NEWNAME
        MVI     B,0
        MVI     C,0
PNLOOP: ALL    STATUS
        RET
RENDO:  CALL    BUILDREN
        LXI     D,SRCFCB
        MVI     C,RENAME
        CALL    BDOS
        CPI     0FFH
        LXI     H,RENOK
        JNZ     RENRES
        LXI     H,RENERR
RENRES: PUSH    H
        CALLMOV     A,M
        ORA     A
        JZ      PNEND
        CPI     '.'
        JZ      PNDOT
        CPI     '*'
        JZ      PNBAD
        CPI     '?'
        JZ      PNBAD
        CPI     '/'
        JZ      PNBAD
        CPI     ':'
        LOADL
        CALL    LOADR
        CALL    DRAW
        POP     H
        CALL    STATUS
        RET
RENNONE:LXI     H,NOFILES
        CALL    STATUS
        RET

GETNEW: LXI     H,NEWBUF
        MVI     M,0
        SHLD    INPTR
            JZ      PNBAD
        CPI     ';'
        JZ      PNBAD
        CPI     '<'
        JZ      PNBAD
        CPI     '='
        JZ      PNBAD
        CPI     '>'
        JZ      PNBAD
        CPI     '['
        JZ      PNBAD
        CPI     'XRA     A
        STA     INLEN
        LXI     H,NEWASK
        CALL    STATUS
GNKEY:  CALL    GETKEY
        CPI     1BH
        JZ      GNCANCEL
        CPI     0DH
        JZ      GNDONE
        CPI     08H
        JZ      GNBACK
        CPI]'
        JZ      PNBAD
        MOV     A,C
        ORA     A
        JNZ     PNEXTC
        MOV     A,B
        CPI     8
        JNC     PNBAD
        MOV     A,M
        STAX    D
        INX     D
        INR     B
        INX     H
          7FH
        JZ      GNBACK
        CPI     'a'
        JC      GNUP
        CPI     'z'+1
        JNC     GNUP
        SUI     20H
GNUP:   CPI     21H
        JC      GNKEY
        CPI     7FH
        JNC     GNKEY
        MOV     B,A
       JMP     PNLOOP
PNEXTC: MOV     A,B
        CPI     3
        JNC     PNBAD
        MOV     A,M
        STAX    D
        INX     D
        INR     B
        INX     H
        JMP     PNLOOP
PNDOT:  MOV     A,C
        ORA     A
        JNZ      LDA     INLEN
        CPI     12
        JNC     GNKEY
        MOV     A,B
        LHLD    INPTR
        MOV     M,A
        INX     H
        MVI     M,0
        SHLD    INPTR
        LDA     INLEN
        INR     A
        STA     INLEN
    PNBAD
        MOV     A,B
        ORA     A
        JZ      PNBAD
        MVI     C,1
        MVI     B,0
        LXI     D,NEWNAME+8
        INX     H
        JMP     PNLOOP
PNEND:  MOV     A,C
        ORA     A
        JZ      PNBCHK
            MOV     A,B
        CALL    PUTC
        JMP     GNKEY
GNBACK: LDA     INLEN
        ORA     A
        JZ      GNKEY
        DCR     A
        STA     INLEN
        LHLD    INPTR
        DCX     H
        SHLD    INPTR
        MVI     M,0   MOV     A,B
        ORA     A
        JZ      PNBAD
PNBCHK: LDA     NEWNAME
        CPI     ' '
        JZ      PNBAD
        MVI     A,1
        RET
PNBAD:  LXI     H,BADNAME
        CALL    STATUS
        XRA     A
        RET

NEWEXISTS:
        LXI     H,DSTFCB
        CALL    CLEAR36
        LDA     SRCDRIVE
        STA     DSTFCB
        LXI     H,NEWNAME
        LXI     D,DSTFCB+1
        MVI     B,11
NECOPY: MOV     A,M
        STAX    D
        INX     H
        INX     D   B
        PUSH    D
        PUSH    H
        MOV     E,A
        MVI     C,CONOUT
        CALL    BDOS
        POP     H
        POP     D
        POP     B
        RET

GETKEY: PUSH    B
        PUSH    D
        PUSH    H
GKWAIT: MVI   
        DCR     B
        JNZ     NECOPY
        LXI     D,DIRBUF
        MVI     C,SETDMA
        CALL    BDOS
        LXI     D,DSTFCB
        MVI     C,SFIRST
        CALL    BDOS
        CPI     0FFH
        MVI     A,0
        RZ
          E,0FFH
        MVI     C,DIRIO
        CALL    BDOS
        ORA     A
        JZ      GKWAIT
        POP     H
        POP     D
        POP     B
        RET

SHOWSTART:
        PUSH    PSW
        MVI     A,0CH
        CALL    PUTC
      MVI     A,1
        RET

BUILDREN:
        CALL    BUILDSRC
        LDA     SRCDRIVE
        STA     SRCFCB+16
        LXI     H,NEWNAME
        LXI     D,SRCFCB+17
        MVI     B,11
BRCOPY: MOV     A,M
        STAX    D
        INX     H
   LXI     H,STARTMSG
        CALL    PRINTZ
        POP     PSW
        ADI     'A'-1
        CALL    PUTC
        MVI     A,':'
        CALL    PUTC
        LXI     H,WAITMSG
        CALL    PRINTZ
        RET

SHOWREAD:
        PUSH    PSW
        INX     D
        DCR     B
        JNZ     BRCOPY
        RET

; ---------------------------------------------------------------------------
; Common helpers

YESNO:  CALL    GETKEY
        CPI     'a'
        JC      YNUP
        CPI          LXI     H,READMSG
        CALL    STATUS
        POP     PSW
        ADI     'A'-1
        CALL    PUTC
        MVI     A,':'
        CALL    PUTC
        RET

; ---------------------------------------------------------------------------
;  'z'+1
        JNC     YNUP
        SUI     20H
YNUP:   CPI     'Y'
        JZ      YNYES
        CPI     'N'
        JNZ     YESNO
        XRA     A
        RET
YNYES:  MVI     A,1
        RET

CLEAR36:MVI     B,36
        XRA     A
C36LOOP Data

STARTMSG:
        DB      'P2FILE: READING DRIVE ',0
WAITMSG:DB      ' - PLEASE WAIT',0
READMSG:DB      'P2FILE: READING DRIVE ',0
UNKSIZE:DB      '    ?',0
HELP:   DB      'TAB PANEL  W/S MOVE  SPACE MARK  C COPY  D DELETE'
        DB      :MOV     M,A
        INX     H
        DCR     B
        JNZ     C36LOOP
        RET

PRINTSHORT:
        PUSH    H
        MVI     B,8
PSBASE: MOV     A,M
        CPI     ' '
        CZ      PSNOP
        CNZ     PUTC
        INX     H
     '  R RENAME  V DRIVE  Q QUIT',0
DRIVEMSG:
        DB      ' DRIVE ',0
FILEMSG:DB      ' FILES ',0
DRVHEAD:DB      'SELECT DRIVE',0
DRVOPTS:DB      'A:  B:  C:  D:  E:  F:',0
DRVPROMPT:
        DB      'PRESS A-F OR ESC TO CANCEL',0
DRVREADY:
        DCR     B
        JNZ     PSBASE
        POP     H
        LXI     D,8
        DAD     D
        MOV     A,M
        CPI     ' '
        RZ
        MVI     A,'.'
        CALL    PUTC
        MVI     B,3
PSEXT:  MOV     A,M
        CPI     '    DB      'INSERT DISK BEFORE SELECTING',0
BYEMSG: DB      'P2FILE finished.',13,10,0
NOFILES:DB      'No files in the active panel.',0
SAMEDRV:DB      'Choose two different drives before copying.',0
COPYOK: DB      'Copy complete.',0
COPYERR:DB     '
        CZ      PSNOP
        CNZ     PUTC
        INX     H
        DCR     B
        JNZ     PSEXT
PSNOP:  RET

PRINTZ: MOV     A,M
        ORA     A
        RZ
        CALL    PUTC
        INX     H
        JMP     PRINTZ

PUTC:   PUSH  'Copy finished with a disk error.',0
CPHEAD: DB      'COPYING FILES',0
CPFILE: DB      'FILE: ',0
CPSTEP: DB      'FILE ',0
CPOF:   DB      ' OF ',0
CPRECS: DB      'RECORDS ',0
CPACK:  DB      'PRESS A KEY TO CONTINUE',0
OVER1:  DB      'Overwrite ',0
OVER2:  DB      '? (Y/N)',0
DELASK: DB      'Delete selected file(s)? (Y/N)',0
DELOK:  DB      'Delete complete.',0
DELERR: DB      'Delete finished with an error.',0
NEWASK: DB      'New name (ESC cancels): ',0
BADNAME:DB      'Invalid CP/M 8.3ňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňň filename.',0
NAMEUSED:
        DB      'That filename already exists.',0
RENOK:  DB      'Rename complete.',0
RENERR: DB      'Rename failed.',0


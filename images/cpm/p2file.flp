;
; Assemble on the P2000C with Digital Research's tools:
;     ASM P2FILE
;     LOAD P2FILE
;     P2FILE
;
; Keys: TAB panel, W/S move, SPACE mark, C copy, D delete, R rename,
;         XRI     1
        STA     ACTIVE
        CALL    LOADCURSIZE
        CALL    SETL
        CALL    DRAWHDR
        CALL    DRAWCUR
        CALL    SETR
        CALL    DRAWHDR
        CALL    DRAWCUR
        JMP     KEYLOOP

KUP:    CALL       V choose drive, Q quit.
;
; Intel 8080 source.  The program uses only documented CP/M 2.2 BDOS calls
; and documented P2000C terminal escape sequences.

BDOS    EQU     0005H
CONOUT  EQU     02H
DIRIO   EQU     06H
OPENF   EQU     0FH
CLOSEF  ESAVENAV
        CALL    MOVEUP
        CALL    LOADCURSIZE
        CALL    NAVDRAW
        JMP     KEYLOOP

KDOWN:  CALL    SAVENAV
        CALL    MOVEDOWN
        CALL    LOADCURSIZE
        CALL    NAVDRAW
        JMP     KEYLOOP

KMARK:  CAQU     10H
SFIRST  EQU     11H
SNEXT   EQU     12H
DELETE  EQU     13H
READSEQ EQU     14H
WRITSEQ EQU     15H
MAKEF   EQU     16H
RENAME  EQU     17H
SETDMA  EQU     1AH
FSIZE   EQU     23H

MAXFILE EQU     128
ROWS    EQU     22
FIRST   EQU LL    MARKFILE
        CALL    REDRAWC
        JMP     KEYLOOP

KCOPY:  CALL    COPYFILES
        JMP     KEYLOOP

KDEL:
        CALL    DELFILES
        JMP     KEYLOOP

KREN:
        CALL    RENFILE
        JMP     KEYLOOP

KDRIVE:CALL        1
ENTSIZ  EQU     16
NORMATT EQU     40H
INVATT  EQU     50H
BOLDINV EQU     11H

        ORG     0100H

START:  LXI     SP,STACK
        LDA     LDRIVE
        CALL    SHOWSTART
        CALL    LOADL
        CALL    DRAW
        LDA     RPICKDRIVE
        JMP     MAIN

KQUIT:  MVI     A,0CH
        CALL    PUTC
        LXI     H,BYEMSG
        CALL    PRINTZ
        JMP     0000H

; ---------------------------------------------------------------------------
; Directory loading
DRIVE
        CALL    SHOWREAD
        CALL    LOADR

MAIN:   CALL    DRAW
        CALL    LOADCURSIZE
        CALL    REDRAWC
KEYLOOP:CALL    GETKEY
        STA     KEYTMP
        LDA     MODAL
        ORA     A
        JZ      KEYFOOT
       
LOADL:  LDA     LDRIVE
        STA     SRCHFCB
        LXI     H,LFILES
        SHLD    STOREPTR
        LXI     H,LCOUNT
        SHLD    CNTPTR
        CALL    READDIR
        CALL    NORML
        RET

LOADR:  LDA     RDRIVE
        STA     S XRA     A
        STA     MODAL
        CALL    DRAW
        JMP     KEYLOAD
KEYFOOT:
        LDA     FOOTMSG
        ORA     A
        JZ      KEYLOAD
        CALL    DRAWHELP
KEYLOAD:LDA     KEYTMP
        CPI     'a'
        JC      KEYUP
 RCHFCB
        LXI     H,RFILES
        SHLD    STOREPTR
        LXI     H,RCOUNT
        SHLD    CNTPTR
        CALL    READDIR
        CALL    NORMR
        RET

READDIR:
        LXI     H,SRCHFCB+1
        MVI     B,11
RDFILL: MVI     M,'?'       CPI     'z'+1
        JNC     KEYUP
        SUI     20H
KEYUP:  CPI     09H
        JZ      KTAB
        CPI     'W'
        JZ      KUP
        CPI     'S'
        JZ      KDOWN
        CPI     ' '
        JZ      KMARK
        CPI     '
        INX     H
        DCR     B
        JNZ     RDFILL
        MVI     B,24
        XRA     A
RDZERO: MOV     M,A
        INX     H
        DCR     B
        JNZ     RDZERO
        LHLD    CNTPTR
        MVI     M,0
        LXI     D,DIRBUFC'
        JZ      KCOPY
        CPI     'D'
        JZ      KDEL
        CPI     'R'
        JZ      KREN
        CPI     'V'
        JZ      KDRIVE
        CPI     'Q'
        JZ      KQUIT
        JMP     KEYLOOP

KTAB:   LDA     ACTIVE
   
        MVI     C,SETDMA
        CALL    BDOS
        LXI     D,SRCHFCB
        MVI     C,SFIRST
        CALL    BDOS
RDLOOP: CPI     0FFH
        JZ      RDDONE
        ANI     03H
        RLC
        RLC
        RLC
        RLC
        RLC
        MOV     E,A
        MVI     D,0
        LXI     H,DIRBUF
        DAD     D
        INX     H
        SHLD    DIRPTR
        LXI     D,8
        DAD     D
        MVI     B,0
        MOV     A,M
        ANI     80H
        JZ      RDATTR      LHLD    ENTRYPTR
        LXI     D,12
        DAD     D
        LDA     SRCFCB+33
        MOV     M,A
        INX     H
        LDA     SRCFCB+34
        MOV     M,A
        INX     H
        LDA     SRCFCB+35
        MOV     M,A
        RS
        MVI     B,1
RDATTRS:INX     H
        MOV     A,M
        ANI     80H
        JZ      RDATTRA
        MOV     A,B
        ORI     2
        MOV     B,A
RDATTRA:INX     H
        MOV     A,M
        ANI     80H
        JZ      RDATTRDET

NORML:  LDA     LCOUNT
        MOV     B,A
        LDA     LCUR
        CALL    NORM
        STA     LCUR
        CPI     ROWS
        JC      NORMZL
        SUI     ROWS-1
        JMP     NORMSL
NORMZL: XRA     A
NORMSL:
        STA     L
        MOV     A,B
        ORI     4
        MOV     B,A
RDATTRD:MOV     A,B
        STA     ATTRTMP
        LHLD    DIRPTR
        XCHG
        LHLD    STOREPTR
        MVI     B,11
RDCOPY: LDAX    D
        ANI     7FH
        MOV     M,A
 TOP
        RET

NORMR:  LDA     RCOUNT
        MOV     B,A
        LDA     RCUR
        CALL    NORM
        STA     RCUR
        CPI     ROWS
        JC      NORMZR
        SUI     ROWS-1
        JMP     NORMSR
NORMZR: XRA     A
NORMSR:
          INX     D
        INX     H
        DCR     B
        JNZ     RDCOPY
        MVI     M,0
        INX     H
        MVI     M,0
        INX     H
        MVI     M,0
        INX     H
        MVI     M,0FFH
        INX     H
        LDA       STA     RTOP
        RET

NORM:   MOV     C,A
        MOV     A,B
        ORA     A
        JZ      NORMZERO
        MOV     A,C
        CMP     B
        RC
        MOV     A,B
        DCR     A
        RET
NORMZERO:
        XRA     A
   ATTRTMP
        MOV     M,A
        INX     H
        SHLD    STOREPTR
        LHLD    CNTPTR
        INR     M
        MOV     A,M
        CPI     MAXFILE
        JZ      RDDONE
        LXI     D,SRCHFCB
        MVI     C,SNEXT
        CALL         RET

; ---------------------------------------------------------------------------
; Screen drawing

DRAW:   MVI     A,0CH
        CALL    PUTC
        CALL    DRAWL
        CALL    DRAWR
        CALL    DRAWHELP
        RET

DRAWHELP:   BDOS
        JMP     RDLOOP

RDDONE: RET

; Resolve an entry's size only when its row becomes active. Byte 14 of the
; panel entry is FFH until BDOS function 35 has populated bytes 12-14.
ENSURESIZE:
        LDA     LINEIDX
        CALL    PENT
        MVI     B,23
        MVI     C,0
        CALL    POS
        MVI     A,INVATT
        CALL    SETATTR
        MVI     A,1BH
        CALL    PUTC
        MVI     A,'K'
        CALL    PUTC
        LXI     H,HELP
        CALL    PRINTZ
  RY
        SHLD    ENTRYPTR
        LXI     D,14
        DAD     D
        MOV     A,M
        CPI     0FFH
        RNZ
        LXI     H,SRCFCB
        CALL    CLEAR36
        LDA     PDRIVE
        STA     SRCFCB
        LHLD    ENTRYPTR
          MVI     A,NORMATT
        CALL    SETATTR
        XRA     A
        STA     FOOTMSG
        RET

DRAWL:  CALL    SETL
        CALL    DRAWP
        RET

SETL:   XRA     A
        STA     PCOL
        LDA     LDRIVE
        STA     PDRIVE    XCHG
        LXI     H,SRCFCB+1
        MVI     B,11
RDSZCP: LDAX    D
        MOV     M,A
        INX     D
        INX     H
        DCR     B
        JNZ     RDSZCP
        LXI     D,SRCFCB
        MVI     C,FSIZE
        CALL    BDOS
  
        LDA     LCOUNT
        STA     PCOUNT
        LDA     LCUR
        STA     PCUR
        LDA     LTOP
        STA     PTOP
        LXI     H,LFILES
        SHLD    PLIST
        LDA     ACTIVE
        XRI     1
        STA     PACTIVE
        RET

DRAWR:  CALL    SETR
        CALL    DRAWP
        RET

SETR:   MVI     A,41
        STA     PCOL
        LDA     RDRIVE
        STA     PDRIVE
        LDA     RCOUNT
        STA     PCOUNT
        LDA     RCUR
        STA     PCUR   JZ      DPHDOWN
        MVI     A,'v'
DPHDOWN:CALL    PUTC
        MVI     A,NORMATT
        CALL    SETATTR
        RET

DRAWROWS:
        LDA     PTOP
        STA     DRAWIDX
        MVI     A,FIRST
        STA     DRAWROW
        MVI     
        LDA     RTOP
        STA     PTOP
        LXI     H,RFILES
        SHLD    PLIST
        LDA     ACTIVE
        STA     PACTIVE
        RET

DRAWP:  CALL    DRAWHDR
        CALL    DRAWROWS
        RET

DRAWHDR:
        MVI     A,INVA,ROWS
        STA     DRAWLEFT
DPLOOP: LDA     DRAWROW
        CALL    DRAWLINE
        LDA     DRAWIDX
        INR     A
        STA     DRAWIDX
        LDA     DRAWROW
        INR     A
        STA     DRAWROW
        LDA     DRAWLEFT
       ATT
        STA     LINEATT
        LDA     PACTIVE
        ORA     A
        JZ      DPHATTR
        MVI     A,BOLDINV
        STA     LINEATT
DPHATTR:MVI     B,0
        LDA     PCOL
        MOV     C,A
        CALL    POS
        LDA     LINE DCR     A
        STA     DRAWLEFT
        JNZ     DPLOOP
        RET

DRAWLINE:
        LDA     DRAWIDX
        STA     LINEIDX
        MOV     D,A
        LDA     PCOUNT
        CMP     D
        MVI     A,0
        JC      DLVALID
        ATT
        CALL    SETATTR
        MVI     B,39
DPHCLR: MVI     A,' '
        CALL    PUTC
        DCR     B
        JNZ     DPHCLR
        MVI     B,0
        LDA     PCOL
        MOV     C,A
        CALL    POS
        LDA     PACTIVE
      JZ      DLVALID
        MVI     A,1
DLVALID:STA     LINEOK
        MVI     A,NORMATT
        STA     LINEATT
        LDA     LINEOK
        ORA     A
        JZ      DLATTR
        LDA     PACTIVE
        ORA     A
        JZ      DLATTR
         ORA     A
        MVI     A,' '
        JZ      DPHMARK
        MVI     A,'*'
DPHMARK:CALL    PUTC
        LXI     H,DRIVEMSG
        CALL    PRINTZ
        LDA     PDRIVE
        ADI     'A'-1
        CALL    PUTC
        MVI     A,':'
       LDA     PCUR
        MOV     D,A
        LDA     LINEIDX
        CMP     D
        JNZ     DLATTR
        MVI     A,INVATT
        STA     LINEATT
DLATTR: LDA     DRAWROW
        MOV     B,A
        LDA     PCOL
        MOV     C,A
        CALL  CALL    PUTC
        MVI     A,' '
        CALL    PUTC
        MVI     A,' '
        CALL    PUTC
        LDA     PCOUNT
        CALL    PRINT3
        LXI     H,FILEMSG
        CALL    PRINTZ
        LDA     PCOUNT
        ORA     A
            POS
        LDA     LINEATT
        CALL    SETATTR
        MVI     B,39
DLBLANK:MVI     A,' '
        CALL    PUTC
        DCR     B
        JNZ     DLBLANK
        LDA     LINEOK
        ORA     A
        JZ      DLNORM
        LDA     DRAJZ      DPHPOS
        LDA     PCUR
        INR     A
DPHPOS: CALL    PRINT3
        MVI     A,'/'
        CALL    PUTC
        LDA     PCOUNT
        CALL    PRINT3
        MVI     A,' '
        CALL    PUTC
        LDA     PTOP
        ORA    WROW
        MOV     B,A
        LDA     PCOL
        MOV     C,A
        CALL    POS
        LDA     LINEIDX
        MOV     D,A
        LDA     PACTIVE
        ORA     A
        JZ      DLNOCUR
        LDA     PCUR
        CMP     D
        M A
        MVI     A,' '
        JZ      DPHUP
        MVI     A,'^'
DPHUP:  CALL    PUTC
        LDA     PTOP
        ADI     ROWS
        MOV     B,A
        LDA     PCOUNT
        CMP     B
        MVI     A,' '
        JC      DPHDOWN
     VI     A,' '
        JNZ     DLCURS
        MVI     A,'>'
        JMP     DLCURS
DLNOCUR:MVI     A,' '
DLCURS: CALL    PUTC
        LDA     LINEIDX
        CALL    PENTRY
        PUSH    H
        LXI     D,11
        DAD     D
        MOV     A,M
        ORA     A
        MVI     A,' '
        JZ      DLSEL
        MVI     A,'*'
DLSEL:  CALL    PUTC
        MVI     A,' '
        CALL    PUTC
        POP     H
        PUSH    H
        CALL    PRINTNAME
        POP     H
        MVI          MOV     A,L
        ADI     '0'
        CALL    PUTC
        RET

PRINT5: XRA     A
        STA     LEAD
        LXI     D,10000
        CALL    PDIV
        LXI     D,1000
        CALL    PDIV
        LXI     D,100
        CALL    PDIV   A,' '
        CALL    PUTC
        PUSH    H
        LXI     D,14
        DAD     D
        MOV     A,M
        CPI     0FFH
        JZ      DLUNKSZ
        DCX     H
        DCX     H
        MOV     E,M
        INX     H
        MOV     D,
        LXI     D,10
        CALL    PDIV
        MOV     A,L
        ADI     '0'
        CALL    PUTC
        RET

PDIV:   MVI     B,0
PDLOOP: MOV     A,H
        CMP     D
        JC      PDDONE
        JNZ     PDSUB
        MOV     A,L
  M
        XCHG
        LXI     D,7
        DAD     D
        CALL    HALF
        CALL    HALF
        CALL    HALF
        CALL    PRINT5
        JMP     DLSIZED
DLUNKSZ:
        LXI     H,UNKSIZE
        CALL    PRINTZ
DLSIZED:
        MVI        CMP     E
        JC      PDDONE
PDSUB:  MOV     A,L
        SUB     E
        MOV     L,A
        MOV     A,H
        SBB     D
        MOV     H,A
        INR     B
        JMP     PDLOOP
PDDONE: MOV     A,B
        ORA     A
        JN   A,'K'
        CALL    PUTC
        MVI     A,' '
        CALL    PUTC
        POP     H
        LXI     D,15
        DAD     D
        MOV     A,M
        STA     ATTRTMP
        ANI     1
        MVI     A,'-'
        JZ      DLAR
        MZ     PDNUM
        LDA     LEAD
        ORA     A
        MVI     A,' '
        JZ      PDOUT
        MVI     A,'0'
        JMP     PDOUT
PDNUM:  MVI     A,1
        STA     LEAD
        MOV     A,B
        ADI     '0'
PDOUT:  CALL    PUTC
   VI     A,'R'
DLAR:   CALL    PUTC
        LDA     ATTRTMP
        ANI     2
        MVI     A,'-'
        JZ      DLAS
        MVI     A,'S'
DLAS:   CALL    PUTC
        LDA     ATTRTMP
        ANI     4
        MVI     A,'-'
        JZ      DLA     RET

HALF:   ORA     A
        MOV     A,H
        RAR
        MOV     H,A
        MOV     A,L
        RAR
        MOV     L,A
        RET

SETATTR:MOV     B,A
        MVI     A,1BH
        CALL    PUTC
        MVI     A,'0'
        CALA
        MVI     A,'A'
DLAA:   CALL    PUTC
DLNORM: MVI     A,NORMATT
        CALL    SETATTR
        RET

PENTRY: LHLD    PLIST
ENTRYA: ORA     A
        RZ
        LXI     D,ENTSIZ
ENTLOOP:DAD     D
        DCR     A
        JNZ     ENTLOOPL    PUTC
        MOV     A,B
        CALL    PUTC
        RET

POS:    PUSH    B
        MVI     A,1BH
        CALL    PUTC
        MVI     A,'Y'
        CALL    PUTC
        POP     B
        MOV     A,B
        ADI     20H
        CALL    P
        RET

PRINTNAME:
        MVI     B,8
PNBASE: MOV     A,M
        CALL    PUTC
        INX     H
        DCR     B
        JNZ     PNBASE
        MVI     A,'.'
        CALL    PUTC
        MVI     B,3
PNEXT:  MOV     A,M
        CALL  UTC
        MOV     A,C
        ADI     20H
        CALL    PUTC
        RET

STATUS: PUSH    H
        MVI     B,23
        MVI     C,0
        CALL    POS
        MVI     A,1BH
        CALL    PUTC
        MVI     A,'K'
        CALL    PUTC  PUTC
        INX     H
        DCR     B
        JNZ     PNEXT
        RET

PRINT3: MOV     L,A
        MVI     H,0
        XRA     A
        STA     LEAD
        LXI     D,100
        CALL    PDIV
        LXI     D,10
        CALL    PDIV

        POP     H
        CALL    PRINTZ
        MVI     A,1
        STA     FOOTMSG
        RET

; ---------------------------------------------------------------------------
; Navigation and marking

SAVENAV:LDA     ACTIVE
        ORA     A
        JNZ     SAVER
        LDA     LCUR
        STA     OLDCUR
        LDA     LTOP
        STA     OLDTOP
        RET
SAVER:  LDA     RCUR
        STA     OLDCUR
        LDA     RTOP
        STA     OLDTOP
        RET

NAVDRAW:LDA     ACTIVE     CALL    DRAWLINE
        RET

MOVEUP: LDA     ACTIVE
        ORA     A
        JNZ     RUP
        LDA     LCUR
        ORA     A
        RZ
        DCR     A
        STA     LCUR
        MOV     B,A
        LDA     LTOP
        MOV     C
        ORA     A
        JNZ     NAVR
        CALL    SETL
        JMP     NAVSET
NAVR:   CALL    SETR
NAVSET: LDA     PCUR
        MOV     B,A
        LDA     OLDCUR
        CMP     B
        JNZ     NAVCHG
        LDA     PTOP
        MOV  ,A
        MOV     A,B
        CMP     C
        RNC
        STA     LTOP
        RET
RUP:    LDA     RCUR
        ORA     A
        RZ
        DCR     A
        STA     RCUR
        MOV     B,A
        LDA     RTOP
        MOV     C,A
         B,A
        LDA     OLDTOP
        CMP     B
        RZ
NAVCHG:CALL    DRAWHDR
        LDA     PTOP
        MOV     B,A
        LDA     OLDTOP
        CMP     B
        JZ      NAVROWS
        CALL    DRAWROWS
        RET
NAVROWS:
        L  MOV     A,B
        CMP     C
        RNC
        STA     RTOP
        RET

MOVEDOWN:
        LDA     ACTIVE
        ORA     A
        JNZ     RDOWN
        LDA     LCOUNT
        MOV     B,A
        LDA     LCUR
        INR     A
        CDA     OLDCUR
        STA     DRAWIDX
        MOV     B,A
        LDA     PTOP
        MOV     C,A
        MOV     A,B
        SUB     C
        ADI     FIRST
        STA     DRAWROW
        CALL    DRAWLINE
        LDA     PCUR
        MOV     MP     B
        RNC
        STA     LCUR
        MOV     B,A
        LDA     LTOP
        ADI     ROWS
        CMP     B
        JC      LDSCROLL
        JZ      LDSCROLL
        RET
LDSCROLL:
        LDA     LTOP
        INR     A
        STB,A
        LDA     OLDCUR
        CMP     B
        RZ
        MOV     A,B
        STA     DRAWIDX
        MOV     B,A
        LDA     PTOP
        MOV     C,A
        MOV     A,B
        SUB     C
        ADI     FIRST
        STA     DRAWROWA     LTOP
        RET
RDOWN:  LDA     RCOUNT
        MOV     B,A
        LDA     RCUR
        INR     A
        CMP     B
        RNC
        STA     RCUR
        MOV     B,A
        LDA     RTOP
        ADI     ROWS
        CMP     B
       
        CALL    DRAWLINE
        RET

REDRAWC:LDA     ACTIVE
        ORA     A
        JNZ     REDRAWR
        CALL    SETL
        JMP     REDSET
REDRAWR:CALL    SETR
REDSET: CALL    DRAWCUR
        RET

LOADCURSIZE:
        LDA     ACTIVE JC      RDSCROLL
        JZ      RDSCROLL
        RET
RDSCROLL:
        LDA     RTOP
        INR     A
        STA     RTOP
        RET

MARKFILE:
        LDA     ACTIVE
        ORA     A
        JNZ     RMARK
        LDA     LCOUNT
        
        ORA     A
        JNZ     LCSR
        CALL    SETL
        JMP     LCSSET
LCSR:   CALL    SETR
LCSSET: LDA     PCOUNT
        ORA     A
        RZ
        LDA     PCUR
        STA     LINEIDX
        CALL    ENSURESIZE
        RET

DORA     A
        RZ
        LDA     LCUR
        LXI     H,LFILES
        JMP     DOMARK
RMARK:  LDA     RCOUNT
        ORA     A
        RZ
        LDA     RCUR
        LXI     H,RFILES
DOMARK: SHLD    WORKLIST
        CALL    WENTRY
        RAWCUR:LDA     PCOUNT
        ORA     A
        RZ
        LDA     PCUR
        STA     DRAWIDX
        MOV     B,A
        LDA     PTOP
        MOV     C,A
        MOV     A,B
        SUB     C
        ADI     FIRST
        STA     DRAWROW
   LXI     D,11
        DAD     D
        MOV     A,M
        XRI     1
        MOV     M,A
        RET

WENTRY: LHLD    WORKLIST
        JMP     ENTRYA

PICKDRIVE:
        CALL    SHOWDRIVES
PDKEY:  CALL    GETKEY
        CPI     1BH
        RZ
        CPI     'a'
        JC      PDUP
        CPI     'z'+1
        JNC     PDUP
        SUI     20H
PDUP:   CPI     'A'
        JC      PDKEY
        CPI     'G'
        JNC     PDKEY
        SUI     'A'-1
        MOV     B,A
        PUSH NEXT
        JMP     CPONE
CPCUR:  LDA     SCUR
        CMP     B
        JNZ     CPNEXT
CPONE:  MOV     A,B
        CALL    SENTRY
        SHLD    ENTRYPTR
        LDA     CPNUM
        INR     A
        STA     CPNUM
        CALL    SHOWCOPY
   B
        CALL    SHOWREAD
        POP     B
        LDA     ACTIVE
        ORA     A
        JNZ     PDRIGHT
        MOV     A,B
        STA     LDRIVE
        CALL    LOADL
        RET
PDRIGHT:MOV     A,B
        STA     RDRIVE
        CAL        CALL    COPYONE
CPNEXT: LDA     LOOPIDX
        INR     A
        STA     LOOPIDX
        JMP     CPLOOP
CPDONE: CALL    LOADL
        CALL    LOADR
        CALL    DRAW
        LDA     OPERROR
        ORA     A
        JNZ     SHOWCPERRL    LOADR
        RET

SHOWDRIVES:
        CALL    MODBOX
        MVI     B,9
        MVI     C,34
        CALL    POS
        LXI     H,DRVHEAD
        CALL    PRINTZ
        MVI     B,10
        MVI     C,29
        CALL    POS
        LXI 
        CALL    SHOWCPDONE
        RET

SHOWCPERR:
        CALL    SHOWERROR
        RET

SETSOURCE:
        LDA     ACTIVE
        ORA     A
        JNZ     SRCRIGHT
        LDA     LDRIVE
        STA     SRCDRIVE
        LDA     RDRIVE
       H,DRVOPTS
        CALL    PRINTZ
        MVI     B,11
        MVI     C,27
        CALL    POS
        LXI     H,DRVPROMPT
        CALL    PRINTZ
        MVI     B,12
        MVI     C,26
        CALL    POS
        LXI     H,DRVREADY
           STA     DSTDRIVE
        LDA     LCOUNT
        STA     SCOUNT
        LDA     LCUR
        STA     SCUR
        LXI     H,LFILES
        SHLD    SLIST
        RET
SRCRIGHT:
        LDA     RDRIVE
        STA     SRCDRIVE
        LDA     LD  CALL    PRINTZ
        MVI     A,NORMATT
        CALL    SETATTR
        RET

; ---------------------------------------------------------------------------
; Copy

COPYFILES:
        CALL    SETSOURCE
        LDA     SRCDRIVE
        MOV     BRIVE
        STA     DSTDRIVE
        LDA     RCOUNT
        STA     SCOUNT
        LDA     RCUR
        STA     SCUR
        LXI     H,RFILES
        SHLD    SLIST
        RET

FINDSEL:XRA     A
        STA     LOOPIDX
FSLOOP: LDA     LOOPIDX,A
        LDA     DSTDRIVE
        CMP     B
        JNZ     CPDIFF
        LXI     H,SAMEDRV
        CALL    STATUS
        RET
CPDIFF:
        LDA     SCOUNT
        ORA     A
        JNZ     CPHAVE
        LXI     H,NOFILES
        CALL    
        MOV     B,A
        LDA     SCOUNT
        CMP     B
        JZ      FSNONE
        MOV     A,B
        CALL    SENTRY
        LXI     D,11
        DAD     D
        MOV     A,M
        ORA     A
        MVI     A,1
        RNZ
       STATUS
        RET
CPHAVE: CALL    FINDSEL
        STA     SELMODE
        CALL    COUNTCP
        XRA     A
        STA     OPERROR
        STA     LOOPIDX
        STA     CPNUM
CPLOOP: LDA     LOOPIDX
        MOV     B,A
        LDA     SCOUNT LDA     LOOPIDX
        INR     A
        STA     LOOPIDX
        JMP     FSLOOP
FSNONE: XRA     A
        RET

COUNTCP:LDA     SELMODE
        ORA     A
        JNZ     CCSEL
        MVI     A,1
        STA     CPTOTAL
        RET
CCSEL:  XR
        CMP     B
        JZ      CPDONE
        LDA     SELMODE
        ORA     A
        JZ      CPCUR
        MOV     A,B
        CALL    SENTRY
        LXI     D,11
        DAD     D
        MOV     A,M
        ORA     A
        JZ      CPA     A
        STA     CPTOTAL
        STA     LOOPIDX
CCLOOP: LDA     LOOPIDX
        MOV     B,A
        LDA     SCOUNT
        CMP     B
        RZ
        MOV     A,B
        CALL    SENTRY
        LXI     D,11
        DAD     D
        MOV     A,M
        ORA     A
        JZ      CCNEXT
        LDA     CPTOTAL
        INR     A
        STA     CPTOTAL
CCNEXT: LDA     LOOPIDX
        INR     A
        STA     LOOPIDX
        JMP     CCLOOP

SENTRY: LHLD    SLIST
        JMP       JNC     OVUP
        SUI     20H
OVUP:   CPI     'Y'
        JZ      OVYES
        CPI     'N'
        JNZ     OVKEY
        XRA     A
        RET
OVYES:  CALL    SHOWCOPY
        MVI     A,1
        RET

; Four-row inverse-video copy modal. ENTRYA

COPYONE:
        CALL    BUILDFCBS
        LXI     D,DIRBUF
        MVI     C,SETDMA
        CALL    BDOS
        LXI     D,DSTFCB
        MVI     C,SFIRST
        CALL    BDOS
        CPI     0FFH
        JZ      CPNEW
        CALL    It deliberately stays clear of row 23,
; so the keyboard legend remains visible throughout the operation.
MODBOX: MVI     B,9
MBLOOP:CALL    MODROW
        INR     B
        MOV     A,B
        CPI     13
        JNZ     MBLOOP
        RET

MODR ASKOVER
        ORA     A
        RZ
        CALL    BUILDFCBS
        LXI     D,DSTFCB
        MVI     C,DELETE
        CALL    BDOS
CPNEW:  CALL    BUILDFCBS
        LXI     D,SRCFCB
        MVI     C,OPENF
        CALL    BDOS
        CPI   OW:MOV     A,B
        STA     MODROWNO
        MVI     C,20
        CALL    POS
        MVI     A,INVATT
        CALL    SETATTR
        MVI     D,40
MRCLEAR:MVI     A,' '
        CALL    PUTC
        DCR     D
        JNZ     MRCLEAR
        L  0FFH
        JZ      CPFAIL
        LXI     D,DSTFCB
        MVI     C,MAKEF
        CALL    BDOS
        CPI     0FFH
        JZ      CPMKERR
CPRECORD:
        LXI     D,BUFFER
        MVI     C,SETDMA
        CALL    BDOS
        LXI     D,SDA     MODROWNO
        MOV     B,A
        MVI     C,20
        CALL    POS
        RET

SHOWCOPY:
        CALL    MODBOX
        MVI     B,9
        MVI     C,32
        CALL    POS
        LXI     H,CPHEAD
        CALL    PRINTZ
        MVIRCFCB
        MVI     C,READSEQ
        CALL    BDOS
        ORA     A
        JNZ     CPCLOSE
        LXI     D,BUFFER
        MVI     C,SETDMA
        CALL    BDOS
        LXI     D,DSTFCB
        MVI     C,WRITSEQ
        CALL    BDOS
            B,10
        MVI     C,22
        CALL    POS
        LXI     H,CPFILE
        CALL    PRINTZ
        LHLD    ENTRYPTR
        CALL    PRINTSHORT
        MVI     B,11
        MVI     C,29
        CALL    POS
        LXI     H,CPSTEP
        ORA     A
        JZ      CPRECORD
        MVI     A,1
        STA     OPERROR
CPCLOSE:LXI     D,DSTFCB
        MVI     C,CLOSEF
        CALL    BDOS
        LXI     D,SRCFCB
        MVI     C,CLOSEF
        CALL    BDOS
        RET
CPMKERR:LXI CALL    PRINTZ
        LDA     CPNUM
        CALL    PRINT3
        LXI     H,CPOF
        CALL    PRINTZ
        LDA     CPTOTAL
        CALL    PRINT3
        MVI     B,12
        MVI     C,34
        CALL    POS
        LXI     H,CPWAIT
         D,SRCFCB
        MVI     C,CLOSEF
        CALL    BDOS
CPFAIL: MVI     A,1
        STA     OPERROR
        RET

ASKOVER:CALL    MODBOX
        MVI     B,10
        MVI     C,22
        CALL    POS
        LXI     H,OVER1
        CALL    PR    CALL    PRINTZ
        MVI     A,NORMATT
        CALL    SETATTR
        RET

SHOWCPDONE:
        CALL    MODBOX
        MVI     B,10
        MVI     C,33
        CALL    POS
        LXI     H,COPYOK
        CALL    PRINTZ
        JMP     SINTZ
        LHLD    ENTRYPTR
        CALL    PRINTSHORT
        LXI     H,OVER2
        CALL    PRINTZ
        MVI     A,NORMATT
        CALL    SETATTR
OVKEY:  CALL    GETKEY
        CPI     'a'
        JC      OVUP
        CPI     'z'+1
     HOWACK

SHOWERROR:
        CALL    MODBOX
        MVI     B,10
        MVI     C,25
        CALL    POS
        LXI     H,COPYERR
        CALL    PRINTZ
SHOWACK:MVI     B,11
        MVI     C,31
        CALL    POS
        LXI     H,CPACK
        CALL    PRINTZ
        MVI     A,NORMATT
        CALL    SETATTR
        MVI     A,1
        STA     MODAL
        RET

BUILDFCBS:
        LXI     H,SRCFCB
        CALL    CLEAR36
        LXI     H,DSTFCB
        CALL    CLEAR36
        LDADONE:CALL    LOADL
        CALL    LOADR
        CALL    DRAW
        LDA     OPERROR
        ORA     A
        LXI     H,DELOK
        JZ      DELSTAT
        LXI     H,DELERR
DELSTAT:CALL    STATUS
        RET

BUILDSRC:
        LXI     H,SRC     SRCDRIVE
        STA     SRCFCB
        LDA     DSTDRIVE
        STA     DSTFCB
        LHLD    ENTRYPTR
        XCHG
        LXI     H,SRCFCB+1
        MVI     B,11
BFSRC:  LDAX    D
        MOV     M,A
        INX     D
        INX     HFCB
        CALL    CLEAR36
        LDA     SRCDRIVE
        STA     SRCFCB
        LHLD    ENTRYPTR
        XCHG
        LXI     H,SRCFCB+1
        MVI     B,11
BSONE:  LDAX    D
        MOV     M,A
        INX     D
        INX     H
        
        DCR     B
        JNZ     BFSRC
        LHLD    ENTRYPTR
        XCHG
        LXI     H,DSTFCB+1
        MVI     B,11
BFDST:  LDAX    D
        MOV     M,A
        INX     D
        INX     H
        DCR     B
        JNZ     BFDST
   DCR     B
        JNZ     BSONE
        RET

; ---------------------------------------------------------------------------
; Rename

RENFILE:LDA     ACTIVE
        ORA     A
        JNZ     RENR
        LDA     LCOUNT
        ORA     A
             RET

; ---------------------------------------------------------------------------
; Delete

DELFILES:
        CALL    SETSOURCE
        LDA     SCOUNT
        ORA     A
        JNZ     DELHAVE
        LXI     H,NOFILES
        CALL    STATJZ      RENNONE
        LDA     LDRIVE
        STA     SRCDRIVE
        LDA     LCUR
        LXI     H,LFILES
        JMP     RENSET
RENR:   LDA     RCOUNT
        ORA     A
        JZ      RENNONE
        LDA     RDRIVE
        STA     SRCDRIVEUS
        RET
DELHAVE:CALL    FINDSEL
        STA     SELMODE
        LXI     H,DELASK
        CALL    STATUS
        CALL    YESNO
        ORA     A
        RZ
        XRA     A
        STA     OPERROR
        STA     LOOPIDX
DELLOOP:LDA     
        LDA     RCUR
        LXI     H,RFILES
RENSET: SHLD    WORKLIST
        CALL    WENTRY
        SHLD    ENTRYPTR
        CALL    GETNEW
        ORA     A
        RZ
        CALL    NEWEXISTS
        ORA     A
        JZ      RENDO
       LOOPIDX
        MOV     B,A
        LDA     SCOUNT
        CMP     B
        JZ      DELDONE
        LDA     SELMODE
        ORA     A
        JZ      DELCUR
        MOV     A,B
        CALL    SENTRY
        LXI     D,11
        DAD     D
     LXI     H,NAMEUSED
        CALL    STATUS
        RET
RENDO:  CALL    BUILDREN
        LXI     D,SRCFCB
        MVI     C,RENAME
        CALL    BDOS
        CPI     0FFH
        LXI     H,RENOK
        JNZ     RENRES
        LXI     H,RENERR
R    MOV     A,M
        ORA     A
        JZ      DELNEXT
        JMP     DELONE
DELCUR: LDA     SCUR
        CMP     B
        JNZ     DELNEXT
DELONE: MOV     A,B
        CALL    SENTRY
        SHLD    ENTRYPTR
        CALL    BUILDSRC
        ENRES: PUSH    H
        CALL    LOADL
        CALL    LOADR
        CALL    DRAW
        POP     H
        CALL    STATUS
        RET
RENNONE:LXI     H,NOFILES
        CALL    STATUS
        RET

GETNEW: LXI     H,NEWBUF
        MVI     M,0
 LXI     D,SRCFCB
        MVI     C,DELETE
        CALL    BDOS
        CPI     0FFH
        JNZ     DELNEXT
        MVI     A,1
        STA     OPERROR
DELNEXT:LDA     LOOPIDX
        INR     A
        STA     LOOPIDX
        JMP     DELLOOP
DEL       SHLD    INPTR
        XRA     A
        STA     INLEN
        LXI     H,NEWASK
        CALL    STATUS
GNKEY:  CALL    GETKEY
        CPI     1BH
        JZ      GNCANCEL
        CPI     0DH
        JZ      GNDONE
        CPI     08H
        JZ      GNBACK
        CPI     7FH
        JZ      GNBACK
        CPI     'a'
        JC      GNUP
        CPI     'z'+1
        JNC     GNUP
        SUI     20H
GNUP:   CPI     21H
        JC      GNKEY
        CPI     7FH
        JNC     GN   B
        INX     H
        JMP     PNLOOP
PNEXTC: MOV     A,B
        CPI     3
        JNC     PNBAD
        MOV     A,M
        STAX    D
        INX     D
        INR     B
        INX     H
        JMP     PNLOOP
PNDOT:  MOV     A,C
  KEY
        MOV     B,A
        LDA     INLEN
        CPI     12
        JNC     GNKEY
        MOV     A,B
        LHLD    INPTR
        MOV     M,A
        INX     H
        MVI     M,0
        SHLD    INPTR
        LDA     INLEN
        INR        ORA     A
        JNZ     PNBAD
        MOV     A,B
        ORA     A
        JZ      PNBAD
        MVI     C,1
        MVI     B,0
        LXI     D,NEWNAME+8
        INX     H
        JMP     PNLOOP
PNEND:  MOV     A,C
        ORA     A   A
        STA     INLEN
        MOV     A,B
        CALL    PUTC
        JMP     GNKEY
GNBACK: LDA     INLEN
        ORA     A
        JZ      GNKEY
        DCR     A
        STA     INLEN
        LHLD    INPTR
        DCX     H
        SHLD
        JZ      PNBCHK
        MOV     A,B
        ORA     A
        JZ      PNBAD
PNBCHK: LDA     NEWNAME
        CPI     ' '
        JZ      PNBAD
        MVI     A,1
        RET
PNBAD:  LXI     H,BADNAME
        CALL    STATUS
        XRA       INPTR
        MVI     M,0
        MVI     A,08H
        CALL    PUTC
        MVI     A,' '
        CALL    PUTC
        MVI     A,08H
        CALL    PUTC
        JMP     GNKEY
GNDONE: CALL    PARSENEW
        RET
GNCANCEL:
        XRA       A
        RET

NEWEXISTS:
        LXI     H,DSTFCB
        CALL    CLEAR36
        LDA     SRCDRIVE
        STA     DSTFCB
        LXI     H,NEWNAME
        LXI     D,DSTFCB+1
        MVI     B,11
NECOPY: MOV     A,M
        STAX    D
      A
        RET

PARSENEW:
        LXI     H,NEWNAME
        MVI     B,11
        MVI     A,' '
PNCLR:  MOV     M,A
        INX     H
        DCR     B
        JNZ     PNCLR
        LXI     H,NEWBUF
        LXI     D,NEWNAME
        MVI     B,0  INX     H
        INX     D
        DCR     B
        JNZ     NECOPY
        LXI     D,DIRBUF
        MVI     C,SETDMA
        CALL    BDOS
        LXI     D,DSTFCB
        MVI     C,SFIRST
        CALL    BDOS
        CPI     0FFH
        MVI
        MVI     C,0
PNLOOP: MOV     A,M
        ORA     A
        JZ      PNEND
        CPI     '.'
        JZ      PNDOT
        CPI     '*'
        JZ      PNBAD
        CPI     '?'
        JZ      PNBAD
        CPI     '/'
        JZ      PN     A,0
        RZ
        MVI     A,1
        RET

BUILDREN:
        CALL    BUILDSRC
        LDA     SRCDRIVE
        STA     SRCFCB+16
        LXI     H,NEWNAME
        LXI     D,SRCFCB+17
        MVI     B,11
BRCOPY: MOV     A,M
        SBAD
        CPI     ':'
        JZ      PNBAD
        CPI     ';'
        JZ      PNBAD
        CPI     '<'
        JZ      PNBAD
        CPI     '='
        JZ      PNBAD
        CPI     '>'
        JZ      PNBAD
        CPI     '['
        JZTAX    D
        INX     H
        INX     D
        DCR     B
        JNZ     BRCOPY
        RET

; ---------------------------------------------------------------------------
; Common helpers

YESNO:  CALL    GETKEY
        CPI     'a'
            PNBAD
        CPI     ']'
        JZ      PNBAD
        MOV     A,C
        ORA     A
        JNZ     PNEXTC
        MOV     A,B
        CPI     8
        JNC     PNBAD
        MOV     A,M
        STAX    D
        INX     D
        INR    JC      YNUP
        CPI     'z'+1
        JNC     YNUP
        SUI     20H
YNUP:   CPI     'Y'
        JZ      YNYES
        CPI     'N'
        JNZ     YESNO
        XRA     A
        RET
YNYES:  MVI     A,1
        RET

CLEAR36:MVI     B,36
        XRA     A
C36LOOP:MOV     M,A
        INX     H
        DCR     B
        JNZ     C36LOOP
        RET

PRINTSHORT:
        PUSH    H
        MVI     B,8
PSBASE: MOV     A,M
        CPI     ' '
        CZ      PSNOP
        CNZ     Y  D DELETE'
        DB      '  R RENAME  V DRIVE  Q QUIT',0
DRIVEMSG:
        DB      ' DRIVE ',0
FILEMSG:DB      ' FILES ',0
DRVHEAD:DB      'SELECT DRIVE',0
DRVOPTS:DB      'A:  B:  C:  D:  E:  F:',0
DRVPROMPT:
        DB      'PRESS A-F OR ESC PUTC
        INX     H
        DCR     B
        JNZ     PSBASE
        POP     H
        LXI     D,8
        DAD     D
        MOV     A,M
        CPI     ' '
        RZ
        MVI     A,'.'
        CALL    PUTC
        MVI     B,3
PSEXT:  MTO CANCEL',0
DRVREADY:
        DB      'INSERT DISK BEFORE SELECTING',0
BYEMSG: DB      'P2FILE finished.',13,10,0
NOFILES:DB      'No files in the active panel.',0
SAMEDRV:DB      'Choose two different drives before copying.',0
COPYOK: DB      'CopyOV     A,M
        CPI     ' '
        CZ      PSNOP
        CNZ     PUTC
        INX     H
        DCR     B
        JNZ     PSEXT
PSNOP:  RET

PRINTZ: MOV     A,M
        ORA     A
        RZ
        CALL    PUTC
        INX     H
        J complete.',0
COPYERR:DB      'Copy finished with a disk error.',0
CPHEAD: DB      'COPYING FILES',0
CPFILE: DB      'FILE: ',0
CPSTEP: DB      'FILE ',0
CPOF:   DB      ' OF ',0
CPWAIT: DB      'PLEASE WAIT',0
CPACK:  DB      'PRESS A KEY TO CONTINMP     PRINTZ

PUTC:   PUSH    B
        PUSH    D
        PUSH    H
        MOV     E,A
        MVI     C,CONOUT
        CALL    BDOS
        POP     H
        POP     D
        POP     B
        RET

GETKEY: PUSH    B
        PUSH    D
   UE',0
OVER1:  DB      'Overwrite ',0
OVER2:  DB      '? (Y/N)',0
DELASK: DB      'Delete selected file(s)? (Y/N)',0
DELOK:  DB      'Delete complete.',0
DELERR: DB      'Delete finished with an error.',0
NEWASK: DB      'New name (ESC cancels): ',0
     PUSH    H
GKWAIT: MVI     E,0FFH
        MVI     C,DIRIO
        CALL    BDOS
        ORA     A
        JZ      GKWAIT
        POP     H
        POP     D
        POP     B
        RET

SHOWSTART:
        PUSH    PSW
        MVI     A,0CHBADNAME:DB      'Invalid CP/M 8.3 filename.',0
NAMEUSED:
        DB      'That filename already exists.',0
RENOK:  DB      'Rename complete.',0
RENERR: DB      'Rename failed.',0

ACTIVE: DB      0
LDRIVE: DB      1
RDRIVE: DB      2
LCOUNT: DB   
        CALL    PUTC
        LXI     H,STARTMSG
        CALL    PRINTZ
        POP     PSW
        ADI     'A'-1
        CALL    PUTC
        MVI     A,':'
        CALL    PUTC
        LXI     H,WAITMSG
        CALL    PRINTZ
        RET

SHO   0
RCOUNT: DB      0
LCUR:   DB      0
RCUR:   DB      0
LTOP:   DB      0
RTOP:   DB      0

PCOL:   DB      0
PDRIVE: DB      0
PCOUNT: DB      0
PCUR:   DB      0
PTOP:   DB      0
PACTIVE:DB      0
DRAWIDX:DB      0
DRAWROW:DB      0
DWREAD:
        PUSH    PSW
        LXI     H,READMSG
        CALL    STATUS
        POP     PSW
        ADI     'A'-1
        CALL    PUTC
        MVI     A,':'
        CALL    PUTC
        RET


                KEYFOOT:
 0132 3A6012            LDA     FOOTMSG
 0135 B7        ;     P2FILE
                ;
                ; Keys: TAB panel, W/S move, SPACE mark, C copy, D delete, R rename,
                ;       V choose drive, Q quit.

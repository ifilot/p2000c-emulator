        DB      0
LINEIDX:DB      0
LINEOK: DB      0
LINEATT:DB      NORMATT
OLDCUR: DB      0
OLDTOP: DB      0

SRCDRIVE:
        DB      0
DSTDRIVE:
        DB      0
SCOUNT: DB      0
SCUR:   DB      0
SELMODE:DB      0
LOOPIDX---------------------------
; Data

STARTMSG:
        DB      'P2FILE: READING DRIVE ',0
WAITMSG:DB      ' - PLEASE WAIT',0
READMSG:DB      'P2FILE: READING DRIVE ',0
UNKSIZE:DB      '    ?',0
HELP:   DB      'TAB PANEL  W/S MOVE  SPACE MARK  C COP:DB      0
OPERROR:DB      0
CPTOTAL:DB      0
CPNUM:  DB      0
MODAL:  DB      0
FOOTMSG:DB      0
KEYTMP: DB      0
MODROWNO:
        DB      0
INLEN:  DB      0
ATTRTMP:DB      0
LEAD:   DB      0

PLIST:  DW      0
SLIST:  DW      0
WORKLIST:
        DW      0
STOREPTR:
        DW      0
CNTPTR: DW      0
DIRPTR: DW      0
ENTRYPTR:
        DW      0
INPTR:  DW      0

SRCHFCB:DS      36
SRCFCB: DS      36
DSTFCB: DS      36
NEWNAME:DS      11
NEWBUF: DS      13
LFILES:DS ňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňňň     MAXFILE*ENTSIZ
RFILES:DS      MAXFILE*ENTSIZ
DIRBUF: DS      128
BUFFER: DS      128

        DS      128
STACK:


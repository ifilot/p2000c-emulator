root = true

[*.{c,cc,cpp,cxx,h,hh,hpp,hxx}]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true

[CMakeLists.txt]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true

[*.cmake]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
